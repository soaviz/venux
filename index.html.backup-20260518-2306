async function showFourcutResult(cutUrls, m) {
  stopFourcutStatus();

  // Build frame on canvas
  const W = 640, H = 1600;
  const canvas = document.createElement('canvas');
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');

  // Background
  ctx.fillStyle = '#0A0A0A';
  ctx.fillRect(0, 0, W, H);

  // Side strip (member gradient)
  const colors = m.gradient.match(/#[0-9A-Fa-f]{6}/g) || [m.badgeColor, m.badgeColor];
  const sideGrad = ctx.createLinearGradient(W - 16, 0, W - 16, H);
  sideGrad.addColorStop(0, colors[0]);
  sideGrad.addColorStop(1, colors[1] || colors[0]);
  ctx.fillStyle = sideGrad;
  ctx.fillRect(W - 16, 0, 16, H);

  // Header
  ctx.fillStyle = 'white';
  ctx.font = '500 28px Fraunces, serif';
  ctx.textAlign = 'center';
  ctx.fillText('VenuX × Me', W / 2 - 8, 60);
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.font = '500 14px "JetBrains Mono", monospace';
  ctx.fillText(getDateString(), W / 2 - 8, 82);

  // 4 cuts
  const cutSize = 296;
  const padX = (W - 16 - cutSize * 2 - 8) / 2;
  const startY = 110;
  const positions = [
    [padX, startY],
    [padX + cutSize + 8, startY],
    [padX, startY + cutSize + 8],
    [padX + cutSize + 8, startY + cutSize + 8]
  ];

  for (let i = 0; i < 4; i++) {
    const img = await loadImage(cutUrls[i]);
    const [x, y] = positions[i];
    ctx.save();
    roundedRect(ctx, x, y, cutSize, cutSize, 12);
    ctx.clip();
    ctx.drawImage(img, x, y, cutSize, cutSize);
    ctx.restore();
  }

  // Footer area below cuts
  const footerY = startY + cutSize * 2 + 8 + 40;
  ctx.fillStyle = 'rgba(255,255,255,0.7)';
  ctx.font = '600 18px "Noto Sans KR", sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText(`Memory with ${m.name}`, W / 2 - 8, footerY);
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.font = '400 12px "JetBrains Mono", monospace';
  ctx.fillText('VenuX Oracle · soaviz.github.io/LLM_ChatBot', W / 2 - 8, footerY + 24);

  // Trim canvas to actual content
  const trimH = footerY + 50;
  const trimCanvas = document.createElement('canvas');
  trimCanvas.width = W; trimCanvas.height = trimH;
  trimCanvas.getContext('2d').drawImage(canvas, 0, 0);

  const dataUrl = trimCanvas.toDataURL('image/png');
  const msg = getRandomMessage(fourcutSelectedMember);
  const tint = m.glow || 'rgba(107,91,214,0.08)';

  const resultDiv = document.getElementById('fourcutResult');
  resultDiv.style.display = 'block';
  resultDiv.innerHTML = `
    <div class="fourcut-frame">
      <img src="${dataUrl}" style="width:100%;border-radius:12px;">
    </div>
    <div class="member-msg-card" style="--msg-color:${m.badgeColor};--msg-tint:${tint}">
      <div class="member-msg-label">💌 ${m.name}가 너에게 해주고 싶은 말</div>
      <div class="member-msg-text">${msg}</div>
      <div class="member-msg-footer" style="color:${m.badgeColor}">— ${fourcutSelectedMember} · ${m.element}</div>
    </div>
    <div style="margin-top:16px;display:flex;gap:8px">
      <button class="bottom-btn secondary" style="flex:1" onclick="resetFourcut()">📸 다시찍자!</button>
      <button class="bottom-btn secondary" style="flex:1" onclick="downloadFourcut()">예쁘니까 저장! 💾</button>
    </div>
  `;
  resultDiv.scrollIntoView({ behavior: 'smooth' });
}

function roundedRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

