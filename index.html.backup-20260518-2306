      `;
      circle.style.position = 'relative';
      circle.style.overflow = 'visible';
      circle.appendChild(ripple);
      requestAnimationFrame(() => {
        ripple.style.transform = 'scale(2)';
        ripple.style.opacity = '0';
      });
      setTimeout(() => ripple.remove(), 550);
    });
  });

  // ── CTA 버튼 클릭 시 파티클 ─────────────────────
  const ctaBtn = document.getElementById('ctaBtn');
  if (ctaBtn) {
    ctaBtn.addEventListener('click', function() {
      if (this.disabled) return;
      for (let i = 0; i < 8; i++) {
        const p = document.createElement('span');
        const angle = (i / 8) * 360;
        const dist = 40 + Math.random() * 30;
        p.style.cssText = `
          position:fixed; width:5px; height:5px; border-radius:50%;
          background:${i%2===0 ? '#A78BFA' : '#67E8F9'};
          pointer-events:none; z-index:9999;
          left:${this.getBoundingClientRect().left + this.offsetWidth/2}px;
          top:${this.getBoundingClientRect().top + this.offsetHeight/2}px;
          transform:translate(-50%,-50%);
          transition:transform .5s ease, opacity .5s ease;
          opacity:1;
        `;
        document.body.appendChild(p);
        requestAnimationFrame(() => {
          const rad = angle * Math.PI / 180;
          p.style.transform = `translate(calc(-50% + ${Math.cos(rad)*dist}px), calc(-50% + ${Math.sin(rad)*dist}px)) scale(0)`;
          p.style.opacity = '0';
        });
        setTimeout(() => p.remove(), 550);
      }
    });
  }

  // ── 탭 스위치 시 활성 탭 글로우 리프레시 ────────
  document.querySelectorAll('.tab-bar-item').forEach(tab => {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.tab-bar-item').forEach(t => {
        t.style.removeProperty('filter');
      });
    });
  });

  // ── 예시 카드 호버 시 dot 컬러 변화 ─────────────
  document.addEventListener('mouseover', function(e) {
    const card = e.target.closest('.example-card');
    if (card) {
      const dot = card.querySelector('.example-dot');
      if (dot) dot.style.boxShadow = `0 0 8px ${dot.style.background || '#A78BFA'}`;
    }
  });
  document.addEventListener('mouseout', function(e) {
    const card = e.target.closest('.example-card');
    if (card) {
      const dot = card.querySelector('.example-dot');
      if (dot) dot.style.boxShadow = '';
    }
  });

  // ── 스크롤 시 헤더 강도 변화 ─────────────────────
  const landing = document.getElementById('screen-landing');
  if (landing) {
    landing.addEventListener('scroll', function() {
      const header = this.querySelector('.header');
      if (!header) return;
      const s = Math.min(this.scrollTop / 80, 1);
      header.style.borderBottomColor = `rgba(167,139,250,${0.18 + s*0.3})`;
    });
  }

  // ── input 글자 입력 시 카운터 컬러 변화 ──────────
  const ta = document.getElementById('questionInput');
  if (ta) {
    ta.addEventListener('input', function() {
      const counter = document.getElementById('charCounter');
      if (!counter) return;
      const ratio = this.value.length / 500;
      if (ratio > .8) counter.style.color = '#E8C97A';
      else if (ratio > .5) counter.style.color = '#A78BFA';
      else counter.style.color = 'rgba(139,130,170,.5)';
    });
  }

  // ── 페이지 첫 진입 시 순차 fade-in 애니메이션 ────
  function runEntrance() {
    const items = [
      '.header', '.daily-status-bar', '.member-row',
      '.headline-section', '.input-section',
      '.cta-section', '.examples-section'
    ];
    items.forEach((sel, i) => {
      const el = document.querySelector(sel);
      if (!el) return;
      el.style.opacity = '0';
      el.style.transform = 'translateY(16px)';
      el.style.transition = `opacity .4s ease ${i*80}ms, transform .4s ease ${i*80}ms`;
      requestAnimationFrame(() => {
        setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, 50 + i*80);
      });
    });
  }

  if (document.readyState === 'complete') runEntrance();
  else window.addEventListener('load', runEntrance);
})();
</script>
</body>
</html>
