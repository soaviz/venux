function parseResponse(raw) {
  const parts = raw.split('/');
  if (parts.length >= 2) {
    return { answer: parts.slice(0, -1).join('/').trim(), micDrop: parts[parts.length - 1].trim() };
  }
  const lines = raw.split('\n').filter(Boolean);
  return lines.length >= 2
    ? { answer: lines.slice(0, -1).join(' '), micDrop: lines[lines.length - 1] }
    : { answer: raw, micDrop: '' };
}

async function getMemberResponse(key, question, apiKey) {
  const model = localStorage.getItem('venux_ai_model') || 'gpt-4o';
  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: { 'Authorization': `Bearer ${apiKey}`, 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model,
      messages: [
        { role: 'system', content: MEMBER_SYSTEM_PROMPTS[key] },
        { role: 'user', content: question }
      ],
      temperature: 0.9,
      max_tokens: 200
    })
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw { status: res.status, error: err };
  }
  const data = await res.json();
  return data.choices[0].message.content.trim();
}

async function getVerdictFromApi(question, responses, apiKey) {
  const model = localStorage.getItem('venux_ai_model') || 'gpt-4o';
  const summaries = memberOrder.map(k => `${k} (${memberData[k].name}): ${responses[k] || '응답 없음'}`).join('\n');
  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: { 'Authorization': `Bearer ${apiKey}`, 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model,
      messages: [
        { role: 'system', content: '당신은 VenuX Oracle의 판정관입니다. 질문과 5명의 답변을 보고, 이 질문에 가장 적합한 멤버를 선택하세요. JSON으로만 답하세요: {"member":"코드네임","reason":"한 줄 이유"}' },
        { role: 'user', content: `질문: ${question}\n\n답변들:\n${summaries}` }
      ],
      temperature: 0.7,
      max_tokens: 100
    })
  });
  if (!res.ok) throw new Error('verdict failed');
  const data = await res.json();
  try {
    const txt = data.choices[0].message.content.trim();
    const match = txt.match(/\{[\s\S]*\}/);
    return match ? JSON.parse(match[0]) : null;
  } catch { return null; }
}

function pickVerdict(question) {
  const keywords = {
    'ARA-462': ['단호','솔직','직접','결단','빨리','그만','참지','화','싸움','헤어져','끊어','결정'],
    'LUX-299': ['의미','아름다','시각','관점','빛','거울','새롭','다르게','보이','미래'],
    'EUR-0K':  ['슬프','외로','울','감정','힘들','지쳐','위로','공감','이해','마음','눈물','괜찮'],
    'KIN-360': ['모험','도전','새로','변화','떠나','여행','다른','재밌','시작','자유','편도'],
    'ATP-X1':  ['왜','본질','진짜','의미','뿌리','원래','자연','근본','깊','생각','질문']
  };
  let best = 'ARA-462', maxScore = 0;
  const q = question.toLowerCase();
  for (const [key, words] of Object.entries(keywords)) {
    let score = 0;
    words.forEach(w => { if (q.includes(w)) score++; });
    if (score > maxScore) { maxScore = score; best = key; }
  }
  if (maxScore === 0) best = memberOrder[Math.floor(Math.random() * memberOrder.length)];
  return best;
}

function apiErrorMessage(err) {
  if (err.status === 401) return 'API Key가 유효하지 않아요. 설정을 확인해주세요.';
  if (err.status === 429) return '요청이 너무 많아요. 잠시 후 다시 시도해주세요.';
  if (err.status >= 500) return 'OpenAI 서버 오류. 잠시 후 다시 시도해주세요.';
  return '네트워크 연결을 확인해주세요.';
}

