const CONSENT_REQUIRED = ['terms','privacy','research'];
const CONSENT_ALL = ['terms','privacy','research','marketing'];
const _consentState = { terms:false, privacy:false, research:false, marketing:false };

function toggleConsentItem(key) {
  const el = document.getElementById('ci-'+key);
  el.classList.toggle('open');
}
function toggleConsentCheck(key) {
  _consentState[key] = !_consentState[key];
  document.getElementById('chk-'+key).classList.toggle('checked', _consentState[key]);
  _syncConsentAll();
  _validateConsent();
}
function toggleConsentAll() {
  const allChecked = CONSENT_ALL.every(k => _consentState[k]);
  CONSENT_ALL.forEach(k => {
    _consentState[k] = !allChecked;
    document.getElementById('chk-'+k).classList.toggle('checked', !allChecked);
  });
  document.getElementById('chk-all').classList.toggle('checked', !allChecked);
  _validateConsent();
}
function _syncConsentAll() {
  const allChecked = CONSENT_ALL.every(k => _consentState[k]);
  document.getElementById('chk-all').classList.toggle('checked', allChecked);
}
function _validateConsent() {
  const ok = CONSENT_REQUIRED.every(k => _consentState[k]);
  document.getElementById('consentNextBtn').disabled = !ok;
}
function onboardConsent() {
  if (!CONSENT_REQUIRED.every(k => _consentState[k])) return;
  const db = getOrCreateDB();
  db.consent = {
    terms: true,
    privacy: true,
    research: true,
    marketing: _consentState.marketing,
    agreedAt: new Date().toISOString()
  };
  saveDB(db);
  onboardNext(2);
}

