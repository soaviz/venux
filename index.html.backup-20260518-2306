function sendLetter(memberKey) {
  const ta = document.getElementById(`letterTextarea-${memberKey}`);
  const text = ta.value.trim();
  if (text.length < 300) { showToast('300자 이상 써주세요 💜'); return; }

  const m = memberData[memberKey];

  // 친밀도 +15pt
  const db = getOrCreateDB();
  addAffinity(db, memberKey, 15, 'letter');
  saveDB(db);

  // 편지 저장 (reply: null = 아직 답장 없음)
  const letters = JSON.parse(localStorage.getItem(`venux_letters_${memberKey}`) || '[]');
  const newLetter = { text, date: new Date().toISOString(), reply: null, replyDate: null };
  letters.unshift(newLetter);
  if (letters.length > 10) letters.pop();
  localStorage.setItem(`venux_letters_${memberKey}`, JSON.stringify(letters));

  // textarea 초기화
  ta.value = '';
  onLetterInput(memberKey);

