const VENUX_QR_URL = 'https://soaviz.github.io/LLM_ChatBot';
let _qrCanvas = null;

function initQRCanvas() {
  try {
    if (typeof QRCode === 'undefined') return;
    const wrap = document.createElement('div');
    wrap.style.cssText = 'position:fixed;left:-9999px;top:-9999px;width:100px;height:100px';
    document.body.appendChild(wrap);
    new QRCode(wrap, { text: VENUX_QR_URL, width:100, height:100,
      colorDark:'#1a1a1a', colorLight:'#ffffff', correctLevel: QRCode.CorrectLevel.M });
    setTimeout(() => {
      const c = wrap.querySelector('canvas');
      const im = wrap.querySelector('img');
      if (c) {
        _qrCanvas = c;
      } else if (im) {
        const tmp = document.createElement('canvas');
        tmp.width = 100; tmp.height = 100;
        const ctx = tmp.getContext('2d');
        im.onload = () => { ctx.drawImage(im, 0, 0, 100, 100); _qrCanvas = tmp; };
        if (im.complete) { ctx.drawImage(im, 0, 0, 100, 100); _qrCanvas = tmp; }
      }
      document.body.removeChild(wrap);
    }, 300);
  } catch(e) { console.warn('QR init failed', e); }
}

function addQRWatermark(srcDataUrl) {
  return new Promise((resolve) => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => {
      const W = img.width;
      const BAR = Math.round(W * 0.13);   // 하단 바 높이
      const canvas = document.createElement('canvas');
      canvas.width = W;
      canvas.height = img.height + BAR;
      const ctx = canvas.getContext('2d');

      // 원본 이미지
      ctx.drawImage(img, 0, 0);

      // 하단 바 — 그라데이션 다크
      const grad = ctx.createLinearGradient(0, img.height, 0, img.height + BAR);
      grad.addColorStop(0, '#0d0d0d');
      grad.addColorStop(1, '#1a1a1a');
      ctx.fillStyle = grad;
      ctx.fillRect(0, img.height, W, BAR);

      // 로고 텍스트
      const baseY = img.height + BAR * 0.42;
      ctx.fillStyle = '#ffffff';
      ctx.font = `700 ${Math.round(W * 0.048)}px "JetBrains Mono", monospace`;
      ctx.textAlign = 'left';
      ctx.fillText('VenuX', Math.round(W * 0.05), baseY);
      ctx.font = `400 ${Math.round(W * 0.028)}px "JetBrains Mono", monospace`;
      ctx.fillStyle = 'rgba(255,255,255,0.45)';
      ctx.fillText('venux.app', Math.round(W * 0.05), baseY + BAR * 0.34);

      // QR 코드
      const qrSize = Math.round(BAR * 0.82);
      const qrX = W - qrSize - Math.round(W * 0.04);
      const qrY = img.height + Math.round((BAR - qrSize) / 2);
      if (_qrCanvas) {
        // 화이트 패딩
        ctx.fillStyle = '#ffffff';
        ctx.roundRect
          ? ctx.roundRect(qrX - 4, qrY - 4, qrSize + 8, qrSize + 8, 4)
          : ctx.rect(qrX - 4, qrY - 4, qrSize + 8, qrSize + 8);
        ctx.fill();
        ctx.drawImage(_qrCanvas, qrX, qrY, qrSize, qrSize);
      } else {
        // QR 없을 때 URL 텍스트 폴백
        ctx.fillStyle = 'rgba(255,255,255,0.35)';
        ctx.font = `${Math.round(W * 0.022)}px monospace`;
        ctx.textAlign = 'right';
        ctx.fillText(VENUX_QR_URL, W - Math.round(W * 0.04), baseY);
      }

      resolve(canvas.toDataURL('image/png'));
    };
    img.onerror = () => resolve(srcDataUrl); // 실패 시 원본 그대로
    img.src = srcDataUrl;
  });
}

