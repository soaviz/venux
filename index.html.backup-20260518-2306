      color: var(--vx-purple) !important;
      background: rgba(167,139,250,.08) !important;
    }
    .example-tab.active {
      background: linear-gradient(135deg, rgba(124,91,223,.35), rgba(103,232,249,.15)) !important;
      border-color: var(--vx-purple) !important;
      color: var(--vx-text) !important;
      box-shadow: 0 0 14px rgba(167,139,250,.25) !important;
    }

    /* ── EXAMPLE CARDS ──────────────────────────── */
    .examples-title { color: var(--vx-text) !important; }
    .refresh-btn { color: var(--vx-purple) !important; filter: drop-shadow(0 0 6px var(--vx-purple)); }
    .example-card {
      background: var(--vx-bg2) !important;
      border: 1px solid var(--vx-border) !important;
      box-shadow: none !important;
      transition: all .22s !important;
    }
    .example-card:hover {
      border-color: rgba(167,139,250,.45) !important;
      background: var(--vx-bg3) !important;
      transform: translateX(4px) !important;
      box-shadow: 0 0 12px rgba(167,139,250,.1) !important;
    }
    .example-card:active { transform: scale(.97) translateX(2px) !important; }
    .example-text { color: var(--vx-text) !important; }
    .example-arrow { color: var(--vx-purple) !important; }

    /* ── CTA BUTTON ─────────────────────────────── */
    .cta-btn {
      background: linear-gradient(135deg, var(--vx-purple2), #6B5BD6 50%, #A78BFA) !important;
      border: 1px solid rgba(167,139,250,.4) !important;
      font-family: 'JetBrains Mono', monospace !important;
      letter-spacing: .04em !important;
      position: relative !important;
      overflow: hidden !important;
      animation: vx-cta-breathe 3s ease-in-out infinite !important;
      transition: all .2s !important;
    }
    .cta-btn::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 60%;
      height: 100%;
      background: linear-gradient(105deg, transparent, rgba(255,255,255,.18), transparent);
      transform: translateX(-120%);
      animation: vx-shimmer 2.5s ease-in-out infinite;
      pointer-events: none;
    }
    .cta-btn:hover {
      box-shadow: 0 0 30px rgba(167,139,250,.5), 0 0 60px rgba(167,139,250,.2) !important;
      transform: translateY(-1px) !important;
      animation: none !important;
    }
    .cta-btn:active { transform: scale(.97) !important; }
    .cta-btn:disabled { opacity: .35 !important; animation: none !important; }

    /* ── FOOTER ─────────────────────────────────── */
    .footer { color: rgba(139,130,170,.5) !important; }
    .footer a { color: var(--vx-purple) !important; }

    /* ── TAB BAR ─────────────────────────────────── */
    .tab-bar {
      background: rgba(6,4,15,.92) !important;
      border-top: 1px solid var(--vx-border) !important;
      backdrop-filter: blur(24px) !important;
      -webkit-backdrop-filter: blur(24px) !important;
    }
    .tab-bar::before {
      content: '';
      position: absolute;
      top: -1px; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--vx-purple), transparent);
      opacity: .5;
    }
    .tab-bar { position: fixed; }
    .tab-bar-item { color: rgba(139,130,170,.5) !important; transition: color .2s, text-shadow .2s !important; }
    .tab-bar-item.active {
      color: var(--vx-purple) !important;
      text-shadow: 0 0 10px var(--vx-purple) !important;
    }
    .tab-bar-item.active .tab-icon {
      filter: drop-shadow(0 0 6px var(--vx-purple));
      animation: vx-float 2.5s ease-in-out infinite;
    }

    /* ── LOADING SCREEN ──────────────────────────── */
    #screen-loading {
      background:
        linear-gradient(rgba(167,139,250,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(167,139,250,.04) 1px, transparent 1px),
        rgba(6,4,15,.98) !important;
      background-size: 30px 30px, 30px 30px, 100% !important;
    }
    .loading-pill {
      background: rgba(167,139,250,.06) !important;
      border: 1px solid rgba(167,139,250,.1) !important;
    }
    .loading-pill.active {
      background: rgba(167,139,250,.12) !important;
      border-color: rgba(167,139,250,.4) !important;
      box-shadow: 0 0 16px rgba(167,139,250,.15) !important;
    }
    .loading-pill.done {
      background: rgba(124,91,223,.22) !important;
      border-color: rgba(167,139,250,.5) !important;
    }

    /* ── RESULTS SCREEN ──────────────────────────── */
    #screen-results { background: var(--vx-bg) !important; }
    .results-header {
      background: rgba(6,4,15,.92) !important;
      border-bottom: 1px solid var(--vx-border) !important;
    }
    .results-question { color: var(--vx-text) !important; }
    .back-btn {
      background: rgba(167,139,250,.08) !important;
      color: var(--vx-purple) !important;
      border: 1px solid var(--vx-border) !important;
    }
    .back-btn:hover { background: rgba(167,139,250,.16) !important; }
    .result-card {
      background: var(--vx-bg2) !important;
      border: 1px solid var(--vx-border) !important;
      box-shadow: 0 0 20px rgba(167,139,250,.06) !important;
    }
    .result-card.show { animation: vx-fade-up .5s ease both; }
    .result-krname { color: var(--vx-text) !important; }
    .result-answer { color: rgba(237,233,255,.85) !important; }

    /* ── VERDICT SECTION ─────────────────────────── */
    .verdict-name { color: var(--vx-text) !important; }
    .verdict-label { color: var(--vx-muted) !important; }
    .verdict-desc { color: var(--vx-muted) !important; }

    /* ── AFFINITY SCREEN ─────────────────────────── */
    #screen-affinity { background: var(--vx-bg) !important; }

    /* ── COLLECTION SCREEN ───────────────────────── */
    #screen-collection { background: var(--vx-bg) !important; }

    /* ── GAME/SETTINGS SCREEN ────────────────────── */
    #screen-game-settings { background: var(--vx-bg) !important; }

    /* ── MODALS & OVERLAYS ───────────────────────── */
    .settings-modal, .profile-sheet, .about-modal, .share-modal,
    .notif-center, .achievements-modal, .chat-screen {
      background: var(--vx-bg2) !important;
      border: 1px solid var(--vx-border) !important;
    }

    /* ── PHOTO SECTION ───────────────────────────── */
    .photo-section {
      background: var(--vx-bg2) !important;
      border: 1px solid var(--vx-border) !important;
      box-shadow: 0 0 20px rgba(167,139,250,.05) !important;
    }
    .photo-section-title { color: var(--vx-text) !important; }
    .photo-section-sub { color: var(--vx-muted) !important; }
    .photo-preview-box { background: var(--vx-bg3) !important; border: 1px solid var(--vx-border) !important; }

    /* ── ACCORDION ───────────────────────────────── */
    .accord-item {
      background: var(--vx-bg2) !important;
      border-color: var(--vx-border) !important;
    }
    .accord-title { color: var(--vx-text) !important; }

    /* ── FULLSCREEN PLAYER ───────────────────────── */
    .fullscreen-player {
      background: linear-gradient(180deg, #0D0A1C 0%, #06040F 100%) !important;
    }

    /* ── SMALL UI DETAILS ────────────────────────── */
    /* dot blink on example cards */
    .example-dot { animation: vx-dot-blink 2s ease-in-out infinite; }

    /* member select animation trigger via JS: add class .vx-selected */
    .member-circle.vx-selected { animation: vx-pulse .4s ease; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 3px; height: 3px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(167,139,250,.3); border-radius: 2px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(167,139,250,.6); }

    /* selection color */
    ::selection { background: rgba(167,139,250,.3); color: var(--vx-text); }
  </style>
</head>
<body>

<!-- ONBOARDING -->
<div class="onboarding-overlay hidden" id="onboardingOverlay">
  <div class="onboarding-card" style="overflow-y:auto;max-height:90vh;">
    <!-- Step 1: Welcome -->
    <div class="onboarding-step" id="onboardStep1">
      <div class="onboarding-emoji">✨</div>
      <div class="onboarding-title">VenuX Daily에<br>오신 걸 환영해요</div>
      <div class="onboarding-sub">5명의 멤버와<br>매일 만나는 일상이 시작됩니다</div>
      <button class="onboarding-btn" onclick="onboardNext('C')">시작하기 →</button>
    </div>

    <!-- Step C: 개인정보 동의 -->
    <div class="onboarding-step" id="onboardStepC">
      <div class="consent-card">
        <div style="font-family:'Fraunces',serif;font-size:22px;font-weight:500;color:#0A0A0A;margin-bottom:4px;text-align:center">서비스 이용 동의</div>
        <div style="font-size:13px;color:#888;margin-bottom:18px;text-align:center">아래 약관을 확인하고 동의해 주세요</div>

        <!-- 전체 동의 -->
        <div class="consent-all-row" onclick="toggleConsentAll()">
          <div class="consent-checkbox" id="chk-all"></div>
          <div>
            <div class="consent-all-label">전체 동의</div>
            <span class="consent-all-sub">선택 항목 포함 모든 약관에 동의합니다</span>
          </div>
        </div>

        <!-- ① 서비스 이용약관 (필수) -->
        <div class="consent-item" id="ci-terms">
          <div class="consent-item-header" onclick="toggleConsentItem('terms')">
            <div class="consent-checkbox" id="chk-terms" onclick="event.stopPropagation();toggleConsentCheck('terms')"></div>
            <span class="consent-item-title">서비스 이용약관</span>
            <span class="consent-badge required">필수</span>
            <span class="consent-toggle-icon">▼</span>
          </div>
          <div class="consent-item-body">
            <div class="consent-item-text">
              <strong>제1조 (목적)</strong><br>
              본 약관은 SOAVIZ(이하 "회사")가 제공하는 VenuX Daily 서비스(이하 "서비스") 이용에 관한 조건 및 절차, 이용자와 회사의 권리·의무 및 책임사항을 규정함을 목적으로 합니다.<br><br>
              <strong>제2조 (이용 조건)</strong><br>
              서비스는 만 14세 이상이면 누구나 이용할 수 있습니다. 허위 정보 기재, 타인 정보 도용, 서비스 운영 방해 등의 행위는 금지됩니다.<br><br>
              <strong>제3조 (서비스 내용)</strong><br>
              회사는 AI 기반 가상 멤버와의 일상 상호작용, 친밀도 시스템, 컨텐츠 열람 등의 서비스를 제공합니다. 서비스 내용은 회사의 사정에 따라 변경될 수 있습니다.<br><br>
              <strong>제4조 (책임의 한계)</strong><br>
              서비스 내 AI 멤버의 응답은 실제 사람의 견해가 아니며, 이를 실제 조언이나 정보로 활용하는 것에 대한 책임은 이용자 본인에게 있습니다.<br><br>
              <strong>제5조 (약관 변경)</strong><br>
              회사는 약관을 변경할 경우 서비스 내 공지를 통해 사전 안내합니다.
            </div>
          </div>
        </div>

        <!-- ② 개인정보 수집 및 이용 (필수) -->
        <div class="consent-item" id="ci-privacy">
          <div class="consent-item-header" onclick="toggleConsentItem('privacy')">
            <div class="consent-checkbox" id="chk-privacy" onclick="event.stopPropagation();toggleConsentCheck('privacy')"></div>
            <span class="consent-item-title">개인정보 수집 및 이용 동의</span>
            <span class="consent-badge required">필수</span>
            <span class="consent-toggle-icon">▼</span>
          </div>
          <div class="consent-item-body">
            <div class="consent-item-text">
              <strong>수집 항목</strong><br>
              닉네임, MBTI 유형, 앱 이용 기록(친밀도·대화 내용·방문 이력), 기기 브라우저 정보<br><br>
              <strong>수집 및 이용 목적</strong><br>
              • 서비스 이용자 식별 및 맞춤 경험 제공<br>
              • 멤버 추천 및 친밀도 시스템 운영<br>
              • 서비스 개선을 위한 통계 분석<br>
              • 부정 이용 방지 및 서비스 보안<br><br>
              <strong>보유 및 이용 기간</strong><br>
              서비스 탈퇴 시까지. 단, 관계 법령에 따라 일정 기간 보관이 필요한 경우 해당 기간 동안 보관합니다.<br><br>
              <strong>동의 거부 시 불이익</strong><br>
              위 항목의 수집에 동의하지 않을 경우 VenuX Daily 서비스 이용이 제한될 수 있습니다.<br><br>
              <strong>데이터 저장 방식</strong><br>
              모든 개인정보는 브라우저 localStorage에만 저장되며 외부 서버로 전송되지 않습니다.
            </div>
          </div>
        </div>

        <!-- ③ 연구 참여 및 데이터 활용 (필수) -->
        <div class="consent-item" id="ci-research">
          <div class="consent-item-header" onclick="toggleConsentItem('research')">
            <div class="consent-checkbox" id="chk-research" onclick="event.stopPropagation();toggleConsentCheck('research')"></div>
            <span class="consent-item-title">연구 참여 및 데이터 활용 동의</span>
            <span class="consent-badge required">필수</span>
            <span class="consent-toggle-icon">▼</span>
          </div>
          <div class="consent-item-body">
            <div class="consent-item-text">
              <strong>연구 목적</strong><br>
              본 서비스는 홍익대학교 AI 실감미디어콘텐츠 연구의 일환으로 운영됩니다. 이용자의 서비스 이용 데이터는 AI 캐릭터와의 상호작용 연구에 활용됩니다.<br><br>
              <strong>활용 범위</strong><br>
              • 친밀도 변화 패턴 분석<br>
              • 대화 유형 및 응답 반응 연구<br>
              • 서비스 체류 시간 및 행동 패턴 분석<br><br>
              <strong>익명성 보장</strong><br>
              연구에 활용되는 모든 데이터는 개인 식별이 불가능한 형태로 익명 처리됩니다. 논문 및 발표 자료에는 개인 정보가 포함되지 않습니다.<br><br>
              <strong>참여 철회</strong><br>
              언제든지 설정 메뉴에서 연구 참여 동의를 철회할 수 있습니다.
            </div>
          </div>
        </div>

        <!-- ④ 마케팅 수신 (선택) -->
        <div class="consent-item" id="ci-marketing">
          <div class="consent-item-header" onclick="toggleConsentItem('marketing')">
            <div class="consent-checkbox" id="chk-marketing" onclick="event.stopPropagation();toggleConsentCheck('marketing')"></div>
            <span class="consent-item-title">마케팅 정보 수신 동의</span>
            <span class="consent-badge optional">선택</span>
            <span class="consent-toggle-icon">▼</span>
          </div>
          <div class="consent-item-body">
            <div class="consent-item-text">
              <strong>수신 내용</strong><br>
              신규 멤버 업데이트, 이벤트·프로모션 안내, 서비스 새 기능 알림<br><br>
              <strong>수신 방법</strong><br>
              서비스 내 알림(푸시) 형태로 전달됩니다.<br><br>
              <strong>동의 철회</strong><br>
              설정 메뉴에서 언제든지 수신 동의를 철회할 수 있습니다.<br><br>
              본 항목에 동의하지 않아도 서비스 이용에는 제한이 없습니다.
            </div>
          </div>
        </div>

        <button class="consent-next-btn" id="consentNextBtn" disabled onclick="onboardConsent()">동의하고 시작하기 →</button>
      </div>
    </div>
    <!-- Step 2: Nickname -->
    <div class="onboarding-step" id="onboardStep2">
      <div class="onboarding-emoji">👋</div>
      <div class="onboarding-title">뭐라고 불러줄까요?</div>
      <div class="onboarding-sub">멤버들이 당신을 부를 이름이에요</div>
      <input class="onboarding-input" id="onboardNickname" placeholder="닉네임 입력" maxlength="20" autocomplete="off">
      <button class="onboarding-btn" onclick="onboardSaveNickname()">다음 →</button>
    </div>
    <!-- Step 3: MBTI -->
    <div class="onboarding-step" id="onboardStep3">
      <div class="onboarding-emoji">🧠</div>
      <div class="onboarding-title">당신의 MBTI는?</div>
      <div class="onboarding-sub">멤버 호환성을 알려드려요</div>
      <div class="onboarding-mbti-grid" id="mbtiGrid"></div>
      <button class="onboarding-btn" onclick="onboardSaveMBTI()" id="mbtiNextBtn" disabled>다음 →</button>
      <button class="onboarding-btn secondary" onclick="onboardSkipMBTI()">모르겠어요 · 건너뛰기</button>
    </div>
    <!-- Step 4: Recommended member -->
    <div class="onboarding-step" id="onboardStep4">
      <div class="onboarding-emoji">💜</div>
      <div class="onboarding-title">당신과 가장 잘 맞는 멤버</div>
      <div class="onboarding-recommend" id="onboardRecommend"></div>
      <button class="onboarding-btn" onclick="onboardFinish()">만나러 가기 →</button>
    </div>
  </div>
</div>

<!-- DAILY ATTENDANCE MODAL -->
<div class="attendance-overlay" id="attendanceOverlay">
  <div class="attendance-card">
    <div class="attendance-portrait" id="attendancePortrait"></div>
