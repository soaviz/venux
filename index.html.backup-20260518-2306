let currentLang = localStorage.getItem('venux_lang') || 'ko';

function t(key, ...args) {
  const pack = LANG_PACK[currentLang] || LANG_PACK.ko;
  const val = pack[key] ?? LANG_PACK.ko[key] ?? key;
  return typeof val === 'function' ? val(...args) : val;
}

function applyLang() {
  // data-i18n → textContent
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.dataset.i18n;
    el.textContent = t(key);
  });
  // data-i18n-placeholder → placeholder
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
    el.placeholder = t(el.dataset.i18nPlaceholder);
  });
  // CTA 버튼 (솔로 선택 상태면 유지)
  const ctaBtn = document.getElementById('ctaBtn');
  if (ctaBtn && !ctaBtn.dataset.solo) ctaBtn.textContent = t('cta_group');
  // 메인 질문 textarea placeholder
  const qi = document.getElementById('questionInput');
  if (qi && !qi.dataset.soloPlaceholder) qi.placeholder = t('question_placeholder');
  // 언어 라디오 선택 반영
  document.querySelectorAll('.lang-radio').forEach(r => {
