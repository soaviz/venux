  const h12 = h % 12 || 12;
  return `${ampm} ${h12}:${m}`;
}

function formatChatDate(ts) {
  const d = new Date(ts);
  const days = ['일','월','화','수','목','금','토'];
  return `${d.getFullYear()}년 ${d.getMonth()+1}월 ${d.getDate()}일 ${days[d.getDay()]}요일`;
}

