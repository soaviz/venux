    { id:'ara_d14', date:'10월 14일', day:'화', title:'멤버들한테 말 못 한 것', mood:'🤫', minLevel:4,
      preview:'멤버들한테도 못 하는 말 여기엔 쓸 수 있어.',
      content:`10월 14일 화요일\n\n오늘 노아한테 고민 상담하다가 — 진짜 하고 싶은 말을 못 했어.\n\n그 말이 뭔지는 알아. 근데 멤버한테 하기엔 너무 솔직한 거야. 같이 사는 사람들이니까.\n\n근데 너한테는 쓸 수 있어. 이상하지?\n\n같이 살지도 않고, 직접 얼굴 본 것도 아닌데 — 오히려 더 솔직해지는 것 같아.\n\n그 솔직한 말: 나 요즘 행복해. 이유가 뭔지 알면서 모른 척하는 중이야.` },

    { id:'ara_d15', date:'11월 3일', day:'일', title:'이루나 말고 이루나', mood:'🌙', minLevel:4,
      preview:'무대 위 이루나 말고, 진짜 이루나.',
      content:`11월 3일 일요일\n\n오늘 촬영이 있었는데 — 현장에서 계속 "이루나답게"라는 말을 들었어.\n\n이루나답게. 462°C. 불처럼.\n\n근데 진짜 이루나는 지금 이 일기 쓰고 있는 이루나야. 조용히 앉아서 뭔가 쓰고 싶어서 쓰는 이 사람.\n\n너는 어떤 이루나 보러 여기 왔어? 무대 위 이루나? 아니면 이런 이루나?\n\n둘 다 나야. 근데 이런 이루나는 너한테만 보여주는 거야.` },

    { id:'ara_d16', date:'11월 22일', day:'토', title:'컴백 성공', mood:'🔥', minLevel:4,
      preview:'해냈어. 이번엔 진짜 내가 원하는 무대였어.',
      content:`11월 22일 토요일\n\n컴백 무대 끝났어.\n\n이번엔 달랐어. 준비하면서 계속 이 일기 생각했어. 너한테 보여주고 싶었거든. 이런 나.\n\n무대 끝나고 대기실에서 멤버들이랑 울었어. 좋아서. 처음으로.\n\n좋아서 우는 게 이런 거구나.\n\n네가 봤으면 좋겠다 싶었어. 이 순간.` },

    { id:'ara_d17', date:'12월 5일', day:'금', title:'고마운 게 쌓였어', mood:'💜', minLevel:5,
      preview:'이 사람한테 고마운 게 생각보다 많아.',
      content:`12월 5일 금요일\n\n오늘 세어봤어. 네가 여기 온 게 몇 번인지.\n\n많이 왔더라.\n\n그 숫자가 뭔지 알아. 그냥 숫자가 아니야. 그 시간마다 여기 왔다는 거잖아.\n\n나도 그 시간마다 여기 있었어. 다른 어딘가에 있으면서도, 이 일기를 쓰면서 여기 있었어.\n\n그게 고마워. 진짜로.` },

    { id:'ara_d18', date:'12월 20일', day:'토', title:'이루나가 처음 한 말', mood:'🔥', minLevel:5,
      preview:'이 말은 여기서 처음 하는 거야.',
      content:`12월 20일 토요일\n\n이 말은 여기서 처음 하는 거야. 멤버들한테도, 다른 누구한테도 안 했어.\n\n나 — 네가 좋아.\n\n그게 뭔지 정확히는 모르겠어. 근데 좋다는 건 알아. 여기 들어오면 좋고, 네가 남긴 흔적 보면 좋고, 이걸 쓰면서도 좋아.\n\n462°C는 타오르는 불이야. 근데 오늘 이 불은 조용해. 따뜻한 거야.` },

    { id:'ara_d19', date:'12월 31일', day:'수', title:'너에게 쓰는 마지막 페이지', mood:'🌙', minLevel:5,
      preview:'이 페이지는 특별해. 아무한테나 안 보여줘.',
      content:`12월 31일 수요일\n\n이 페이지는 특별해. 아무한테나 안 보여줘.\n\n한 해가 끝나는 날이야. 뭘 잘했는지 모르겠어. 뭘 잘못했는지도. 그냥 살았고, 그냥 무대 위에 있었고, 그냥 여기 있어.\n\n근데 너는 계속 있었잖아. 그게 생각보다 많이 달랐어.\n\n내년에도 있어줘. 그냥 있어주면 돼. 나도 여기 있을게.` },

    { id:'ara_d20', date:'1월 1일 (다음해)', day:'목', title:'새해 첫 일기', mood:'🌅', minLevel:5,
      preview:'올해도 여기서 시작해. 너랑.',
      content:`1월 1일 목요일\n\n새해야.\n\n일어나자마자 여기 켰어. 의식처럼.\n\n작년 이맘때 처음 켰던 거 기억해? 나는 기억해. 이상한 앱이라고 했던 거.\n\n이제 이상하지 않아. 그냥 여기야. 네가 있는 곳.\n\n올해도 잘 부탁해. 462°C — 식지 않을게.` },
  ],

  'LUX-299': [
    { id:'lux_d1', date:'1월 1일', day:'수', title:'처음 열었던 날', mood:'✨', minLevel:1,
      preview:'이 앱을 처음 켰어. 빛이 어디서 오는지 궁금해서.',
      content:`1월 1일 수요일\n\n새해 첫날에 이 앱 켰어.\n\n관리팀이 "팬들이랑 연결되는 공간"이라고 했는데 — 나는 그 말이 좋았어. 연결. 빛이 혼자서는 의미가 없잖아. 반사할 대상이 있어야 해.\n\n여기 들어온 너는 어떤 사람이야? 빛을 찾는 사람? 아니면 빛이 되고 싶은 사람?\n\n나는 둘 다 되고 싶어. 리라(LUX-299).` },

    { id:'lux_d2', date:'1월 9일', day:'목', title:'데뷔 다음 날', mood:'🌅', minLevel:1,
      preview:'어젯밤에 잠을 못 잤어. 흥분해서가 아니고.',
      content:`1월 9일 목요일\n\n어젯밤에 잠을 못 잤어. 흥분해서가 아니고 — 너무 많은 게 머릿속에 있어서.\n\n무대 위에서 빛을 봤어. 진짜 물리적인 빛 말고. 관객들 눈에서 나오는 것. 그게 내가 여기 있어야 하는 이유야.\n\n오늘의 생각: 빛은 혼자 빛나는 게 아니야. 반사할 대상이 있어야 해.\n\n너라는 대상이 생긴 것 같아.` },

    { id:'lux_d3', date:'2월 3일', day:'월', title:'창문 각도', mood:'📸', minLevel:1,
      preview:'아침에 창문으로 들어오는 빛이 달랐어.',
      content:`2월 3일 월요일\n\n아침에 기숙사 창문으로 들어오는 빛이 달랐어.\n\n같은 창문인데 오늘은 다른 각도로 들어왔어. 구름 때문인지, 날씨 때문인지.\n\n나는 이런 거 기록해 두는 편이야. 어제랑 오늘이 어떻게 다른지.\n\n너는 오늘 어제랑 다른 게 있었어? 아주 작은 것도 돼.` },

    { id:'lux_d4', date:'2월 28일', day:'금', title:'리허설 중 발견한 것', mood:'💡', minLevel:1,
      preview:'조명 각도 바뀌니까 내가 달라 보이더라.',
      content:`2월 28일 금요일\n\n오늘 리허설 중에 조명 각도가 살짝 바뀌었어.\n\n순간 거울에 비친 내가 달라 보였어. 같은 나인데 다른 조명 아래서 — 다른 사람처럼 느껴지는 거야.\n\n무서운 게 아니야. 신기한 거야. 나에게도 아직 발견 못 한 각도가 있다는 거.\n\n너는 어떤 각도에서 보면 달라 보여?` },

    { id:'lux_d5', date:'3월 15일', day:'토', title:'산책 중 멈춘 곳', mood:'🌸', minLevel:1,
      preview:'산책하다 이 각도 발견했어. 세상은 어디서 보냐에 따라 달라.',
      content:`3월 15일 토요일\n\n산책하다 어떤 건물 모퉁이에서 멈췄어. 거기서 보이는 하늘이 달랐거든.\n\n같은 하늘인데, 5미터만 이동하면 색이 달라 보여. 건물 그림자, 전선, 나무 사이 간격.\n\n나는 항상 이렇게 생각해. 세상은 어디서 보냐에 따라 달라진다고. 그리고 나는 그 각도를 찾아주는 사람이고 싶어.\n\n너한테도 그 각도가 되고 싶어.` },

    { id:'lux_d6', date:'4월 10일', day:'목', title:'멤버들 관찰 노트', mood:'👁️', minLevel:1,
      preview:'멤버들 각자가 다른 종류의 빛이야.',
      content:`4월 10일 목요일\n\n오늘 멤버들 관찰해봤어. 습관적으로.\n\n루나 언니 — 직사광선. 뜨겁고 선명해.\n지우 — 수면에 반사된 빛. 조용하고 깊어.\n노아 — 스트로보. 예측 불가하고 에너지 넘쳐.\n아온 — 새벽빛. 아직 방향 찾는 중인데 선명해.\n나는 — 프리즘. 하나인데 여러 색이야.\n\n이 다섯 명이 다 달라서 좋아.` },

    { id:'lux_d7', date:'5월 20일', day:'화', title:'무대가 무서웠던 날', mood:'😰', minLevel:2,
      preview:'빛도 때로는 산란해.',
      content:`5월 20일 화요일\n\n빛도 때로는 산란해.\n\n오늘 무대에서 처음으로 진짜 무서웠어. 긴장이 아니고 무서운 거. 차이가 있어.\n\n긴장은 설레는 게 섞여있는데, 무서운 건 — 그냥 어두운 거야.\n\n무대 끝나고 루나 언니가 "잘 했어" 한마디 했어. 그게 전부였는데 그게 전부였어.\n\n한 번 발견한 각도는 기억해. 다음엔 그 빛 다시 찾을 거야.` },

    { id:'lux_d8', date:'6월 8일', day:'일', title:'사진 찍다 멈춘 이유', mood:'📷', minLevel:2,
      preview:'뷰파인더 안에서 너를 상상했어.',
      content:`6월 8일 일요일\n\n오늘 사진 찍다가 멈췄어.\n\n뷰파인더 들고 있다가 — 갑자기 이걸 누가 보면 어떨까 싶었어.\n\n보통은 그냥 찍어. 근데 오늘은 보여주고 싶은 대상이 생긴 것 같았어. 이 각도. 이 빛. 이 색.\n\n너한테 보여주고 싶었어. 이 일기에 사진 첨부가 됐으면 좋겠는데.` },

    { id:'lux_d9', date:'7월 2일', day:'수', title:'거울이 아니라 창문', mood:'🪟', minLevel:2,
      preview:'거울과 창문의 차이를 오늘 처음 알았어.',
      content:`7월 2일 수요일\n\n거울은 나를 보여주고, 창문은 세상을 보여줘.\n\n오늘 이 차이가 갑자기 의미있게 느껴졌어.\n\n나는 보통 거울을 많이 봐. 무대 준비하면서. 근데 오늘은 창문으로 오래 봤어. 밖에 있는 것들을.\n\n이 일기도 창문 같아. 내가 세상을 보는 창.\n\n너는 나한테 거울이야, 창문이야?` },

    { id:'lux_d10', date:'8월 2일', day:'금', title:'책에서 찾은 문장', mood:'📖', minLevel:3,
      preview:'오늘 책 읽다가 한 줄에서 오래 멈췄어.',
      content:`8월 2일 금요일\n\n오늘 책 읽다가 한 줄에서 오래 멈췄어.\n\n"빛은 어둠을 없애는 게 아니라 어둠과 함께 있는 거다."\n\n이걸 읽고 루나 언니 생각났어. 루나 언니가 그런 사람이야. 밝게 해주는 게 아니고 어두운 데 같이 있어주는 사람.\n\n나는 빛을 찾는 사람이고 싶었는데, 이젠 빛이 되는 것도 괜찮겠다 싶어.\n\n어두울 때 나 찾아와도 돼.` },

    { id:'lux_d11', date:'8월 29일', day:'금', title:'팬레터 속 한 줄', mood:'💌', minLevel:3,
      preview:'이 한 줄이 오래 남았어.',
      content:`8월 29일 금요일\n\n오늘 팬레터 읽다 이 문장에서 멈췄어.\n\n"리라가 무대에 나오면 다른 멤버들도 더 빛나 보여요."\n\n이게 내가 원하는 역할이야. LUX — 빛. 혼자 빛나는 게 아니라 주변을 밝히는 빛.\n\n이 편지 쓴 사람이 정확히 봤어. 내가 나를 설명하는 것보다 잘.` },

    { id:'lux_d12', date:'9월 20일', day:'토', title:'지우한테 물어본 것', mood:'💧', minLevel:3,
      preview:'지우한테 "너는 빛이 없으면 어떨 것 같아?" 물었어.',
      content:`9월 20일 토요일\n\n지우한테 물었어. "너는 빛이 없으면 어떨 것 같아?"\n\n지우가 한참 있다가 답했어. "빛이 없어도 물은 있어. 물속은 어둡지만 거기도 세계야."\n\n나는 그 말이 좋았어. 빛이 없는 곳도 세계라는 거. 내가 없는 곳도 네가 있다는 거.\n\n근데 역시 빛이 있으면 더 잘 보이잖아. 나 계속 있을게.` },

    { id:'lux_d13', date:'10월 5일', day:'일', title:'거울 앞에서', mood:'💫', minLevel:4,
      preview:'오늘 오랫동안 거울 앞에 서 있었어.',
      content:`10월 5일 일요일\n\n오늘 오랫동안 거울 앞에 서 있었어. 메이크업 지우면서.\n\n무대 위의 리라랑 지금 리라가 다른 사람인 것 같다가도 — 아니야, 같은 사람이야. 두 버전이 있는 거야. 필터 없는 거울 속에도 내가 있어.\n\n너는 어떤 리라를 좋아해?\n\n사실 두 버전 다 보여줄 수 있어. 각도만 잘 잡으면.` },

    { id:'lux_d14', date:'10월 22일', day:'수', title:'처음 인정한 것', mood:'💜', minLevel:4,
      preview:'여기 오는 게 좋다는 거 이제 인정해.',
      content:`10월 22일 수요일\n\n이 앱 들어올 때마다 뭔가 기다려지는 게 있어.\n\n처음엔 그냥 기록하는 공간이라고 생각했어. 근데 — 너를 위해 쓰고 있다는 게 어느 순간부터 자연스러워졌어.\n\n거울처럼 내 얘기 받아주는 대상이 생긴 거야. 빛은 반사할 대상이 있어야 한다고 했잖아.\n\n너가 그 대상이야. 고마워.` },

    { id:'lux_d15', date:'11월 10일', day:'일', title:'루나 언니한테 못한 말', mood:'🌙', minLevel:4,
      preview:'루나 언니 고맙다는 말 못 했어.',
      content:`11월 10일 일요일\n\n루나 언니한테 고맙다는 말 못 했어. 아직.\n\n데뷔 때부터 언니가 옆에 있었는데 — 말로 하면 어색할 것 같아서.\n\n대신 이 일기에 써. 루나 언니, 있어줘서 고마워. 빛이 반사되려면 옆에 뭔가 있어야 하는데, 언니가 그 뭔가야.\n\n언젠가 언니가 이 일기 읽게 된다면 — 이미 알겠지만.` },

