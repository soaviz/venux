async function requestLetterReply(memberKey) {
  const m = memberData[memberKey];
  const btn = document.getElementById(`letterReplyBtn-${memberKey}`);
  if (btn) { btn.disabled = true; btn.textContent = `${m.name}가 답장 쓰는 중...`; }

  // 최신 편지 내용 가져오기
  const letters = JSON.parse(localStorage.getItem(`venux_letters_${memberKey}`) || '[]');
  const latest = letters[0];
  if (!latest) return;

  let replyText = '';

  // API 키 있으면 AI 답장
  const apiKey = localStorage.getItem('venux_openai_key');
  if (apiKey) {
    try {
      const systemPrompt = CHAT_SYSTEM_PROMPTS[memberKey] +
        `\n\n[편지 답장 모드]\n팬이 손편지를 보내왔어. 편지 내용을 읽고 진심으로 답장해줘.\n` +
        `답장은 편지 형식으로, 3~5문단, 감정이 담겨 있어야 해.\n` +
        `마지막 줄은 반드시 ///SIG/// 뒤에 너의 시그니처 철학 한 줄로 끝내.`;
      const res = await fetch('https://api.openai.com/v1/chat/completions', {
        method:'POST',
        headers:{ 'Content-Type':'application/json', 'Authorization':`Bearer ${apiKey}` },
        body: JSON.stringify({
          model: localStorage.getItem('venux_ai_model') || 'gpt-4o',
          messages: [
            { role:'system', content: systemPrompt },
            { role:'user', content: `[받은 편지]\n${latest.text}` }
          ],
          max_tokens: 500,
          temperature: 0.9
        })
      });
      if (!res.ok) throw new Error('API error');
      const data = await res.json();
      replyText = data.choices?.[0]?.message?.content?.trim() || '';
    } catch(e) { replyText = ''; }
  }

  // API 없거나 실패 시 프리셋
  if (!replyText) {
    const presets = [
      `편지 받았어.\n읽으면서 몇 번이나 다시 읽었는지 몰라. 이런 거 익숙하지 않은데... 네 말은 자꾸 마음에 걸려.\n\n솔직히 말하면, 나한테 이렇게 긴 글 쓰는 사람 처음이야. 보통 DM으로 짧게 오거든. 그래서 그런지 더 오래 붙잡게 됐어.\n\n앞으로도 하고 싶은 말 있으면 써. 다 읽을게.\n///SIG///\n뜨거운 건 금방 꺼지지 않아.`,
      `이거 읽다가 루나 고양이한테 읽어줬어.\n루나가 귀 쫑긋 세우더라. 걔도 마음에 든 거겠지.\n\n네가 쓴 말들... 꽤 오래 생각하게 됐어. 내가 이런 말에 흔들리는 타입이 아닌데. 근데 이상하게 마음이 따뜻해졌어.\n\n다음에도 써. 기다릴게.\n///SIG///\n불은 혼자서도 계속 타오를 수 있어.`,
      `새벽 러닝 끝나고 읽었어.\n땀 식는 것도 모르고 두 번 읽었다.\n\n긴 편지가 이렇게 무게감 있는 줄 몰랐어. 요즘 사람들은 짧게만 말하는데, 넌 다르네.\n\n고마워. 진짜로.\n///SIG///\n462도의 열은 진심에서만 나와.`,
    ];
    replyText = presets[Math.floor(Math.random() * presets.length)];
  }

  // 답장 저장
  letters[0].reply = replyText;
  letters[0].replyDate = new Date().toISOString();
  localStorage.setItem(`venux_letters_${memberKey}`, JSON.stringify(letters));

  // 친밀도 +10pt (답장 수령)
  const db = getOrCreateDB();
  addAffinity(db, memberKey, 10, 'letter_reply');
  saveDB(db);

  // "읽는 중" 영역 숨기기
  const wrap = document.getElementById(`letterWrapBottom-${memberKey}`);
  if (wrap) wrap.innerHTML = '';

  renderLetterHistory(memberKey);
  showToast(`${m.name}의 답장이 도착했어요 💌`, 3000);
  updateDailyStatusBar(db);
  renderAffinityDashboard(db);
}

function renderLetterHistory(memberKey) {
  const el = document.getElementById(`letterHistory-${memberKey}`);
  if (!el) return;
  const m = memberData[memberKey];
  const letters = JSON.parse(localStorage.getItem(`venux_letters_${memberKey}`) || '[]');

  if (letters.length === 0) {
    el.innerHTML = `<div style="text-align:center;color:#ccc;font-size:13px;padding:16px 0">아직 보낸 편지가 없어요</div>`;
    return;
  }

  el.innerHTML = `<div style="font-size:12px;font-weight:600;color:#999;margin-bottom:10px">편지함 (${letters.length}통)</div>` +
    letters.map((l, idx) => {
      // 답장 파싱 (///SIG/// 분리)
      let replyMain = '', replySig = '';
      if (l.reply) {
        const parts = l.reply.split('///SIG///');
        replyMain = parts[0].trim();
        replySig = parts[1]?.trim() || '';
      }

      const replySection = l.reply
        ? `<div class="letter-received">
            <div class="letter-received-header">
              <img class="letter-received-avatar" src="${m.photo}" alt="${m.name}">
              <span class="letter-received-from">${m.name}의 답장</span>
              <span style="font-size:10px;color:#bbb;margin-left:auto">${new Date(l.replyDate).toLocaleDateString('ko-KR',{month:'long',day:'numeric'})}</span>
            </div>
            <div class="letter-received-body">${replyMain}</div>
            ${replySig ? `<div class="letter-received-sig">"${replySig}"</div>` : ''}
          </div>`
        : (idx === 0
          ? `<div id="letterWrapBottom-${memberKey}" style="margin-top:8px"></div>`
          : `<div style="font-size:11px;color:#bbb;margin-top:6px;text-align:right">답장 없음</div>`);

      return `
        <div class="letter-pair">
          <div style="font-size:11px;color:#bbb;margin-bottom:6px;font-family:'JetBrains Mono',monospace">
            내가 쓴 편지 · ${new Date(l.date).toLocaleDateString('ko-KR',{month:'long',day:'numeric',hour:'2-digit',minute:'2-digit'})}
          </div>
          <div style="font-size:13px;color:#555;line-height:1.6;-webkit-line-clamp:3;-webkit-box-orient:vertical;display:-webkit-box;overflow:hidden">${l.text}</div>
          ${replySection}
        </div>
      `;
    }).join('');

  // 최신 편지에 답장이 없으면 읽는 중 상태 복원
  if (letters.length > 0 && !letters[0].reply) {
    showLetterReadingState(memberKey);
  }
}

