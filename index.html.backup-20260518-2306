        <div class="chat-msg-avatar" style="${showAvatar?'':'visibility:hidden'}"><img src="${m.photo}" alt="${m.letter}"></div>
        <div class="chat-bubble member-bubble${msg.isSig?' sig-bubble':''}" style="${msg.isSig?'color:'+m.badgeColor:''}">${msg.text}</div>
        ${timeStr}
      </div>`;
    } else {
      const colors = CHAT_COLORS[memberKey];
      html += `<div class="chat-msg-row user">
        ${timeStr}
        <div class="chat-bubble user-bubble" style="background:${colors.userBubble}">${msg.text}</div>
