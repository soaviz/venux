function handleFourcutUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  const idx = fourcutUploadIndex;
  fourcutPhotos[idx] = file;
  const reader = new FileReader();
  reader.onload = (ev) => {
    fourcutDataUrls[idx] = ev.target.result;
    const slot = document.querySelectorAll('#fourcutGrid .fourcut-slot')[idx];
    slot.classList.add('filled');
    slot.innerHTML = `<span class="slot-label">${idx + 1}</span><img src="${ev.target.result}">`;
    slot.onclick = () => triggerFourcutUpload(idx);
    updateFourcutCounter();
    checkFourcutReady();
  };
  reader.readAsDataURL(file);
  e.target.value = '';
}

