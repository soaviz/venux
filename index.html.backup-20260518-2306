function onLetterInput(memberKey) {
  const ta = document.getElementById(`letterTextarea-${memberKey}`);
  const counter = document.getElementById(`letterCounter-${memberKey}`);
  const btn = document.getElementById(`letterSendBtn-${memberKey}`);
  const len = ta.value.length;
  counter.textContent = `${len} / 300`;
  if (len >= 300) {
    counter.classList.add('ready');
