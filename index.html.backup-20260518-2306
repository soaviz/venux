function isCardUnlocked(card, db, key) {
  const rel = db.member_relationships[key] || { affection_points:0, conversation_count:0 };
  const u = card.unlock;
  if (u.type === 'always') return true;
  if (u.type === 'level')  return getAffinityLevel(rel.affection_points) >= u.value;
  if (u.type === 'chat')   return (rel.conversation_count || 0) >= u.value;
  if (u.type === 'letter') {
    const letters = JSON.parse(localStorage.getItem('venux_letters_' + key) || '[]');
    return letters.length >= u.value;
  }
  return false;
}

function unlockHint(card) {
  const u = card.unlock;
  if (u.type === 'level')  return `LV ${u.value} 달성 시 해금`;
  if (u.type === 'chat')   return `대화 ${u.value}회 시 해금`;
  if (u.type === 'letter') return `편지 ${u.value}통 시 해금`;
  return '';
}

