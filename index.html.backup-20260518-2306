        method: 'POST',
        headers: { 'Authorization': `Bearer ${apiKey}` },
        body: form
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        if (res.status === 401) { showToast('API Key를 확인해주세요'); throw new Error('invalid key'); }
        if (res.status === 429) { showToast('요청 한도 초과. Mock 모드로 전환합니다.'); throw new Error('rate limit'); }
        throw new Error('API error');
      }

      const data = await res.json();
      const imgData = data.data[0]?.url || (data.data[0]?.b64_json ? `data:image/png;base64,${data.data[0].b64_json}` : null);
      if (!imgData) throw new Error('no image');
      cuts.push(imgData);
    }

    updateFourcutStatus(4);
    await new Promise(r => setTimeout(r, 500));
    showFourcutResult(cuts, m);
