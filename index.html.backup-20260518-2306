function setupImageFallbacks(container) {
  if (!container) return;
  container.querySelectorAll('img').forEach(img => {
    if (img.dataset.fallbackSet) return;
    img.dataset.fallbackSet = '1';
    img.addEventListener('error', function() {
      const parent = this.parentElement;
      if (!parent) return;
      const alt = this.alt || '?';
      // Find matching member data for gradient
      const key = memberOrder.find(k => memberData[k].letter === alt || memberData[k].photo === this.src.split('/').pop());
      const m = key ? memberData[key] : null;
      const bg = m ? m.gradient : '#888';
      const size = parent.offsetWidth || 48;
      const fontSize = Math.max(12, Math.round(size * 0.3));
      parent.innerHTML = `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:${bg};border-radius:50%;font-family:'JetBrains Mono',monospace;font-size:${fontSize}px;color:white;font-weight:600">${alt}</div>`;
    });
  });
}

