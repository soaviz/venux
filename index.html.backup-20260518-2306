function addTrackFromFile(title, member, audioFile, coverFile) {
  return new Promise((resolve) => {
    const id = 'track_' + Date.now();
    const track = { id, title, artist:'VenuX', member, cover:'', audio:'', duration:0, keyColor: memberData[member]?.badgeColor || '#6B5BD6' };

    // Read audio as data URL (small files only)
    if (audioFile) {
      const reader = new FileReader();
      reader.onload = (e) => {
        track.audio = e.target.result;
        // Read cover if provided
        if (coverFile) {
          const cr = new FileReader();
          cr.onload = (ce) => { track.cover = ce.target.result; finishAdd(track); resolve(track); };
          cr.readAsDataURL(coverFile);
        } else { finishAdd(track); resolve(track); }
      };
      reader.readAsDataURL(audioFile);
    } else { resolve(null); }
  });
}

function addTrackFromURL(title, member, audioUrl, coverUrl) {
  const id = 'track_' + Date.now();
  const track = { id, title, artist:'VenuX', member, cover:coverUrl || '', audio:audioUrl, duration:0, keyColor: memberData[member]?.badgeColor || '#6B5BD6' };
  finishAdd(track);
  return track;
}

function finishAdd(track) {
  venuxTracks.push(track);
  savePlayerTracks(venuxTracks);
  document.getElementById('miniPlayerEmpty').style.display = 'none';
  document.getElementById('miniPlayer').style.display = 'flex';
  if (venuxTracks.length === 1) loadTrack(0, false);
  renderTracklist();
  showToast(`🎵 "${track.title}" 추가됨`);
}

function removeTrack(idx) {
  if (idx < 0 || idx >= venuxTracks.length) return;
  const wasPlaying = !playerAudio.paused && idx === currentTrackIdx;
  venuxTracks.splice(idx, 1);
  savePlayerTracks(venuxTracks);
  if (venuxTracks.length === 0) {
    playerPause();
    document.getElementById('miniPlayer').style.display = 'none';
    document.getElementById('miniPlayerEmpty').style.display = 'flex';
  } else {
    if (currentTrackIdx >= venuxTracks.length) currentTrackIdx = 0;
    loadTrack(currentTrackIdx, wasPlaying);
  }
  renderTracklist();
}

