async function generateAiPhoto() {
  const apiKey = localStorage.getItem('venux_openai_key');
  if (!apiKey || !photoSelectedMember || !photoUserFile) return;
  const btn = document.getElementById('photoGenerateBtn');
  const m = memberData[photoSelectedMember];
  btn.disabled = true;
  btn.textContent = '생성 중... ⏳';
  startPhotoStatus(m.name);

  try {
    // Prepare both images as 1024x1024 PNGs
    const userBlob = await resizeImageToSquare(photoUserFile);
    const memberBlob = await loadMemberPortraitBlob(photoSelectedMember);
    const memberResized = await resizeImageToSquare(memberBlob);

    // Build prompt with identity preservation
    const prompt = buildPhotoPromptWithOptions(PHOTO_PROMPTS[photoSelectedMember] || '') + PHOTO_PROMPT_SUFFIX;

    // Multi-image FormData: image[] array
    const form = new FormData();
    form.append('model', 'gpt-image-2');
    form.append('image[]', userBlob, 'user.png');
    form.append('image[]', memberResized, 'member.png');
    form.append('prompt', prompt);
    form.append('size', '1024x1024');
    form.append('quality', 'high');

    const res = await fetch('https://api.openai.com/v1/images/edits', {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${apiKey}` },
      body: form
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      if (err.error?.code === 'content_policy_violation') throw new Error('콘텐츠 정책 위반');
      if (res.status === 401) { showToast('API Key를 확인해주세요'); openSettings(); throw new Error('invalid key'); }
      if (res.status === 429) throw new Error('요청 한도 초과. 잠시 후 다시 시도해주세요.');
      throw new Error(apiErrorMessage({ status: res.status }));
    }

    const data = await res.json();
    const imgData = data.data[0]?.url || (data.data[0]?.b64_json ? `data:image/png;base64,${data.data[0].b64_json}` : null);
    if (!imgData) throw new Error('이미지 데이터가 없어요');
    showPhotoResult(imgData, m);
  } catch (err) {
    stopPhotoStatus();
    if (err.message !== 'invalid key') {
      showToast(err.message || '사진 생성에 실패했어요. Mock 모드로 전환합니다.');
      generateMockPhoto();
    }
  } finally {
    btn.disabled = false;
    btn.textContent = '✨ 최애 멤버와 함께 셀카찍기';
    checkPhotoReady();
  }
}

// Mock photo: Canvas composite
async function generateMockPhoto() {
  if (!photoSelectedMember || !photoUserFile) return;
  const btn = document.getElementById('photoGenerateBtn');
  const m = memberData[photoSelectedMember];
  btn.disabled = true;
  btn.textContent = '생성 중... ⏳';
  startPhotoStatus(m.name);

  try {
    await new Promise(r => setTimeout(r, 2000));

    const canvas = document.createElement('canvas');
    canvas.width = 1024; canvas.height = 1024;
    const ctx = canvas.getContext('2d');

    // Background with member gradient
    const grad = ctx.createLinearGradient(0, 0, 1024, 1024);
    const colors = m.gradient.match(/#[0-9A-Fa-f]{6}/g) || ['#f5f3ff', '#e8e5ff'];
    grad.addColorStop(0, colors[0] + '33');
    grad.addColorStop(1, (colors[1] || colors[0]) + '33');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, 1024, 1024);

    // Left: user photo
    const userImg = await loadImage(photoUserDataUrl);
    ctx.save();
    ctx.beginPath();
    ctx.rect(0, 0, 512, 1024);
    ctx.clip();
    const uScale = Math.max(512 / userImg.width, 1024 / userImg.height);
    const uw = userImg.width * uScale, uh = userImg.height * uScale;
    ctx.drawImage(userImg, (512 - uw) / 2, (1024 - uh) / 2, uw, uh);
    ctx.restore();

    // Right: member photo
    const memberImg = await loadImage(m.photo);
    ctx.save();
    ctx.beginPath();
    ctx.rect(512, 0, 512, 1024);
    ctx.clip();
    const mScale = Math.max(512 / memberImg.width, 1024 / memberImg.height);
    const mw = memberImg.width * mScale, mh = memberImg.height * mScale;
    ctx.drawImage(memberImg, 512 + (512 - mw) / 2, (1024 - mh) / 2, mw, mh);
    ctx.restore();

    // Center sparkle overlay
    ctx.fillStyle = 'rgba(255,255,255,0.15)';
    ctx.beginPath();
    ctx.arc(512, 512, 60, 0, Math.PI * 2);
    ctx.fill();
    ctx.font = '48px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('✨', 512, 530);

    // Watermark
    ctx.fillStyle = 'rgba(255,255,255,0.7)';
    ctx.fillRect(0, 980, 1024, 44);
    ctx.font = '500 14px "JetBrains Mono", monospace';
    ctx.fillStyle = '#999';
    ctx.textAlign = 'center';
    ctx.fillText(`Me × ${m.name} · VenuX Oracle · ${getDateString()}`, 512, 1006);

    const dataUrl = canvas.toDataURL('image/png');
    showPhotoResult(dataUrl, m);
    showToast('실시간 합성을 위해 설정에서 API Key를 추가해보세요');
  } catch (err) {
    showToast('사진 합성에 실패했어요');
  } finally {
    btn.disabled = false;
    btn.textContent = '✨ 최애 멤버와 함께 셀카찍기';
    checkPhotoReady();
  }
}

function loadImage(src) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => resolve(img);
    img.onerror = reject;
    img.src = src;
  });
}

