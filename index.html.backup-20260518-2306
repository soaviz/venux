function toggleDiaryEntry(key, id) {
  const content = document.getElementById('diary-content-' + id);
  const preview = document.getElementById('diary-prev-' + id);
  const chev = document.getElementById('diary-chev-' + id);
  const row = document.getElementById('diary-row-' + id);
  if (!content) return;
  const isOpen = content.style.display !== 'none';
  if (isOpen) {
    content.style.display = 'none';
    if (preview) preview.style.display = 'block';
    if (chev) chev.style.transform = '';
    if (row) row.classList.remove('diary-open');
  } else {
    // 내용 채우기 (최초 1회)
    if (!content.dataset.loaded) {
      const entries = MEMBER_DIARY[key] || [];
      const entry = entries.find(e => e.id === id);
      if (entry) {
        const m = memberData[key];
        content.innerHTML = `<div class="diary-body">${entry.content.replace(/\n\n/g,'</p><p class="diary-para">').replace(/\n/g,'<br>')}</div>`;
        content.dataset.loaded = '1';
      }
    }
    content.style.display = 'block';
    if (preview) preview.style.display = 'none';
    if (chev) chev.style.transform = 'rotate(90deg)';
    if (row) row.classList.add('diary-open');
  }
}

