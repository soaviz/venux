// Upload state
let pendingCoverFile = null;
let pendingAudioFile = null;

const AUDIO_ACCEPT = ['.mp3','.wav','.flac','.ogg','.aac','.m4a','.aiff','.aif','.opus','.wma','.mov'];
const AUDIO_MIMES = ['audio/mpeg','audio/wav','audio/flac','audio/ogg','audio/aac','audio/mp4','audio/x-m4a','audio/aiff','audio/opus','audio/x-ms-wma','video/quicktime'];
const IMAGE_MIMES = ['image/jpeg','image/png','image/webp','image/gif'];
const MAX_AUDIO_SIZE = 50 * 1024 * 1024; // 50MB
const MAX_IMAGE_SIZE = 10 * 1024 * 1024; // 10MB

function formatFileSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
  return (bytes/(1024*1024)).toFixed(1) + ' MB';
}

function handleCoverSelect(e) { processCoverFile(e.target.files[0]); }
function handleCoverDrop(e) { processCoverFile(e.dataTransfer.files[0]); }
function handleAudioSelect(e) { processAudioFile(e.target.files[0]); }
function handleAudioDrop(e) { processAudioFile(e.dataTransfer.files[0]); }

const COVER_RESIZE_PX = 300; // 앨범 커버 자동 리사이즈 크기

function processCoverFile(file) {
  if (!file) return;
  if (!IMAGE_MIMES.includes(file.type)) { showToast('이미지 파일만 업로드 가능 (JPG, PNG, WEBP, GIF)'); return; }
  if (file.size > MAX_IMAGE_SIZE) { showToast('이미지 크기는 10MB 이하여야 합니다'); return; }

  const preview = document.getElementById('coverPreview');
  const blobUrl = URL.createObjectURL(file);

  // 이미지를 Canvas로 리사이즈 후 저장
  const img = new Image();
  img.onload = () => {
    const size = COVER_RESIZE_PX;
    const canvas = document.createElement('canvas');
    canvas.width = size;
    canvas.height = size;
    const ctx = canvas.getContext('2d');

    // 중앙 크롭 (정사각형)
    const srcSize = Math.min(img.width, img.height);
    const sx = (img.width - srcSize) / 2;
    const sy = (img.height - srcSize) / 2;
    ctx.drawImage(img, sx, sy, srcSize, srcSize, 0, 0, size, size);

    canvas.toBlob((blob) => {
      pendingCoverFile = new File([blob], file.name.replace(/\.[^.]+$/, '.jpg'), { type: 'image/jpeg' });
      const resizedUrl = URL.createObjectURL(pendingCoverFile);
      const origKB = formatFileSize(file.size);
      const newKB = formatFileSize(blob.size);

      preview.style.display = 'block';
      preview.innerHTML = `<div class="upload-preview">
        <img src="${resizedUrl}" class="upload-cover-preview" alt="">
        <div class="upload-preview-info">
          <div class="upload-preview-name">${file.name}</div>
          <div class="upload-preview-size">${img.width}×${img.height} → ${size}×${size} · ${origKB} → ${newKB}</div>
        </div>
        <button class="upload-preview-remove" onclick="removeCoverFile()">삭제</button>
      </div>`;
      document.getElementById('coverUploadZone').style.display = 'none';
      URL.revokeObjectURL(blobUrl);
    }, 'image/jpeg', 0.85);
  };
  img.onerror = () => {
    showToast('이미지를 읽을 수 없습니다');
    URL.revokeObjectURL(blobUrl);
  };
  img.src = blobUrl;
}

function removeCoverFile() {
  pendingCoverFile = null;
  document.getElementById('coverPreview').style.display = 'none';
  document.getElementById('coverPreview').innerHTML = '';
  document.getElementById('coverUploadZone').style.display = '';
  document.getElementById('coverFileInput').value = '';
}

function processAudioFile(file) {
  if (!file) return;
  const ext = '.' + file.name.split('.').pop().toLowerCase();
  if (!AUDIO_MIMES.includes(file.type) && !AUDIO_ACCEPT.includes(ext)) {
    showToast('지원하지 않는 오디오 형식입니다'); return;
  }
  if (file.size > MAX_AUDIO_SIZE) { showToast('오디오 크기는 50MB 이하여야 합니다'); return; }
  pendingAudioFile = file;
  const preview = document.getElementById('audioPreview');
  preview.style.display = 'block';
  const extLabel = ext.toUpperCase().replace('.','');
  preview.innerHTML = `<div class="upload-preview">
    <div class="upload-preview-icon">🎵</div>
    <div class="upload-preview-info">
      <div class="upload-preview-name">${file.name}</div>
      <div class="upload-preview-size">${formatFileSize(file.size)} · ${extLabel}</div>
    </div>
    <button class="upload-preview-remove" onclick="removeAudioFile()">삭제</button>
  </div>`;
  document.getElementById('audioUploadZone').style.display = 'none';
}

function removeAudioFile() {
  pendingAudioFile = null;
  document.getElementById('audioPreview').style.display = 'none';
  document.getElementById('audioPreview').innerHTML = '';
  document.getElementById('audioUploadZone').style.display = '';
  document.getElementById('audioFileInput').value = '';
}

function settingsAddTrack() {
  if (!getAdminSession()) { showToast('관리자 로그인이 필요합니다'); return; }

  const title = document.getElementById('addTrackTitle').value.trim();
  const audioUrl = document.getElementById('addTrackAudio').value.trim();
  const member = document.getElementById('addTrackMember').value;

  if (!title) { showToast('트랙 제목을 입력하세요'); return; }
  if (!pendingAudioFile && !audioUrl) { showToast('음원 파일 또는 URL을 입력하세요'); return; }

  // Show progress
  const progressEl = document.getElementById('uploadProgress');
  const fillEl = document.getElementById('uploadProgressFill');
  progressEl.style.display = 'block';
  fillEl.style.width = '10%';

  if (pendingAudioFile) {
    // File upload — read as data URL (for localStorage)
    fillEl.style.width = '30%';
    const audioReader = new FileReader();
    audioReader.onprogress = (e) => {
      if (e.lengthComputable) fillEl.style.width = (30 + (e.loaded/e.total)*40) + '%';
    };
    audioReader.onload = (ae) => {
      fillEl.style.width = '75%';
      const audioData = ae.target.result;
      if (pendingCoverFile) {
        const coverReader = new FileReader();
        coverReader.onload = (ce) => {
          fillEl.style.width = '90%';
          finishTrackAdd(title, member, audioData, ce.target.result, progressEl, fillEl);
        };
        coverReader.readAsDataURL(pendingCoverFile);
      } else {
        finishTrackAdd(title, member, audioData, '', progressEl, fillEl);
      }
    };
    audioReader.readAsDataURL(pendingAudioFile);
  } else {
    // URL mode
    fillEl.style.width = '50%';
    if (pendingCoverFile) {
      const coverReader = new FileReader();
      coverReader.onload = (ce) => {
        fillEl.style.width = '90%';
        finishTrackAdd(title, member, audioUrl, ce.target.result, progressEl, fillEl);
      };
      coverReader.readAsDataURL(pendingCoverFile);
    } else {
      finishTrackAdd(title, member, audioUrl, '', progressEl, fillEl);
    }
  }
}

function finishTrackAdd(title, member, audio, cover, progressEl, fillEl) {
  addTrackFromURL(title, member, audio, cover);
  fillEl.style.width = '100%';
  setTimeout(() => {
    progressEl.style.display = 'none';
    fillEl.style.width = '0';
    // Reset form
    document.getElementById('addTrackTitle').value = '';
    document.getElementById('addTrackAudio').value = '';
    removeCoverFile();
    removeAudioFile();
    renderGameSettings();
  }, 500);
}

