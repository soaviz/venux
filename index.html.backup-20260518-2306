  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
    html, body { width:100%; height:100%; overflow:hidden; font-family:'Noto Sans KR','Inter',sans-serif; background:#F5F3FF; color:#0A0A0A; -webkit-font-smoothing:antialiased; }
    body { padding-top:env(safe-area-inset-top); padding-bottom:env(safe-area-inset-bottom); padding-left:env(safe-area-inset-left); padding-right:env(safe-area-inset-right); }

    /* SCREENS */
    .screen { position:absolute; top:0; left:0; width:100%; height:100%; overflow-y:auto; overflow-x:hidden; transition:opacity 0.4s,transform 0.4s; opacity:0; pointer-events:none; transform:translateY(20px); -webkit-overflow-scrolling:touch; }
    .screen.active { opacity:1; pointer-events:auto; transform:translateY(0); z-index:10; }

    /* HEADER */
    .back-btn { display:inline-flex; align-items:center; gap:4px; padding:6px 12px 6px 8px; border-radius:20px; border:none; background:rgba(107,91,214,0.08); color:#6B5BD6; font-size:13px; font-weight:600; font-family:'Noto Sans KR',sans-serif; cursor:pointer; -webkit-tap-highlight-color:transparent; transition:background 0.15s; flex-shrink:0; }
    .back-btn:active { background:rgba(107,91,214,0.18); }
    .back-btn svg { width:16px; height:16px; }
    .header { position:sticky; top:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:12px 20px; background:rgba(245,243,255,0.92); backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); border-bottom:1px solid rgba(0,0,0,0.04); }
    .header-logo { font-family:'Fraunces',serif; font-size:20px; font-weight:600; background:linear-gradient(135deg,#6B5BD6,#8B6BD6); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .header-actions { display:flex; gap:8px; }
    .header-btn { background:rgba(107,91,214,0.08); border:none; padding:8px 14px; border-radius:20px; font-size:13px; font-weight:500; color:#6B5BD6; cursor:pointer; transition:all 0.2s; font-family:'Noto Sans KR',sans-serif; }
    .header-btn:hover { background:rgba(107,91,214,0.15); }

    /* MEMBER ROW */
    .member-row { display:flex; justify-content:center; gap:12px; padding:20px 16px 8px; flex-shrink:0; }
    .member-item { display:flex; flex-direction:column; align-items:center; gap:6px; cursor:pointer; transition:transform 0.2s; }
    .member-item:active { transform:scale(0.92); }
    .member-circle { width:62px; height:62px; border-radius:50%; background:var(--color); display:flex; align-items:center; justify-content:center; box-shadow:0 4px 20px var(--glow); position:relative; overflow:hidden; }
    .member-circle img { width:100%; height:100%; object-fit:cover; border-radius:50%; }
    .circle-inner { font-family:'JetBrains Mono',monospace; font-size:14px; font-weight:600; color:white; text-shadow:0 1px 3px rgba(0,0,0,0.3); }
    .member-circle.has-photo .circle-inner { display:none; }
    .member-label { display:flex; flex-direction:column; align-items:center; gap:2px; text-align:center; }
    .member-kr-name { font-family:'Noto Sans KR',sans-serif; font-size:15px; font-weight:600; color:#0A0A0A; transition:color 0.18s; line-height:1.2; }
    .member-item:hover .member-kr-name { color:var(--member-accent); }
    .member-codename { font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:500; letter-spacing:0.04em; line-height:1.2; }

    /* HEADLINE */
    .headline-section { text-align:center; padding:8px 24px 0; flex-shrink:0; }
    .headline-main { font-family:'Fraunces',serif; font-size:38px; font-weight:500; color:#0A0A0A; line-height:1.05; margin-bottom:6px; }
    .headline-sub { font-family:'Noto Sans KR',sans-serif; font-size:15px; color:#666; font-weight:400; margin-bottom:4px; }
    .headline-desc { font-family:'Inter',sans-serif; font-size:12px; color:#999; letter-spacing:0.02em; }

    /* INPUT */
    .input-section { padding:16px 20px 8px; flex-shrink:0; }
    .textarea-wrap { position:relative; }
    .textarea-wrap textarea { width:100%; min-height:80px; padding:16px; border:2px solid rgba(107,91,214,0.12); border-radius:16px; font-size:15px; font-family:'Noto Sans KR',sans-serif; resize:none; background:white; color:#0A0A0A; outline:none; transition:border-color 0.2s; line-height:1.5; }
    .textarea-wrap textarea:focus { border-color:#6B5BD6; }
    .textarea-wrap textarea::placeholder { color:#aaa; }
    .char-counter { position:absolute; bottom:8px; right:12px; font-size:11px; color:#bbb; font-family:'JetBrains Mono',monospace; }

    /* CATEGORY TABS */
    .examples-tabs-wrap { overflow-x:auto; overflow-y:hidden; -webkit-overflow-scrolling:touch; padding:8px 20px 4px; white-space:nowrap; scrollbar-width:none; }
    .examples-tabs-wrap::-webkit-scrollbar { display:none; }
    .examples-tabs { display:inline-flex; gap:8px; }
    .example-tab { display:inline-flex; align-items:center; height:36px; padding:0 16px; border-radius:18px; border:1.5px solid #e0dce8; background:white; color:#666; font-size:13px; font-weight:500; font-family:'Noto Sans KR',sans-serif; cursor:pointer; transition:all 0.2s; white-space:nowrap; flex-shrink:0; }
    .example-tab.active { background:#5B5BD6; color:white; border-color:#5B5BD6; }
    .example-tab:not(.active):hover { border-color:#6B5BD6; color:#6B5BD6; }

    /* EXAMPLE CARDS */
    .examples-section { padding:6px 0 12px; flex-shrink:0; }
    .examples-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; padding:0 20px; }
    .examples-title { font-size:14px; font-weight:600; color:#333; }
    .refresh-btn { background:none; border:none; font-size:18px; cursor:pointer; padding:4px; transition:transform 0.4s; }
    .refresh-btn.spinning { transform:rotate(360deg); }
    .examples-cards { display:flex; flex-direction:column; gap:8px; padding:0 20px; min-height:150px; }
    .example-card { display:flex; align-items:center; gap:10px; padding:14px 16px; background:white; border-radius:14px; cursor:pointer; transition:all 0.2s; box-shadow:0 2px 8px rgba(0,0,0,0.04); opacity:1; transform:translateY(0); }
    .example-card:active { transform:scale(0.97); }
    .example-card.fade-out { opacity:0; transform:translateY(-8px); }
    .example-card.fade-in { opacity:0; transform:translateY(8px); }
    .example-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
    .example-text { flex:1; font-size:14px; color:#333; line-height:1.4; }
    .example-arrow { color:#bbb; font-size:14px; flex-shrink:0; }

    /* CTA */
    .cta-section { padding:8px 20px 12px; flex-shrink:0; }
    .cta-btn { width:100%; height:60px; border:none; border-radius:30px; background:linear-gradient(135deg,#6B5BD6,#8B6BD6); color:white; font-size:17px; font-weight:600; font-family:'Noto Sans KR',sans-serif; cursor:pointer; transition:all 0.2s; box-shadow:0 4px 20px rgba(107,91,214,0.3); }
    .cta-btn:active { transform:scale(0.97); }
    .cta-btn:disabled { opacity:0.5; cursor:not-allowed; }

    /* FOOTER */
    .footer { text-align:center; padding:12px 20px 20px; font-size:11px; color:#bbb; }
    .footer a { color:#6B5BD6; text-decoration:none; }

    /* LOADING SCREEN */
    #screen-loading { background:rgba(10,10,10,0.95); }
    .loading-container { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:100vh; padding:40px 24px; gap:16px; }
    .loading-title { font-family:'Fraunces',serif; font-size:22px; color:white; margin-bottom:20px; text-align:center; }
    .loading-pill { display:flex; align-items:center; gap:12px; padding:14px 20px; background:rgba(255,255,255,0.06); border-radius:16px; width:100%; max-width:320px; transition:all 0.4s; }
    .loading-pill.active { background:rgba(255,255,255,0.12); }
    .loading-pill.done { background:rgba(107,91,214,0.2); }
    .loading-avatar { width:36px; height:36px; border-radius:50%; overflow:hidden; flex-shrink:0; }
    .loading-avatar img { width:100%; height:100%; object-fit:cover; }
    .loading-avatar-letter { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:600; color:white; }
    .loading-info { flex:1; }
    .loading-name { font-size:14px; font-weight:600; color:white; }
    .loading-status { font-size:12px; color:rgba(255,255,255,0.5); margin-top:2px; }
    .loading-check { font-size:18px; opacity:0; transition:opacity 0.3s; }
    .loading-pill.done .loading-check { opacity:1; }
    .loading-pill.active .loading-status { color:rgba(255,255,255,0.8); }
    @keyframes pulse-glow { 0%,100%{opacity:0.6} 50%{opacity:1} }
    .loading-pill.active { animation:pulse-glow 1.5s ease-in-out infinite; }

    /* RESULTS SCREEN */
    .results-header { position:sticky; top:0; z-index:50; background:rgba(245,243,255,0.95); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); padding:14px 20px; border-bottom:1px solid rgba(0,0,0,0.04); }
    .results-question { font-size:15px; font-weight:600; color:#333; line-height:1.4; }
    .results-cards { padding:16px 20px; display:flex; flex-direction:column; gap:16px; }
    .result-card { background:white; border-radius:20px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.06); opacity:0; transform:translateY(20px); transition:all 0.5s; }
    .result-card.show { opacity:1; transform:translateY(0); }
    .result-card-band { height:4px; }
    .result-card-body { padding:20px; }
    .result-card-header { display:flex; align-items:center; gap:12px; margin-bottom:12px; }
    .result-avatar { width:48px; height:48px; border-radius:50%; overflow:hidden; flex-shrink:0; }
    .result-avatar img { width:100%; height:100%; object-fit:cover; }
    .result-avatar-letter { width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'JetBrains Mono',monospace; font-size:16px; font-weight:600; color:white; }
    .result-name-row { flex:1; }
    .result-codename { font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:500; letter-spacing:0.04em; }
    .result-krname { font-size:16px; font-weight:600; color:#0A0A0A; }
    .result-element { font-size:12px; padding:3px 8px; border-radius:10px; font-weight:500; display:inline-block; }
    .result-answer { font-size:15px; line-height:1.65; color:#333; margin-bottom:10px; word-break:keep-all; }
    .result-micdrop { font-style:italic; font-size:14px; line-height:1.5; padding:10px 14px; border-radius:12px; }

    /* VERDICT */
    .verdict-section { padding:32px 20px; text-align:center; }
    .verdict-label { font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.1em; color:#999; text-transform:uppercase; margin-bottom:16px; }
    .verdict-portrait { width:140px; height:140px; border-radius:50%; margin:0 auto 16px; overflow:hidden; box-shadow:0 8px 40px rgba(0,0,0,0.1); }
    .verdict-portrait img { width:100%; height:100%; object-fit:cover; }
    .verdict-portrait-letter { width:140px; height:140px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'JetBrains Mono',monospace; font-size:40px; font-weight:600; color:white; margin:0 auto 16px; }
    .verdict-name { font-family:'Fraunces',serif; font-size:28px; font-weight:500; color:#0A0A0A; margin-bottom:4px; }
    .verdict-reason { font-size:14px; font-weight:500; margin-bottom:8px; }
    .verdict-desc { font-size:13px; color:#888; line-height:1.5; max-width:300px; margin:0 auto; }

    /* PHOTO SECTION */
    .photo-section { padding:24px 20px; background:white; border-radius:24px; margin:16px 20px; box-shadow:0 2px 12px rgba(0,0,0,0.04); }
    .photo-section-title { font-size:18px; font-weight:600; margin-bottom:4px; }
    .photo-section-sub { font-size:13px; color:#888; margin-bottom:16px; }
    .photo-member-row { display:flex; gap:10px; justify-content:center; margin-bottom:20px; }
    .photo-member-item { display:flex; flex-direction:column; align-items:center; gap:4px; cursor:pointer; transition:all 0.25s; opacity:0.45; filter:grayscale(0.6); }
    .photo-member-item.active { opacity:1; filter:none; transform:scale(1.1); }
    .photo-member-circle { width:52px; height:52px; border-radius:50%; overflow:hidden; border:3px solid transparent; transition:all 0.25s; box-shadow:0 2px 8px transparent; }
    .photo-member-item.active .photo-member-circle { border-width:4px; border-color:var(--pm-color); box-shadow:0 4px 16px var(--pm-glow); }
    .photo-member-circle img { width:100%; height:100%; object-fit:cover; }
    .photo-member-name { font-size:11px; color:#aaa; transition:all 0.2s; font-weight:400; }
    .photo-member-item.active .photo-member-name { color:var(--pm-color); font-weight:700; }
    .photo-preview-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }
    .photo-preview-box { aspect-ratio:1; border-radius:16px; overflow:hidden; background:#f5f5f5; display:flex; align-items:center; justify-content:center; flex-direction:column; position:relative; }
    .photo-preview-box img { width:100%; height:100%; object-fit:cover; }
    .photo-preview-box .preview-label { position:absolute; bottom:8px; left:50%; transform:translateX(-50%); font-size:11px; font-weight:600; background:rgba(0,0,0,0.5); color:white; padding:3px 10px; border-radius:10px; white-space:nowrap; }
    .photo-preview-placeholder { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; color:#bbb; font-size:13px; width:100%; height:100%; }
    .photo-preview-placeholder .placeholder-icon { font-size:28px; }
    .photo-member-big { position:relative; }
    .photo-member-big img { width:100%; height:100%; object-fit:cover; border-radius:16px; }
    .photo-member-big-label { position:absolute; bottom:10px; left:50%; transform:translateX(-50%); background:rgba(0,0,0,0.55); color:white; padding:4px 12px; border-radius:12px; font-size:12px; font-weight:600; white-space:nowrap; backdrop-filter:blur(4px); }
    .photo-generate-btn { width:100%; padding:14px; border:none; border-radius:14px; background:linear-gradient(135deg,#6B5BD6,#8B6BD6); color:white; font-size:15px; font-weight:600; cursor:pointer; font-family:'Noto Sans KR',sans-serif; transition:all 0.2s; }
    /* 의상/배경 아코디언 */
    .photo-options-accordion { margin-bottom:16px; border-radius:14px; overflow:hidden; border:1px solid rgba(107,91,214,0.15); display:none; }
    .photo-options-accordion.visible { display:block; }
    /* 아코디언 — CSS 변수로 색상 분리 */
    .accord-item { background:#fff; --ac:#6B5BD6; --ac-rgb:107,91,214; }
    .accord-item + .accord-item { border-top:1px solid rgba(0,0,0,0.06); }
    .accord-header { display:flex; align-items:center; justify-content:space-between; padding:12px 16px; cursor:pointer; user-select:none; -webkit-tap-highlight-color:transparent; }
    .accord-header-left { display:flex; align-items:center; gap:8px; }
    .accord-title { font-size:13px; font-weight:600; color:#333; font-family:'Noto Sans KR',sans-serif; }
    .accord-selected { font-size:11px; color:var(--ac); background:rgba(var(--ac-rgb),0.1); padding:2px 8px; border-radius:20px; }
    .accord-arrow { font-size:11px; color:#aaa; transition:transform 0.2s; }
    .accord-item.open .accord-arrow { transform:rotate(180deg); }
    .accord-body { display:none; padding:0 16px 14px; }
    .accord-item.open .accord-body { display:block; }
    .accord-cat-tabs { display:flex; gap:6px; overflow-x:auto; padding-bottom:10px; margin-bottom:10px; scrollbar-width:none; -ms-overflow-style:none; border-bottom:1px solid rgba(0,0,0,0.06); }
    .accord-cat-tabs::-webkit-scrollbar { display:none; }
    .accord-cat-tab { padding:5px 12px; border-radius:20px; border:1.5px solid rgba(var(--cat-rgb),0.25); background:rgba(var(--cat-rgb),0.06); font-size:11px; font-family:'Noto Sans KR',sans-serif; color:#777; cursor:pointer; white-space:nowrap; flex-shrink:0; transition:all 0.15s; }
    .accord-cat-tab.active { background:var(--cat); border-color:var(--cat); color:#fff; font-weight:700; }
    .accord-chips { display:flex; flex-wrap:wrap; gap:7px; max-height:120px; overflow-y:auto; scrollbar-width:none; }
    .accord-chips::-webkit-scrollbar { display:none; }
    .accord-chip { padding:6px 12px; border-radius:20px; border:1.5px solid rgba(var(--chip-rgb),0.25); background:rgba(var(--chip-rgb),0.05); font-size:12px; font-family:'Noto Sans KR',sans-serif; color:#555; cursor:pointer; transition:all 0.15s; white-space:nowrap; }
    .accord-chip.active { background:var(--chip); border-color:var(--chip); color:#fff; font-weight:600; }
    .accord-chip:active { transform:scale(0.95); }
    /* 의상: 대주제 로즈핑크 / 소주제 웜오렌지 */
    #accordOutfit { --ac:#E8568A; --ac-rgb:232,86,138; --cat:#E8568A; --cat-rgb:232,86,138; --chip:#F97316; --chip-rgb:249,115,22; }
    /* 배경: 대주제 스카이블루 / 소주제 에메랄드 */
    #accordBg     { --ac:#0EA5E9; --ac-rgb:14,165,233;  --cat:#0EA5E9; --cat-rgb:14,165,233;  --chip:#10B981; --chip-rgb:16,185,129; }
    .photo-generate-btn:disabled { opacity:0.4; cursor:not-allowed; background:#ccc; }
    .photo-generate-btn:not(:disabled):active { transform:scale(0.97); }
    .photo-result { margin-top:16px; text-align:center; }
    .photo-result img { width:100%; border-radius:16px; box-shadow:0 4px 20px rgba(0,0,0,0.1); }
    .photo-result-watermark { font-size:11px; color:#bbb; margin-top:8px; font-family:'JetBrains Mono',monospace; }
    .photo-result-comment { margin-top:8px; font-size:14px; font-style:italic; color:#666; }
    .member-msg-card { margin-top:20px; padding:24px; border-radius:24px; border-left:4px solid var(--msg-color); box-shadow:0 2px 12px rgba(0,0,0,0.04); position:relative; overflow:hidden; opacity:0; animation:msgFadeIn 0.5s ease forwards; }
    .member-msg-card::before { content:''; position:absolute; top:0; left:0; width:100%; height:100%; background:radial-gradient(circle at 20% 50%, var(--msg-tint) 0%, white 70%); z-index:0; }
    .member-msg-card > * { position:relative; z-index:1; }
    .member-msg-label { font-family:'Inter',sans-serif; font-size:12px; color:#999; margin-bottom:12px; }
    .member-msg-text { font-family:'Noto Sans KR',sans-serif; font-size:17px; font-weight:400; color:#0A0A0A; line-height:1.6; word-break:keep-all; }
    .member-msg-footer { text-align:right; margin-top:14px; font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:500; }
    @keyframes msgFadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
    .photo-status-text { text-align:center; font-size:13px; color:#888; padding:12px 0; }
    @keyframes sparkle-float { 0%{transform:translateY(0) scale(1);opacity:0.8} 50%{transform:translateY(-8px) scale(1.2);opacity:1} 100%{transform:translateY(0) scale(1);opacity:0.8} }
    .photo-sparkle { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:28px; z-index:5; animation:sparkle-float 1.2s ease-in-out infinite; pointer-events:none; }
    .photo-api-key-modal { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); backdrop-filter:blur(8px); z-index:1100; display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; transition:opacity 0.3s; }
    .photo-api-key-modal.show { opacity:1; pointer-events:auto; }
    .photo-api-key-card { background:white; border-radius:20px; padding:28px 24px; max-width:340px; width:90%; }
    .photo-api-key-card h3 { font-size:16px; margin-bottom:12px; text-align:center; }
    .photo-api-key-card input { width:100%; padding:12px; border:2px solid #e8e8e8; border-radius:12px; font-size:14px; margin-bottom:12px; outline:none; transition:border-color 0.2s; font-family:'Noto Sans KR',sans-serif; }
    .photo-api-key-card input:focus { border-color:#6B5BD6; }
