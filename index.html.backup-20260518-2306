function checkDailyReset(db) {
  const today = todayStr();
  if (db.game_state.last_reset !== today) {
    db.game_state.available_actions_today = 3;
    db.game_state.last_reset = today;
    // Randomize moods
    memberOrder.forEach(k => {
      db.member_relationships[k].current_mood = MOODS[Math.floor(Math.random() * MOODS.length)];
    });
    saveDB(db);
  }
  return db;
}

