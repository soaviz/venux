  { id:'track_atp', title:'Root (Solo)', artist:'ATP-X1', member:'ATP-X1', cover:'', audio:'', duration:0, keyColor:'#9BAE82' }
];

let venuxTracks = [];
let playerAudio = null;
let currentTrackIdx = 0;
let playerRepeat = false;
let playerShuffle = false;

function loadPlayerTracks() {
  try {
    const saved = JSON.parse(localStorage.getItem('venux_tracks'));
    if (saved && saved.length) return saved;
  } catch {}
  return [];
}
function savePlayerTracks(tracks) {
  localStorage.setItem('venux_tracks', JSON.stringify(tracks));
}

function loadPlayerState() {
  try { return JSON.parse(localStorage.getItem('venux_player_state')) || {}; }
  catch { return {}; }
}
function savePlayerState() {
  const state = {
    currentTrackId: venuxTracks[currentTrackIdx]?.id || '',
    currentTime: playerAudio?.currentTime || 0,
    repeat: playerRepeat,
    shuffle: playerShuffle
  };
  localStorage.setItem('venux_player_state', JSON.stringify(state));
}

function initPlayer() {
  venuxTracks = loadPlayerTracks();
  if (!playerAudio) {
    playerAudio = new Audio();
    playerAudio.addEventListener('ended', onTrackEnd);
    playerAudio.addEventListener('timeupdate', onTimeUpdate);
    playerAudio.addEventListener('loadedmetadata', onMetaLoaded);
  }

  if (venuxTracks.length === 0) {
    document.getElementById('miniPlayerEmpty').style.display = 'flex';
    document.getElementById('miniPlayer').style.display = 'none';
    return;
  }

  document.getElementById('miniPlayerEmpty').style.display = 'none';
  document.getElementById('miniPlayer').style.display = 'flex';

  // Restore state
  const state = loadPlayerState();
  playerRepeat = state.repeat || false;
  playerShuffle = state.shuffle || false;

  const idx = venuxTracks.findIndex(t => t.id === state.currentTrackId);
  currentTrackIdx = idx >= 0 ? idx : 0;

  loadTrack(currentTrackIdx, false);
  if (state.currentTime && playerAudio.src) {
    playerAudio.currentTime = state.currentTime;
  }
}

function loadTrack(idx, autoplay) {
  if (!venuxTracks.length) return;
  currentTrackIdx = ((idx % venuxTracks.length) + venuxTracks.length) % venuxTracks.length;
  const track = venuxTracks[currentTrackIdx];

  // Set audio
  if (track.audio) {
    playerAudio.src = track.audio;
    playerAudio.load();
  }

  // Cover fallback
  const coverUrl = track.cover || getMemberCoverFallback(track.member);

  // Mini player
  document.getElementById('miniCoverImg').src = coverUrl;
  document.getElementById('miniTitle').textContent = track.title;
  document.getElementById('miniPlayer').style.display = 'flex';
  document.getElementById('miniPlayerEmpty').style.display = 'none';

  // Fullscreen player
  document.getElementById('fpCoverImg').src = coverUrl;
  document.getElementById('fpTitle').textContent = track.title;
  document.getElementById('fpMember').textContent = track.member === 'group' ? 'VenuX' : (memberData[track.member]?.name || track.member);
  document.getElementById('fpBg').style.backgroundImage = `url(${coverUrl})`;
  document.getElementById('fpProgressFill').style.width = '0';
  document.getElementById('fpTimeNow').textContent = '0:00';
  document.getElementById('fpTimeDur').textContent = formatDuration(track.duration || 0);

  // Tracklist highlight
  renderTracklist();
  updateRepeatShuffleUI();
  savePlayerState();

  if (autoplay && track.audio) playerPlay();
}

function getMemberCoverFallback(member) {
  if (member && memberData[member]) return memberData[member].photo;
  // Group fallback — use first member
  return memberData[memberOrder[0]]?.photo || '';
}

function playerPlay() {
  if (!venuxTracks.length || !playerAudio.src) return;
  playerAudio.play().catch(() => {});
  document.getElementById('miniPlayBtn').textContent = '⏸';
  document.getElementById('fpPlayBtn').textContent = '⏸';
  document.getElementById('miniCover').classList.add('spinning');
  document.getElementById('fpCover').classList.add('playing');
}

function playerPause() {
  playerAudio.pause();
  document.getElementById('miniPlayBtn').textContent = '▶';
  document.getElementById('fpPlayBtn').textContent = '▶';
  document.getElementById('miniCover').classList.remove('spinning');
  document.getElementById('fpCover').classList.remove('playing');
  savePlayerState();
}

function playerToggle() {
  if (playerAudio.paused) playerPlay(); else playerPause();
}

function playerNext() {
  if (!venuxTracks.length) return;
  if (playerShuffle) {
    let next;
    do { next = Math.floor(Math.random() * venuxTracks.length); } while (next === currentTrackIdx && venuxTracks.length > 1);
    loadTrack(next, !playerAudio.paused);
  } else {
    loadTrack(currentTrackIdx + 1, !playerAudio.paused);
  }
}

function playerPrev() {
  if (!venuxTracks.length) return;
  if (playerAudio.currentTime > 3) {
    playerAudio.currentTime = 0;
  } else {
    loadTrack(currentTrackIdx - 1, !playerAudio.paused);
  }
}

function onTrackEnd() {
  if (playerRepeat) {
    playerAudio.currentTime = 0;
    playerPlay();
  } else {
    playerNext();
  }
}

function onTimeUpdate() {
  if (!playerAudio.duration) return;
  const pct = (playerAudio.currentTime / playerAudio.duration) * 100;
  document.getElementById('fpProgressFill').style.width = pct + '%';
  document.getElementById('fpTimeNow').textContent = formatDuration(playerAudio.currentTime);
}

function onMetaLoaded() {
  document.getElementById('fpTimeDur').textContent = formatDuration(playerAudio.duration);
  // Update track duration in DB
  if (venuxTracks[currentTrackIdx]) {
    venuxTracks[currentTrackIdx].duration = Math.floor(playerAudio.duration);
    savePlayerTracks(venuxTracks);
  }
}

function seekTrack(e) {
  if (!playerAudio.duration) return;
  const bar = document.getElementById('fpProgressBar');
  const rect = bar.getBoundingClientRect();
  const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
  playerAudio.currentTime = pct * playerAudio.duration;
}

function formatDuration(sec) {
  if (!sec || isNaN(sec)) return '0:00';
  const m = Math.floor(sec / 60);
  const s = Math.floor(sec % 60).toString().padStart(2,'0');
  return `${m}:${s}`;
}

function toggleRepeat() { playerRepeat = !playerRepeat; updateRepeatShuffleUI(); savePlayerState(); }
function toggleShuffle() { playerShuffle = !playerShuffle; updateRepeatShuffleUI(); savePlayerState(); }
function updateRepeatShuffleUI() {
  document.getElementById('fpRepeatBtn')?.classList.toggle('active', playerRepeat);
  document.getElementById('fpShuffleBtn')?.classList.toggle('active', playerShuffle);
}

function openFullPlayer() {
  renderTracklist();
  document.getElementById('fpOverlay').classList.add('open');
}
function closeFullPlayer() {
  document.getElementById('fpOverlay').classList.remove('open');
}

function renderTracklist() {
  const list = document.getElementById('fpTracklist');
  if (!venuxTracks.length) { list.innerHTML = '<div style="text-align:center;padding:20px;color:rgba(255,255,255,0.3);font-size:13px">설정에서 트랙을 추가하세요 🎵</div>'; return; }
  list.innerHTML = venuxTracks.map((t, i) => {
    const cover = t.cover || getMemberCoverFallback(t.member);
    const active = i === currentTrackIdx;
    return `<div class="fp-track-item ${active?'active':''}" onclick="loadTrack(${i},true)">
      <div class="fp-track-item-cover"><img src="${cover}" alt=""></div>
      <div class="fp-track-item-info">
        <div class="fp-track-item-title">${t.title}</div>
        <div class="fp-track-item-member">${t.member === 'group' ? 'VenuX' : (memberData[t.member]?.name || t.member)}</div>
      </div>
      <div class="fp-track-item-dur">${formatDuration(t.duration)}</div>
    </div>`;
  }).join('');
}

function shareTrack() {
  const track = venuxTracks[currentTrackIdx];
  if (!track) return;
  const text = `🎵 ${track.title} — ${track.artist}\nhttps://soaviz.github.io/venux/`;
  if (navigator.share) {
    navigator.share({ title:track.title, text }).catch(()=>{});
  } else {
    navigator.clipboard?.writeText(text).then(() => showToast('링크 복사됨 📋'));
  }
}

