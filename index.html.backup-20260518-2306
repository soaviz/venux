let notifCheckInterval = null;

function getTimePeriod(hour) {
  if (hour >= 5 && hour < 12) return 'morning';
  if (hour >= 12 && hour < 17) return 'afternoon';
  if (hour >= 17 && hour < 21) return 'evening';
  return 'night';
}

function getTimeProbability(hour) {
  if (hour >= 8 && hour <= 10) return 0.05;
  if (hour >= 12 && hour <= 13) return 0.03;
  if (hour >= 19 && hour <= 21) return 0.07;
  if (hour >= 1 && hour <= 3) return 0.02;
  return 0.01;
}

function triggeredToday(type) {
  const key = `venux_notif_trigger_${type}_${todayStr()}`;
  return localStorage.getItem(key) === '1';
}
function markTriggered(type) {
  const key = `venux_notif_trigger_${type}_${todayStr()}`;
  localStorage.setItem(key, '1');
}

function pickRandom(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

function checkNotificationTriggers() {
  const db = getOrCreateDB();
  if (!db.user.nickname) return;

  const now = new Date();
  const hour = now.getHours();
  const lastVisit = db.user.last_visit_date;
  const hoursSince = lastVisit ? (now - new Date(lastVisit + 'T00:00:00')) / 3600000 : 0;

  // Trigger 1: Inactivity (highest priority)
  if (hoursSince >= 168 && !triggeredToday('inactivity')) { // 7 days
    const key = pickRandom(memberOrder);
    addNotification(key, NOTIF_MESSAGES[key].inactivity_7day);
    markTriggered('inactivity');
    return;
  }
  if (hoursSince >= 72 && !triggeredToday('inactivity')) { // 3 days
    const key = pickRandom(memberOrder);
    addNotification(key, NOTIF_MESSAGES[key].inactivity_3day);
    markTriggered('inactivity');
    return;
  }
  if (hoursSince >= 24 && !triggeredToday('inactivity')) { // 1 day
    const key = pickRandom(memberOrder);
    addNotification(key, NOTIF_MESSAGES[key].inactivity_1day);
    markTriggered('inactivity');
    return;
  }

  // Trigger 2: Level proximity
  if (!triggeredToday('level_prox')) {
    for (const key of memberOrder) {
      const rel = db.member_relationships[key];
      const lv = getAffinityLevel(rel.affection_points);
      if (lv < 5) {
        const nextLvPts = AFFINITY_LEVELS[lv]?.points || 9999;
        const ptsToGo = nextLvPts - rel.affection_points;
        if (ptsToGo > 0 && ptsToGo <= 30) {
          addNotification(key, NOTIF_MESSAGES[key].level_proximity);
          markTriggered('level_prox');
          return;
        }
      }
    }
  }

  // Trigger 3: Time-based random
  const prob = getTimeProbability(hour);
  if (Math.random() < prob && !triggeredToday('time_' + getTimePeriod(hour))) {
    const key = pickRandom(memberOrder);
    const period = getTimePeriod(hour);
    const msgs = NOTIF_MESSAGES[key][period];
    if (msgs && msgs.length) {
      addNotification(key, pickRandom(msgs));
      markTriggered('time_' + period);
    }
  }

  // Trigger 4: Random daily (max 2/day)
  const todayRandom = parseInt(localStorage.getItem(`venux_notif_random_${todayStr()}`) || '0');
  if (todayRandom < 2 && Math.random() < 0.02) {
    const key = pickRandom(memberOrder);
    const period = getTimePeriod(hour);
    const msgs = NOTIF_MESSAGES[key][period];
    if (msgs && msgs.length) {
      addNotification(key, pickRandom(msgs));
      localStorage.setItem(`venux_notif_random_${todayStr()}`, String(todayRandom + 1));
    }
  }
}

function startNotifChecks() {
  // Check immediately on load
  setTimeout(checkNotificationTriggers, 3000);
  // Then every 5 minutes
  notifCheckInterval = setInterval(checkNotificationTriggers, 5 * 60 * 1000);
}

function stopNotifChecks() {
  if (notifCheckInterval) { clearInterval(notifCheckInterval); notifCheckInterval = null; }
}

