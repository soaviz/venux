    if (msgDate !== lastDate) {
      html += `<div class="chat-date-divider"><span class="chat-date-pill">${formatChatDate(msg.timestamp)}</span></div>`;
      lastDate = msgDate;
      lastRole = '';
    }

    const isLast = (i === history.length - 1) || history[i+1]?.role !== msg.role || history[i+1]?.timestamp.slice(0,16) !== msg.timestamp.slice(0,16);
    const timeStr = isLast ? `<span class="chat-msg-time">${formatChatTime(msg.timestamp)}</span>` : '';

    if (msg.role === 'member') {
      const showAvatar = lastRole !== 'member';
      const m = memberData[memberKey];
