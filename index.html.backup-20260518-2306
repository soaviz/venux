      await new Promise(r => setTimeout(r, 600));

      const canvas = document.createElement('canvas');
      canvas.width = 512; canvas.height = 512;
      const ctx = canvas.getContext('2d');

      const colors = m.gradient.match(/#[0-9A-Fa-f]{6}/g) || ['#f5f3ff'];
      ctx.fillStyle = colors[0] + '22';
      ctx.fillRect(0, 0, 512, 512);

      const userImg = await loadImage(fourcutDataUrls[i]);
      ctx.save(); ctx.beginPath(); ctx.rect(0, 0, 256, 512); ctx.clip();
      const us = Math.max(256 / userImg.width, 512 / userImg.height);
      ctx.drawImage(userImg, (256 - userImg.width * us) / 2, (512 - userImg.height * us) / 2, userImg.width * us, userImg.height * us);
      ctx.restore();

      const memImg = await loadImage(m.photo);
      ctx.save(); ctx.beginPath(); ctx.rect(256, 0, 256, 512); ctx.clip();
      const ms = Math.max(256 / memImg.width, 512 / memImg.height);
      ctx.drawImage(memImg, 256 + (256 - memImg.width * ms) / 2, (512 - memImg.height * ms) / 2, memImg.width * ms, memImg.height * ms);
      ctx.restore();

      ctx.fillStyle = colors[0] + '0D';
      ctx.fillRect(0, 0, 512, 512);

      cuts.push(canvas.toDataURL('image/png'));
