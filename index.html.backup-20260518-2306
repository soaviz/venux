// ── Admin Feed 연동: localStorage의 venux_admin_feed 데이터로 MEMBER_POSTS 업데이트 ──
(function mergeAdminFeed() {
  try {
    const adminFeed = JSON.parse(localStorage.getItem('venux_admin_feed') || '{}');
    Object.keys(adminFeed).forEach(key => {
      if (!MEMBER_POSTS[key]) return;
      const adminPosts = adminFeed[key];
      if (!Array.isArray(adminPosts) || !adminPosts.length) return;
      // 관리자가 저장한 게시물을 앞에 병합 (imageData → image 필드로 매핑)
      const merged = adminPosts.map(p => ({
        id: p.id,
        image: p.imageData || p.image || null,  // base64 또는 파일명
        caption: p.caption || '',
        date: p.date || '',
        likes: p.likes || 0,
        filter: p.filter || 'none',
      }));
      // 기존 MEMBER_POSTS에서 같은 id 제거 후 관리자 데이터로 앞쪽 교체
      const existingIds = new Set(merged.map(p => p.id));
      const remaining = MEMBER_POSTS[key].filter(p => !existingIds.has(p.id));
      MEMBER_POSTS[key] = [...merged, ...remaining];
    });
  } catch(e) { /* 연동 실패 시 기본값 유지 */ }
})();

