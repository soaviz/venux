function submitPostComment(postId, key) {
  const input = document.getElementById('postCommentInput-'+postId);
  const text = (input?.value||'').trim();
  if (!text) return;
  const db = getOrCreateDB();
  const myName = db.user.nickname || '나';
  const comments = getPostComments();
  if (!comments[postId]) comments[postId] = [];
  const now = new Date();
  const commentId = postId + '_' + Date.now();
  comments[postId].push({ id:commentId, name:myName, text, date:`${now.getMonth()+1}.${now.getDate()}`, replies:[] });
  savePostComments(comments);
  input.value = '';
  const list = document.getElementById('postCommentsList-'+postId);
  if (list) list.innerHTML = buildCommentListHtml(comments[postId]);

  // 멤버 대댓글 트리거 (70% 확률, 1.5~3.5초 딜레이)
  if (Math.random() < 0.70) {
    const m = memberData[key];
    const replyText = getRandMemberComment(key);
    if (!replyText || !m) return;
    const delay = 1500 + Math.random() * 2000;

    // "답글 작성 중..." 표시
    setTimeout(() => {
      const block = document.getElementById('comment-block-'+commentId);
      if (block) {
        const typing = document.createElement('div');
        typing.className = 'post-comment-replying';
        typing.id = 'typing-'+commentId;
        typing.textContent = m.name + ' 이(가) 답글 작성 중...';
        block.appendChild(typing);
      }
    }, 600);

    setTimeout(() => {
      const typing = document.getElementById('typing-'+commentId);
      if (typing) typing.remove();

      const allComments = getPostComments();
      const target = (allComments[postId]||[]).find(c => c.id === commentId);
      if (!target) return;
      if (!target.replies) target.replies = [];
      target.replies.push({
        name: m.name,
        text: replyText,
        date: `${now.getMonth()+1}.${now.getDate()}`,
        color: m.badgeColor
      });
      savePostComments(allComments);
      if (list) list.innerHTML = buildCommentListHtml(allComments[postId]);
    }, delay);
  }
}

