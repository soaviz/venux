function getAvailableQAIndices(memberKey) {
  if (!chipUsedIndices[memberKey]) chipUsedIndices[memberKey] = new Set();
  const all = CHAT_QA_SETS[memberKey] || [];
  const used = chipUsedIndices[memberKey];
  const available = [];
  for (let i = 0; i < all.length; i++) {
    if (!used.has(i)) available.push(i);
  }
  // If all used, reset (keep going)
  if (available.length === 0) {
    used.clear();
    return all.map((_, i) => i);
  }
  return available;
}

function pickRandomIndices(available, count, exclude) {
  const pool = available.filter(i => !exclude.includes(i));
  const picked = [];
  const copy = [...pool];
  for (let i = 0; i < Math.min(count, copy.length); i++) {
    const r = Math.floor(Math.random() * copy.length);
    picked.push(copy[r]);
    copy.splice(r, 1);
  }
  return picked;
}

