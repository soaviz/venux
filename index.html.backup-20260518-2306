// ============================================================
// SCREENS
// ============================================================
let _navStack = ['screen-landing'];
function showScreen(id, _push) {
  document.querySelectorAll('.screen').forEach(s => { s.classList.remove('active'); });
  document.getElementById(id).classList.add('active');
  document.getElementById(id).scrollTop = 0;
  if (_push !== false && _navStack[_navStack.length-1] !== id) _navStack.push(id);
  _syncBackButtons();
}
function goBack() {
  if (_navStack.length > 1) _navStack.pop();
  const prev = _navStack[_navStack.length-1];
  showScreen(prev, false);
  document.querySelectorAll('.tab-bar-item').forEach(t =>
    t.classList.toggle('active', t.dataset.tab === prev)
  );
  if (prev === 'screen-landing') { resetFocusedMember(); }
}
function _syncBackButtons() {
  const onHome = _navStack[_navStack.length-1] === 'screen-landing';
  document.querySelectorAll('.back-btn').forEach(b =>
    b.style.visibility = onHome ? 'hidden' : 'visible'
  );
}
function goToLanding() {
  _navStack = ['screen-landing'];
  showScreen('screen-landing', false);
  document.getElementById('questionInput').value = '';
  updateCharCount();
  resetFocusedMember();
  _syncBackButtons();
}

// ============================================================
// MEMBER PHOTOS INJECTION
// ============================================================
function injectMemberPhotos() {
  document.querySelectorAll('.member-circle').forEach(circle => {
    const inner = circle.querySelector('.circle-inner');
    if (!inner) return;
    const key = memberOrder.find(k => memberData[k].letter === inner.textContent);
    if (!key) return;
    const img = new Image();
    img.onload = () => {
      circle.innerHTML = '';
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:50%';
      circle.appendChild(img);
      circle.classList.add('has-photo');
    };
    img.src = memberData[key].photo;
  });
}

// ============================================================
// CHAR COUNTER
// ============================================================
function updateCharCount() {
  const t = document.getElementById('questionInput');
  document.getElementById('charCounter').textContent = `${t.value.length}/500`;
}

// ============================================================
// EXAMPLE TABS + CARDS
// ============================================================
function getCurrentPool() {
  if (currentExampleCat === 'all') return QUESTION_POOL;
  return QUESTION_POOL.filter(q => q.cat === currentExampleCat || q.cat === 'all');
}

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; }
  return a;
}

function pick5Questions() {
  const pool = getCurrentPool();
  const shuffled = shuffle(pool);
  return shuffled.slice(0, 5);
}
// legacy alias
function pick3Questions() { return pick5Questions(); }

function renderCards(questions, animate = true) {
  const container = document.getElementById('examplesCards');
  container.innerHTML = questions.map((q, i) => `
    <div class="example-card${animate ? ' fade-in' : ''}" onclick="selectExampleQuestion('${q.text.replace(/'/g, "\\'")}')" style="${animate ? `transition-delay:${i * 80}ms` : ''}">
      <div class="example-dot" style="background:${q.color}"></div>
      <div class="example-text">${q.text}</div>
      <div class="example-arrow">→</div>
    </div>
  `).join('');
  if (animate) {
    requestAnimationFrame(() => {
      container.querySelectorAll('.example-card').forEach(c => c.classList.remove('fade-in'));
    });
  }
}

function rotateExamples(force = false) {
  if (isExamplePaused && !force) return;
  if (document.hidden && !force) return;
  const container = document.getElementById('examplesCards');
  container.querySelectorAll('.example-card').forEach((c, i) => {
    c.style.transitionDelay = `${i * 60}ms`;
    c.classList.add('fade-out');
  });
  setTimeout(() => {
    renderCards(pick5Questions(), true);
  }, 300);
}

function selectExampleTab(btn) {
  document.querySelectorAll('.example-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  currentExampleCat = btn.dataset.cat;
  rotateExamples(true);
  resetExampleInterval();
}

function selectExampleQuestion(text) {
  const textarea = document.getElementById('questionInput');
  textarea.value = '';
  let i = 0;
  const type = () => {
    if (i < text.length) {
      textarea.value += text[i];
      updateCharCount();
      i++;
      setTimeout(type, 30);
    } else {
      setTimeout(() => handleAsk(), 900);
    }
  };
  type();
}

function refreshExamples() {
  const btn = document.getElementById('refreshBtn');
  btn.classList.add('spinning');
  setTimeout(() => btn.classList.remove('spinning'), 400);
  rotateExamples(true);
  resetExampleInterval();
}

function resetExampleInterval() {
  clearInterval(exampleInterval);
  exampleInterval = setInterval(() => rotateExamples(), 3000);
}

function pauseExamples() { isExamplePaused = true; }
function resumeExamples() { isExamplePaused = false; }

function initExamples() {
  renderCards(pick3Questions(), false);
  resetExampleInterval();
}

