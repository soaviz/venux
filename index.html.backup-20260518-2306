function sendQuickReplyQA(qaIdx) {
  if (!currentChatMember) return;
  const qa = CHAT_QA_SETS[currentChatMember];
  if (!qa || !qa[qaIdx]) return;
  
  // Mark as used
  if (!chipUsedIndices[currentChatMember]) chipUsedIndices[currentChatMember] = new Set();
  chipUsedIndices[currentChatMember].add(qaIdx);
  
  // Store the matched answer for fallback
  window._pendingQAAnswer = qa[qaIdx].a;
  
  // Remove the clicked chip with animation, replace with new one
  const clickedBtn = document.querySelector(`[data-qa-idx="${qaIdx}"]`);
  if (clickedBtn) clickedBtn.classList.add('fade-out');
  
  // Send the question
  document.getElementById('chatInput').value = qa[qaIdx].q;
  onChatInput();
  sendChatMessage();
  
  // After send, refresh chips with the used one replaced
  setTimeout(() => {
    if (currentChatMember) {
      const colors = CHAT_COLORS[currentChatMember];
      const available = getAvailableQAIndices(currentChatMember);
      // Keep non-clicked indices, replace clicked one
      const newIndices = [];
      for (const idx of chipCurrentIndices) {
        if (idx === qaIdx) {
          const replacement = pickRandomIndices(available, 1, chipCurrentIndices.concat(newIndices));
          if (replacement.length > 0) newIndices.push(replacement[0]);
        } else if (!chipUsedIndices[currentChatMember].has(idx)) {
          newIndices.push(idx);
        } else {
          const replacement = pickRandomIndices(available, 1, chipCurrentIndices.concat(newIndices));
          if (replacement.length > 0) newIndices.push(replacement[0]);
        }
      }
      chipCurrentIndices = newIndices;
      renderChipButtons(currentChatMember, colors);
    }
  }, 800);
}

async function sendChatMessage() {
  const ta = document.getElementById('chatInput');
  const text = ta.value.trim();
  if (!text || !currentChatMember) return;

  const memberKey = currentChatMember;
  const now = new Date().toISOString();
  const history = loadChatHistory(memberKey);
  const m = memberData[memberKey];
  const colors = CHAT_COLORS[memberKey];

  // Add user message
  history.push({ role:'user', text, timestamp:now });
  saveChatHistory(memberKey, history);
  sbSaveMessage(memberKey, 'user', text); // Supabase 서버 저장 (동의 시)

  // Render user bubble
  const body = document.getElementById('chatBody');
  body.innerHTML += `<div class="chat-msg-row user">
    <span class="chat-msg-time">${formatChatTime(now)}</span>
    <div class="chat-bubble user-bubble" style="background:${colors.userBubble}">${text}</div>
  </div>`;
  body.scrollTop = body.scrollHeight;

  // Clear input
  ta.value = '';
  ta.style.height = 'auto';
  document.getElementById('chatSendBtn').disabled = true;

  // Hide chips
  document.getElementById('chatChips').style.display = 'none';

  // Show typing indicator
  body.innerHTML += `<div class="chat-typing" id="chatTyping">
    <div class="chat-msg-avatar"><img src="${m.photo}" alt="${m.letter}"></div>
    <div class="chat-typing-dots"><div class="chat-typing-dot"></div><div class="chat-typing-dot"></div><div class="chat-typing-dot"></div></div>
  </div>`;
  body.scrollTop = body.scrollHeight;

  // Add affinity
  const db = getOrCreateDB();
  addAffinity(db, memberKey, 5, 'chat');
  useAction(db);

  // Generate response
  let reply = '';
  const apiKey = localStorage.getItem('venux_openai_key');

  if (apiKey) {
    try {
      // Build context: Supabase 기억(서버) 우선, 없으면 localStorage fallback
      let context = [];
      if (hasResearchConsent()) {
        const sbCtx = await buildSupabaseContext(memberKey);
        context = sbCtx.length > 0 ? sbCtx : history.slice(-20).map(msg => ({
          role: msg.role === 'user' ? 'user' : 'assistant',
          content: msg.text
        }));
      } else {
        context = history.slice(-10).map(msg => ({
          role: msg.role === 'user' ? 'user' : 'assistant',
          content: msg.text
        }));
      }

      const res = await fetch('https://api.openai.com/v1/chat/completions', {
        method:'POST',
        headers:{ 'Content-Type':'application/json', 'Authorization':`Bearer ${apiKey}` },
        body: JSON.stringify({
          model: localStorage.getItem('venux_ai_model') || 'gpt-4o',
          messages: [{ role:'system', content: CHAT_SYSTEM_PROMPTS[memberKey] }, ...context],
          max_tokens: 300,
          temperature: 0.85
        })
      });
      if (!res.ok) throw new Error(`API ${res.status}`);
      const data = await res.json();
      reply = data.choices?.[0]?.message?.content?.trim() || '';
    } catch(e) {
      console.warn('Chat API error:', e);
      reply = '';
    }
  }

  // Fallback: use matched QA answer if available, else responseBank
  if (!reply) {
    if (window._pendingQAAnswer) {
      reply = window._pendingQAAnswer;
      window._pendingQAAnswer = null;
    } else {
      // Try to find matching QA
      const qaSet = CHAT_QA_SETS[memberKey] || [];
      const matched = qaSet.find(item => item.q === text);
      if (matched) {
        reply = matched.a;
      } else {
        const bank = responseBank[memberKey];
        const mock = bank[Math.floor(Math.random() * bank.length)];
        reply = mock.answer;
      }
    }
  }

  // Remove typing indicator
  const typingEl = document.getElementById('chatTyping');
  if (typingEl) typingEl.remove();

  // Parse signature line
  let mainReply = reply;
  let sigLine = '';
  if (reply.includes('///SIG///')) {
    const parts = reply.split('///SIG///');
    mainReply = parts[0].trim();
    sigLine = parts[1]?.trim() || '';
  }

  // Slight delay for natural feel
  await new Promise(r => setTimeout(r, 400 + Math.random() * 600));

  const replyTime = new Date().toISOString();

  // Add main reply
  history.push({ role:'member', text:mainReply, timestamp:replyTime });

  body.innerHTML += `<div class="chat-msg-row member">
    <div class="chat-msg-avatar"><img src="${m.photo}" alt="${m.letter}"></div>
    <div class="chat-bubble member-bubble">${mainReply}</div>
    ${sigLine ? '' : `<span class="chat-msg-time">${formatChatTime(replyTime)}</span>`}
  </div>`;

  // Add signature bubble if present
  if (sigLine) {
    history.push({ role:'member', text:sigLine, timestamp:replyTime, isSig:true });
    body.innerHTML += `<div class="chat-msg-row member">
      <div class="chat-msg-avatar" style="visibility:hidden"><img src="${m.photo}" alt=""></div>
      <div class="chat-bubble member-bubble sig-bubble" style="color:${m.badgeColor}">${sigLine}</div>
      <span class="chat-msg-time">${formatChatTime(replyTime)}</span>
    </div>`;
  }

  saveChatHistory(memberKey, history);
  sbSaveMessage(memberKey, 'assistant', mainReply); // Supabase 서버 저장 (동의 시)
  body.scrollTop = body.scrollHeight;

  // Collect message
  if (db.collections.messages.length < 300) {
    db.collections.messages.push({ member:memberKey, text:mainReply, date:replyTime });
    saveDB(db);
  }

  // Show chips again after reply (refresh + restart rotation)
  document.getElementById('chatChips').style.display = 'flex';
  if (currentChatMember) {
    const colors = CHAT_COLORS[currentChatMember];
    const available = getAvailableQAIndices(currentChatMember);
    chipCurrentIndices = pickRandomIndices(available, CHIP_DISPLAY_COUNT, []);
    renderChipButtons(currentChatMember, colors);
    startChipRotation(currentChatMember, colors);
  }
  updateDailyStatusBar(db);
  renderAffinityDashboard(db);
}

