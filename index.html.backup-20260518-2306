// Rotating message card state
let messageRotationInterval = null;
let currentRotationMember = null;

function updateTodayMemberCard(db) {
  if (!db.user.nickname) return;
  const card = document.getElementById('todayMemberCard');
  card.style.display = 'flex';
  // Show first message immediately, then start rotation
  rotateToNextMessage();
  startMessageRotation();
}

function rotateToNextMessage() {
  const members = memberOrder;
  // Pick random member (avoid repeat)
  const available = members.filter(k => k !== currentRotationMember);
  const key = available[Math.floor(Math.random() * available.length)];
  currentRotationMember = key;

  const m = memberData[key];
  const msgs = VENUX_MESSAGES[key];
  const msg = msgs[Math.floor(Math.random() * msgs.length)];
  const db = getOrCreateDB();
  const rel = db.member_relationships[key];

  const card = document.getElementById('todayMemberCard');

  // Fade out
  card.style.opacity = '0.3';
  card.style.transform = 'translateY(4px)';

  setTimeout(() => {
    // Update content
    card.style.setProperty('--today-gradient', m.gradient);
    card.style.setProperty('--today-glow', m.glow);
    card.dataset.member = key;
    document.getElementById('todayPortrait').innerHTML = `<img src="${m.photo}" alt="${m.name}">`;
    document.getElementById('todayMemberName').textContent = `${m.name} ${m.element}`;
    document.getElementById('todayMemberName').style.color = m.badgeColor;
    document.getElementById('todayGreeting').textContent = `"${msg}"`;
    document.getElementById('todayMood').textContent = MOOD_LABELS[rel.current_mood] || '😶 평소';

    // Fade in
    card.style.opacity = '1';
    card.style.transform = 'translateY(0)';
  }, 250);
}

function startMessageRotation() {
  stopMessageRotation();
  const isMobile = window.innerWidth <= 768;
  const interval = isMobile ? 3500 : 3000;
  messageRotationInterval = setInterval(rotateToNextMessage, interval);
}

function stopMessageRotation() {
  if (messageRotationInterval) {
    clearInterval(messageRotationInterval);
    messageRotationInterval = null;
  }
}

// Pause rotation when page hidden, resume when visible
document.addEventListener('visibilitychange', () => {
  if (document.hidden) {
    stopMessageRotation();
  } else if (document.getElementById('todayMemberCard')?.style.display === 'flex') {
    startMessageRotation();
  }
});

function onTodayMemberClick() {
  const key = document.getElementById('todayMemberCard')?.dataset?.member;
  if (key) {
    stopMessageRotation();
    openChatRoom(key);
  }
}

