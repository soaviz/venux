function togglePostLike(postId, key) {
  const likes = getPostLikes();
  const posts = MEMBER_POSTS[key] || [];
  const post = posts.find(p => p.id === postId);
  if (!post) return;
  likes[postId] = !likes[postId];
  savePostLikes(likes);
  const liked = likes[postId];
  const btn = document.getElementById('postLikeBtn-'+postId);
  const cnt = document.getElementById('postLikeCount-'+postId);
  if (btn) btn.textContent = liked ? '❤️' : '🤍';
  if (cnt) cnt.textContent = (post.likes + (liked?1:0)).toLocaleString();
