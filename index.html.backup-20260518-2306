    user: { id:crypto.randomUUID?.() || Date.now().toString(36), nickname:'', mbti:'', joined_date:'', current_streak:0, total_visits:0, last_visit_date:'', settings:{ language:'ko', notifications:true, sound:false } },
    member_relationships: Object.fromEntries(memberOrder.map(k => [k, { level:1, affection_points:0, conversation_count:0, photo_count:0, first_meeting_date:'', last_interaction:'', current_mood:'neutral', unlocked_stories:[], unlocked_costumes:['default'], unlocked_messages:[] }])),
    daily_log: {},
    collections: { photos:[], messages:[], achievements:[], stories_completed:[] },
    game_state: { total_xp:0, current_chapter:1, available_actions_today:3, last_reset:'' }
  };
}

function loadDB() {
  try { const raw = localStorage.getItem(DB_KEY); return raw ? JSON.parse(raw) : null; }
  catch { return null; }
}

function saveDB(db) {
  localStorage.setItem(DB_KEY, JSON.stringify(db));
}

function getOrCreateDB() {
  let db = loadDB();
  if (!db) { db = getDefaultDB(); saveDB(db); }
  // Ensure all member keys exist (migration safety)
  memberOrder.forEach(k => {
    if (!db.member_relationships[k]) {
      db.member_relationships[k] = { level:1, affection_points:0, conversation_count:0, photo_count:0, first_meeting_date:'', last_interaction:'', current_mood:'neutral', unlocked_stories:[], unlocked_costumes:['default'], unlocked_messages:[] };
    }
  });
  if (!db.game_state) db.game_state = { total_xp:0, current_chapter:1, available_actions_today:3, last_reset:'' };
  if (!db.collections.achievements) db.collections.achievements = [];
  // Auto-set joined_date for legacy users who don't have it
  if (db.user.nickname && !db.user.joined_date) {
    // Try to find earliest interaction date from chat history or relationships
    let earliest = todayStr();
    memberOrder.forEach(k => {
      const hist = loadChatHistory(k);
      if (hist.length > 0) {
        const first = hist[0].timestamp?.slice(0,10);
        if (first && first < earliest) earliest = first;
      }
      const fmd = db.member_relationships[k]?.first_meeting_date;
      if (fmd && fmd < earliest) earliest = fmd;
    });
    db.user.joined_date = earliest;
    saveDB(db);
  }
  return db;
}

// D-day calculator
function getDday(joinedDate) {
  if (!joinedDate) return 0;
  const joined = new Date(joinedDate + 'T00:00:00');
  const now = new Date();
  const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  const diff = Math.floor((today - joined) / (1000 * 60 * 60 * 24));
  return diff + 1; // D+1 on first day
}

// D-day milestone checker
const DDAY_MILESTONES = [
  { day:10,  stars:'⭐',         label:'D+10 첫 기념일' },
  { day:30,  stars:'⭐⭐',       label:'D+30 한 달' },
  { day:50,  stars:'⭐⭐',       label:'D+50' },
  { day:100, stars:'⭐⭐⭐',     label:'D+100' },
  { day:200, stars:'⭐⭐⭐',     label:'D+200' },
  { day:365, stars:'⭐⭐⭐⭐⭐', label:'D+365 1주년' }
];

function getNextMilestone(dday) {
  for (const ms of DDAY_MILESTONES) {
    if (dday < ms.day) return ms;
  }
  return null;
}

function getAffinityLevel(points) {
  for (let i = AFFINITY_LEVELS.length - 1; i >= 0; i--) {
    if (points >= AFFINITY_LEVELS[i].points) return AFFINITY_LEVELS[i].level;
  }
  return 1;
}

function getAffinityInfo(points) {
  const lv = getAffinityLevel(points);
  const current = AFFINITY_LEVELS[lv - 1];
  const next = AFFINITY_LEVELS[lv] || current;
  const progress = lv >= 5 ? 1 : (points - current.points) / (next.points - current.points);
  return { level:lv, name:current.name, progress:Math.min(1, Math.max(0, progress)), nextPoints:next.points };
}

function todayStr() { return new Date().toISOString().slice(0,10); }
function getTimeOfDay() {
  const h = new Date().getHours();
  if (h >= 5 && h < 12) return 'morning';
  if (h >= 12 && h < 17) return 'afternoon';
  if (h >= 17 && h < 21) return 'evening';
  return 'night';
}

