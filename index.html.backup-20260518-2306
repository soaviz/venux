let affinitySortMode = 'affinity'; // 'affinity' | 'recent' | 'level'

function toggleAffinitySort() {
  const modes = ['affinity','recent','level'];
  const labels = { affinity:'친밀도순', recent:'최근순', level:'레벨순' };
  const idx = modes.indexOf(affinitySortMode);
  affinitySortMode = modes[(idx + 1) % modes.length];
  document.getElementById('affinitySortBtn').textContent = labels[affinitySortMode];
  renderAffinityPage();
}

function renderAffinityPage() {
  const db = getOrCreateDB();

  // Summary card
  let totalPts = 0;
  let totalLv = 0;
  memberOrder.forEach(key => {
    const rel = db.member_relationships[key];
    totalPts += rel.affection_points;
    totalLv += getAffinityLevel(rel.affection_points);
  });
  const avgLv = (totalLv / 5).toFixed(1);
  const nextAvgLv = Math.ceil(parseFloat(avgLv));
  const ptsForNext = nextAvgLv * 5; // rough estimate

  const dday = db.user.joined_date ? getDday(db.user.joined_date) : 0;
  const nextMs = getNextMilestone(dday);
  const milestoneStr = nextMs ? `다음 기념일: ${nextMs.label} (${nextMs.day - dday}일 후)` : 'D+365+ 🎊';

  document.getElementById('affinitySummaryCard').innerHTML = `
    <div class="affinity-summary-left">
      <div class="affinity-summary-total">${totalPts.toLocaleString()}</div>
      <div class="affinity-summary-label">총 친밀도 포인트</div>
    </div>
    <div class="affinity-summary-right">
      <div class="affinity-summary-avg">${dday > 0 ? `D+${dday}` : `평균 LV ${avgLv}`}</div>
      <div class="affinity-summary-next">${dday > 0 ? milestoneStr : `전체 ${totalLv}/25 레벨`}</div>
    </div>
  `;

  // Sort members
  let sorted = [...memberOrder];
  if (affinitySortMode === 'affinity') {
    sorted.sort((a,b) => db.member_relationships[b].affection_points - db.member_relationships[a].affection_points);
  } else if (affinitySortMode === 'recent') {
    sorted.sort((a,b) => {
      const histA = loadChatHistory(a);
      const histB = loadChatHistory(b);
      const lastA = histA.length ? new Date(histA[histA.length-1].timestamp).getTime() : 0;
      const lastB = histB.length ? new Date(histB[histB.length-1].timestamp).getTime() : 0;
      return lastB - lastA;
    });
  } else if (affinitySortMode === 'level') {
    sorted.sort((a,b) => getAffinityLevel(db.member_relationships[b].affection_points) - getAffinityLevel(db.member_relationships[a].affection_points));
  }

  // Render ranking cards
  const rankingHtml = sorted.map((key, idx) => {
    const m = memberData[key];
    const rel = db.member_relationships[key];
    const pts = rel.affection_points;
    const info = getAffinityInfo(pts);
    const lv = info.level;
    const lvData = AFFINITY_LEVELS[lv - 1];
    const nextData = AFFINITY_LEVELS[lv] || lvData;
    const ptsInLv = pts - lvData.points;
    const ptsNeeded = nextData.points - lvData.points;
    const progress = ptsNeeded > 0 ? Math.min(ptsInLv / ptsNeeded, 1) : 1;
    const ptsToNext = nextData.points - pts;
    const isUnmet = pts === 0 && rel.conversation_count === 0;
    const rank = idx + 1;
    const rankClass = rank <= 3 ? `rank-${rank}` : 'rank-other';
    const delay = idx * 80;

    if (isUnmet) {
      return `<div class="affinity-rank-card" style="animation-delay:${delay}ms" onclick="openChatRoom('${key}')">
        <div class="affinity-rank-badge ${rankClass}">${rank}</div>
        <div class="affinity-rank-portrait unmet"><img src="${m.photo}" alt="${m.letter}"></div>
        <div class="affinity-rank-info">
          <div class="affinity-rank-name-row">
            <span class="affinity-rank-kr">${m.name}</span>
            <span class="affinity-rank-code" style="color:${m.badgeColor}">${key}</span>
          </div>
          <div class="affinity-rank-unmet">아직 만나지 못함</div>
          <button class="affinity-rank-cta" style="background:${m.badgeColor}" onclick="event.stopPropagation();openChatRoom('${key}')">💬 첫 대화하기</button>
        </div>
        <div class="affinity-rank-arrow">→</div>
      </div>`;
    }

    return `<div class="affinity-rank-card" style="animation-delay:${delay}ms" onclick="openChatRoom('${key}')">
      <div class="affinity-rank-badge ${rankClass}">${rank}</div>
      <div class="affinity-rank-portrait" style="border:2px solid ${m.badgeColor}"><img src="${m.photo}" alt="${m.letter}"></div>
      <div class="affinity-rank-info">
        <div class="affinity-rank-name-row">
          <span class="affinity-rank-kr">${m.name}</span>
          <span class="affinity-rank-code" style="color:${m.badgeColor}">${key}</span>
        </div>
        <div class="affinity-rank-lv" style="background:${m.badgeColor}">LV ${lv} ${lvData.name}</div>
        <div class="affinity-rank-bar-wrap">
          <div class="affinity-rank-bar-fill" style="background:linear-gradient(90deg,${m.badgeColor}88,${m.badgeColor});width:${progress*100}%"></div>
        </div>
        <div class="affinity-rank-pts">${pts} / ${nextData.points} pt ${lv < 5 ? `(다음 LV까지 ${ptsToNext}pt)` : '✨ MAX'}</div>
      </div>
      <div class="affinity-rank-arrow">→</div>
    </div>`;
  }).join('');

  document.getElementById('affinityRanking').innerHTML = rankingHtml;

  // Animate bars after render
  requestAnimationFrame(() => {
    document.querySelectorAll('.affinity-rank-bar-fill').forEach(bar => {
      const w = bar.style.width;
      bar.style.width = '0';
      requestAnimationFrame(() => { bar.style.width = w; });
    });
  });

  // Achievement mini pill
  const unlocked = ACHIEVEMENTS_DEF.filter(a => a.check(db)).length;
  document.getElementById('affinityAchievementMini').innerHTML = `
    <div class="affinity-achievement-pill" onclick="openAchievementsModal()">
      🏆 달성 도전과제 ${unlocked}/${ACHIEVEMENTS_DEF.length}
    </div>
  `;
}

