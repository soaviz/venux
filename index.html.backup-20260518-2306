function loadNotifications() {
  try { return JSON.parse(localStorage.getItem('venux_notifications')) || []; }
  catch { return []; }
}
function saveNotifications(notifs) {
  // Prune: max 30, remove 7+ day old
  const cutoff = Date.now() - 7*24*60*60*1000;
  notifs = notifs.filter(n => new Date(n.timestamp).getTime() > cutoff).slice(-30);
  localStorage.setItem('venux_notifications', JSON.stringify(notifs));
}

function addNotification(memberKey, message) {
  const notifs = loadNotifications();
  const id = 'notif_' + Date.now() + '_' + Math.random().toString(36).slice(2,6);
  notifs.push({ id, member:memberKey, message, timestamp:new Date().toISOString(), read:false });
  saveNotifications(notifs);

  // Also add to chat history as member message
  const history = loadChatHistory(memberKey);
  history.push({ role:'member', text:message, timestamp:new Date().toISOString() });
  saveChatHistory(memberKey, history);

  updateNotifBadge();
  // Shake bell
  const bell = document.getElementById('notifBell');
  bell.classList.remove('shake');
  void bell.offsetWidth;
  bell.classList.add('shake');
  // Pulse badge
  const badge = document.getElementById('notifBadge');
  badge.classList.remove('pulse');
  void badge.offsetWidth;
  badge.classList.add('pulse');
}

function updateNotifBadge() {
  const notifs = loadNotifications();
  const unread = notifs.filter(n => !n.read).length;
  const badge = document.getElementById('notifBadge');
  if (unread > 0) {
    badge.style.display = 'flex';
    badge.textContent = unread > 9 ? '9+' : unread;
  } else {
    badge.style.display = 'none';
  }
}

function formatNotifTime(ts) {
  const now = new Date();
  const t = new Date(ts);
  const diffMs = now - t;
  const diffMin = Math.floor(diffMs / 60000);
  const diffHr = Math.floor(diffMs / 3600000);
  if (diffMin < 1) return '방금';
  if (diffMin < 60) return `${diffMin}분 전`;
  if (diffHr < 24) return `${diffHr}시간 전`;
  if (diffHr < 48) return '어제';
  return `${t.getMonth()+1}월 ${t.getDate()}일`;
}

function openNotifCenter() {
  renderNotifList();
  document.getElementById('notifOverlay').classList.add('show');
}

function closeNotifCenter() {
  document.getElementById('notifOverlay').classList.remove('show');
}

function renderNotifList() {
  const notifs = loadNotifications().sort((a,b) => new Date(b.timestamp) - new Date(a.timestamp));
  const list = document.getElementById('notifList');
  const empty = document.getElementById('notifEmpty');

  if (notifs.length === 0) {
    list.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';

  list.innerHTML = notifs.map(n => {
    const m = memberData[n.member];
    if (!m) return '';
    return `<div class="notif-item ${n.read?'read':'unread'}" onclick="openNotif('${n.id}','${n.member}')">
      <div class="notif-portrait" style="border:2px solid ${m.badgeColor}"><img src="${m.photo}" alt="${m.letter}"></div>
      <div class="notif-info">
        <div class="notif-info-top">
          <span class="notif-member-name" style="color:${m.badgeColor}">${m.name}</span>
          <span class="notif-time">${formatNotifTime(n.timestamp)}</span>
        </div>
        <div class="notif-message">${n.message}</div>
      </div>
      ${n.read ? '' : `<div class="notif-unread-dot" style="background:${m.badgeColor}"></div>`}
    </div>`;
  }).join('');
}

function openNotif(notifId, memberKey) {
  // Mark as read
  const notifs = loadNotifications();
  const n = notifs.find(x => x.id === notifId);
  if (n) n.read = true;
  saveNotifications(notifs);
  updateNotifBadge();
  closeNotifCenter();
  openChatRoom(memberKey);
}

function markAllNotifsRead() {
  const notifs = loadNotifications();
  notifs.forEach(n => n.read = true);
  saveNotifications(notifs);
  updateNotifBadge();
  renderNotifList();
}

