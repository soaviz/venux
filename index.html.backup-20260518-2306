function getAdminUsers() {
  try { return JSON.parse(localStorage.getItem('venux_admin_users')) || []; }
  catch { return []; }
}
function saveAdminUsers(users) { localStorage.setItem('venux_admin_users', JSON.stringify(users)); }

function getAdminSession() {
  try { return JSON.parse(localStorage.getItem('venux_admin_session')) || null; }
  catch { return null; }
}
function saveAdminSession(session) {
  if (session) localStorage.setItem('venux_admin_session', JSON.stringify(session));
  else localStorage.removeItem('venux_admin_session');
}

function hashPassword(pw) {
  // Simple hash for localStorage auth (NOT production-grade)
  let hash = 0;
  for (let i = 0; i < pw.length; i++) {
    const char = pw.charCodeAt(i);
    hash = ((hash << 5) - hash) + char;
    hash |= 0;
  }
  return 'vx_' + Math.abs(hash).toString(36) + '_' + pw.length;
}

const ADMIN_MAX_SLOTS = 3;

function adminRegister() {
  const id = document.getElementById('adminRegId').value.trim();
  const pw = document.getElementById('adminRegPw').value;
  const pw2 = document.getElementById('adminRegPw2').value;
  const email = document.getElementById('adminRegEmail').value.trim();
  const birth = document.getElementById('adminRegBirth').value;
  const errEl = document.getElementById('adminRegError');

  const users = getAdminUsers();

  // 3명 상한 체크
  if (users.length >= ADMIN_MAX_SLOTS) {
    errEl.textContent = '관리자 모집이 완료되었습니다 (최대 3명)';
    return;
  }

  if (!id || id.length < 4) { errEl.textContent = '아이디는 4자 이상 입력하세요'; return; }
  if (!pw || pw.length < 6) { errEl.textContent = '비밀번호는 6자 이상 입력하세요'; return; }
  if (pw !== pw2) { errEl.textContent = '비밀번호가 일치하지 않습니다'; return; }
  if (!email || !email.includes('@')) { errEl.textContent = '올바른 이메일을 입력하세요'; return; }
  if (!birth) { errEl.textContent = '생년월일을 선택하세요'; return; }

  if (users.find(u => u.id === id)) { errEl.textContent = '이미 존재하는 아이디입니다'; return; }
  if (users.find(u => u.email === email)) { errEl.textContent = '이미 등록된 이메일입니다'; return; }

  const roleMap = { 0: 'super_admin', 1: 'admin', 2: 'admin' };
  const user = {
    id,
    password: hashPassword(pw),
    email,
    birth,
    role: roleMap[users.length] || 'admin',
    slot: users.length + 1,   // 1·2·3번 슬롯
    created: new Date().toISOString(),
    lastLogin: null
  };
  users.push(user);
  saveAdminUsers(users);

  const session = { id: user.id, role: user.role, loginAt: new Date().toISOString() };
  saveAdminSession(session);
  updateAdminUI();
  closeAdmin();

  const slotLabel = ['👑 최고 관리자 (1번)', '🔐 관리자 (2번)', '🔐 관리자 (3번)'][user.slot - 1] || '관리자';
  const remaining = ADMIN_MAX_SLOTS - users.length;
  showToast(`${slotLabel} 등록 완료! 남은 슬롯: ${remaining}개`);
}

function adminLogin() {
  const id = document.getElementById('adminLoginId').value.trim();
  const pw = document.getElementById('adminLoginPw').value;
  const errEl = document.getElementById('adminLoginError');

  if (!id || !pw) { errEl.textContent = '아이디와 비밀번호를 입력하세요'; return; }

  const users = getAdminUsers();
  const user = users.find(u => u.id === id);
  if (!user) { errEl.textContent = '존재하지 않는 아이디입니다'; return; }
  if (user.password !== hashPassword(pw)) { errEl.textContent = '비밀번호가 틀렸습니다'; return; }

  // Update last login
  user.lastLogin = new Date().toISOString();
  saveAdminUsers(users);

  const session = { id: user.id, role: user.role, loginAt: new Date().toISOString() };
  saveAdminSession(session);
  updateAdminUI();
  closeAdmin();
  showToast(`🔐 ${user.id} 로그인 성공`);
  setTimeout(() => { window.location.href = 'admin.html'; }, 400);
}

function adminLogout() {
  saveAdminSession(null);
  updateAdminUI();
  showToast('🔓 로그아웃 완료');
}

function openAdmin() {
  document.getElementById('adminOverlay').classList.add('show');
  document.getElementById('adminLoginError').textContent = '';
  document.getElementById('adminRegError').textContent = '';
  switchAdminTab('login');
}
function closeAdmin() {
  document.getElementById('adminOverlay').classList.remove('show');
}

function switchAdminTab(tab) {
  const tabs = document.querySelectorAll('.admin-tab');
  const users = getAdminUsers();
  const isFull = users.length >= ADMIN_MAX_SLOTS;

  tabs[0].classList.toggle('active', tab === 'login');
  tabs[1].classList.toggle('active', tab === 'register');
  document.getElementById('adminLoginForm').style.display = tab === 'login' ? 'block' : 'none';
  document.getElementById('adminLoginError').textContent = '';
  document.getElementById('adminRegError').textContent = '';

  const regForm = document.getElementById('adminRegForm');
  if (tab === 'register') {
    if (isFull) {
      // 슬롯 꽉 참 — 폼 숨기고 안내만 표시
      regForm.style.display = 'block';
      regForm.innerHTML = `
        <div style="text-align:center;padding:20px 0">
          <div style="font-size:28px;margin-bottom:12px">🔒</div>
          <div style="font-size:14px;font-weight:600;color:#333;margin-bottom:8px">관리자 모집 완료</div>
          <div style="font-size:12px;color:#999;line-height:1.7">초기 관리자 3명이 모두 등록되었습니다.<br>기존 계정으로 로그인하세요.</div>
          <div style="margin-top:16px;display:flex;flex-direction:column;gap:6px">
            ${users.map((u,i)=>`<div style="font-size:11px;color:#bbb;padding:6px 10px;background:#f8f8f8;border-radius:6px">
              ${'👑🔐🔐'[i]} 슬롯 ${i+1}: ${u.id} (${u.created?.split('T')[0]||'-'})
            </div>`).join('')}
          </div>
          <button class="admin-btn admin-btn-primary" onclick="switchAdminTab('login')" style="margin-top:16px">로그인으로 이동</button>
        </div>`;
    } else {
      // 슬롯 남음 — 폼 표시 + 남은 슬롯 안내
      regForm.style.display = 'block';
      // 폼이 교체되지 않았으면 원본 유지
      if (!regForm.querySelector('#adminRegId')) {
        regForm.innerHTML = `
          <div style="margin-bottom:12px;padding:8px 12px;background:rgba(107,91,214,0.08);border:1px solid rgba(107,91,214,0.2);border-radius:8px;font-size:12px;color:#6B5BD6;text-align:center">
            관리자 슬롯 ${users.length + 1} / ${ADMIN_MAX_SLOTS} &nbsp;·&nbsp; 남은 자리: ${ADMIN_MAX_SLOTS - users.length}개
          </div>
          <input class="admin-input" id="adminRegId" type="text" placeholder="아이디 (4자 이상)" autocomplete="off">
          <input class="admin-input" id="adminRegPw" type="password" placeholder="비밀번호 (6자 이상)" autocomplete="new-password">
          <input class="admin-input" id="adminRegPw2" type="password" placeholder="비밀번호 확인" autocomplete="new-password">
          <input class="admin-input" id="adminRegEmail" type="email" placeholder="이메일">
          <input class="admin-input" id="adminRegBirth" type="date" style="color:#bbb" onfocus="this.style.color='#333'">
          <div class="admin-error" id="adminRegError"></div>
          <button class="admin-btn admin-btn-primary" onclick="adminRegister()">슬롯 ${users.length + 1}번 등록</button>`;
      } else {
        // 이미 폼 있으면 슬롯 안내만 업데이트
        const slotBadge = regForm.querySelector('.slot-badge');
        if (!slotBadge) {
          const badge = document.createElement('div');
          badge.className = 'slot-badge';
          badge.style.cssText = 'margin-bottom:12px;padding:8px 12px;background:rgba(107,91,214,0.08);border:1px solid rgba(107,91,214,0.2);border-radius:8px;font-size:12px;color:#6B5BD6;text-align:center';
          badge.textContent = `관리자 슬롯 ${users.length + 1} / ${ADMIN_MAX_SLOTS} · 남은 자리: ${ADMIN_MAX_SLOTS - users.length}개`;
          regForm.prepend(badge);
        }
      }
    }
  } else {
    regForm.style.display = 'none';
  }
}

