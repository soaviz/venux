function addAffinity(db, memberKey, points, action) {
  const rel = db.member_relationships[memberKey];
  rel.affection_points += points;
  rel.last_interaction = new Date().toISOString();
  if (action === 'chat') rel.conversation_count++;
  if (action === 'photo') rel.photo_count++;
  if (!rel.first_meeting_date) rel.first_meeting_date = todayStr();
  db.game_state.total_xp += points;
  saveDB(db);
  checkAchievements(db);
  return db;
}

function useAction(db) {
  if (db.game_state.available_actions_today > 0) {
    db.game_state.available_actions_today--;
    saveDB(db);
    updateDailyStatusBar(db);
  }
}

