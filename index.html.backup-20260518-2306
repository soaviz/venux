function buildCommentListHtml(postComments) {
  if (postComments.length === 0)
    return `<div style="font-size:12px;color:#ccc;text-align:center;padding:10px 0">첫 번째 댓글을 남겨보세요 💜</div>`;
  return postComments.map(c => {
    const replyHtml = (c.replies||[]).map(r =>
      `<div class="post-comment-reply" style="border-left:2px solid ${r.color||'#6B5BD6'}">
        <strong style="color:${r.color||'#6B5BD6'}">${r.name}</strong><span>${r.text}</span><span class="post-comment-reply-time">${r.date}</span>
      </div>`
    ).join('');
    return `<div class="post-comment-item" id="comment-block-${c.id||''}">
      <strong>${c.name||'나'}</strong><span>${c.text}</span><span class="post-comment-time">${c.date}</span>
      ${replyHtml}
    </div>`;
  }).join('');
}

