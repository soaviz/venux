function pickTodayMember(db) {
  const dow = new Date().getDay();
  const boosted = DAY_MEMBER_BOOST[dow] || null;
  // Weight by affinity + day boost
  const weights = memberOrder.map(k => {
    let w = 1 + db.member_relationships[k].affection_points * 0.01;
    if (k === boosted) w *= 2;
    if (dow === 0 || dow === 6) { // Weekend: boost highest affinity
      w *= (1 + db.member_relationships[k].affection_points * 0.02);
    }
    return w;
  });
  const total = weights.reduce((a,b) => a+b, 0);
  let r = Math.random() * total;
  for (let i = 0; i < memberOrder.length; i++) {
    r -= weights[i];
    if (r <= 0) return memberOrder[i];
  }
  return memberOrder[0];
}

function processAttendance(db) {
  const today = todayStr();
  if (db.daily_log[today]?.attended) return { isNew:false, db };

  // Check streak
  const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0,10);
  if (db.daily_log[yesterday]?.attended) {
    db.user.current_streak++;
  } else {
    db.user.current_streak = 1;
  }
  db.user.total_visits++;
  db.user.last_visit_date = today;

  const todayMember = pickTodayMember(db);
  db.daily_log[today] = { attended:true, member_met:todayMember, actions:[] };

  // Give attendance bonus
  addAffinity(db, todayMember, 5, 'attend');

  // Night owl check
  const h = new Date().getHours();
  if (h >= 2 && h < 5 && !db.collections.achievements.includes('night_owl_trigger')) {
    db.collections.achievements.push('night_owl_trigger');
  }

  saveDB(db);
  return { isNew:true, todayMember, db };
}

