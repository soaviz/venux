let _adminPendingPhotoDataURL = null;

function handleAdminPhotoSelect(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    const img = new Image();
    img.onload = function() {
      // Canvas로 400×400 리사이즈
      const canvas = document.createElement('canvas');
      canvas.width = 400;
      canvas.height = 400;
      const ctx = canvas.getContext('2d');
      // 가운데 크롭 (contain → cover)
      const size = Math.min(img.width, img.height);
      const sx = (img.width - size) / 2;
      const sy = (img.height - size) / 2;
      ctx.drawImage(img, sx, sy, size, size, 0, 0, 400, 400);
      _adminPendingPhotoDataURL = canvas.toDataURL('image/jpeg', 0.92);
      // 미리보기
      const preview = document.getElementById('adminPhotoPreview');
      const previewImg = document.getElementById('adminPhotoPreviewImg');
      const saveBtn = document.getElementById('adminPhotoSaveBtn');
      previewImg.src = _adminPendingPhotoDataURL;
      preview.style.display = 'block';
      saveBtn.style.display = 'block';
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function saveAdminPhoto() {
  if (!_adminPendingPhotoDataURL) return;
  const memberKey = document.getElementById('adminPhotoMemberSelect').value;
  localStorage.setItem('venux_admin_photo_' + memberKey, _adminPendingPhotoDataURL);
  // memberData 즉시 반영
  if (memberData[memberKey]) memberData[memberKey].photo = _adminPendingPhotoDataURL;
  // 열려있는 프로필 이미지 즉시 갱신
  document.querySelectorAll('img[alt="' + memberData[memberKey].name + '"]').forEach(el => {
