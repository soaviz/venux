    <div class="admin-card-sub">VenuX Daily 관리자 인증</div>
    <div class="admin-tabs">
      <div class="admin-tab active" onclick="switchAdminTab('login')">로그인</div>
      <div class="admin-tab" onclick="switchAdminTab('register')">회원가입</div>
