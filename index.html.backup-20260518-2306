// Check preset DB (exact or fuzzy match)
function findPresetResponse(question) {
  const q = question.trim();
  // Exact match
  if (presetResponses[q]) return presetResponses[q];
  // Fuzzy: strip punctuation + check
  const normalize = s => s.replace(/[?？.。!！,，\s]/g, '');
  const qn = normalize(q);
  for (const [key, val] of Object.entries(presetResponses)) {
    if (normalize(key) === qn) return val;
  }
  // Partial match: if question contains a preset key or vice versa
  for (const [key, val] of Object.entries(presetResponses)) {
    if (qn.includes(normalize(key)) || normalize(key).includes(qn)) return val;
  }
  return null;
}

async function handleAsk() {
  const q = document.getElementById('questionInput').value.trim();
  if (!q) { showToast('질문을 입력해주세요 ✨'); return; }
  currentQuestion = q;
  memberResponses = {};

  const apiKey = localStorage.getItem('venux_openai_key');
  showScreen('screen-loading');
  buildLoadingPills();

  // Check preset DB first
  const preset = findPresetResponse(q);

  if (preset) {
    // Use preset responses (no API needed)
    for (let i = 0; i < memberOrder.length; i++) {
      await new Promise(r => setTimeout(r, 300 + Math.random() * 400));
      const key = memberOrder[i];
      const p = preset[key];
      memberResponses[key] = { answer: p.answer, micDrop: p.micDrop, raw: `${p.answer} / ${p.micDrop}` };
      markPillDone(i);
    }
    verdictMember = focusedMember || pickVerdict(q);
  } else if (!apiKey) {
    // Demo mode with random mock responses
    showToast('데모 모드: API Key를 설정하면 AI가 직접 답해요');
    for (let i = 0; i < memberOrder.length; i++) {
      await new Promise(r => setTimeout(r, 400 + Math.random() * 300));
      const key = memberOrder[i];
      const bank = responseBank[key];
      const mock = bank[Math.floor(Math.random() * bank.length)];
      memberResponses[key] = { answer: mock.answer, micDrop: mock.micDrop, raw: `${mock.answer} / ${mock.micDrop}` };
      markPillDone(i);
    }
    verdictMember = focusedMember || pickVerdict(q);
  } else {
    // Real API calls (non-preset questions only)
    const promises = memberOrder.map((key, i) =>
      getMemberResponse(key, q, apiKey)
        .then(raw => {
          const parsed = parseResponse(raw);
          memberResponses[key] = { ...parsed, raw };
          markPillDone(i);
        })
        .catch(err => {
          const bank = responseBank[key];
          const mock = bank[Math.floor(Math.random() * bank.length)];
          memberResponses[key] = { answer: mock.answer, micDrop: mock.micDrop, raw: `${mock.answer} / ${mock.micDrop}` };
          markPillDone(i);
          if (err.status === 401) { showToast('API Key를 확인해주세요'); openSettings(); }
        })
    );
    await Promise.all(promises);

    // Get verdict from API
    try {
      const rawTexts = {};
      memberOrder.forEach(k => { rawTexts[k] = memberResponses[k]?.raw || ''; });
      const v = await getVerdictFromApi(q, rawTexts, apiKey);
      if (v && v.member && memberData[v.member]) {
        verdictMember = v.member;
      } else {
        verdictMember = pickVerdict(q);
      }
    } catch {
      verdictMember = pickVerdict(q);
    }
  }

  await new Promise(r => setTimeout(r, 500));
  buildResults();
  showScreen('screen-results');
  saveReadingAuto();
  resetFocusedMember();
}

