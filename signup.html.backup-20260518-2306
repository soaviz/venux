    function consumeOAuthRedirect() {
      const params = new URLSearchParams((location.hash || '').replace(/^#/, ''));
      const idToken = params.get('id_token');
      const state = params.get('state');
      const error = params.get('error');
      if (error) {
        showToast(`소셜 로그인 오류: ${params.get('error_description') || error}`, 'error');
        history.replaceState(null, '', location.pathname + location.search + (MODE === 'login' ? '#login' : ''));
        return true;
      }
      if (!idToken || !state) return false;
      let pending = null;
      try { pending = JSON.parse(localStorage.getItem(OAUTH_PENDING_KEY) || 'null'); } catch {}
      if (!pending || pending.state !== state) {
        showToast('OAuth state가 일치하지 않습니다. 다시 시도해주세요.', 'error');
        history.replaceState(null, '', location.pathname + location.search);
        return true;
      }
      localStorage.removeItem(OAUTH_PENDING_KEY);
      const claims = decodeJwt(idToken);
      if (!claims?.sub) {
        showToast(`${providerName(pending.provider)} 토큰 디코드 실패`, 'error');
        return true;
      }
      const email = claims.email || claims.preferred_username || claims.upn || '';
      const existing = getProfile();
      if (existing?.email && email && existing.email !== email) {
        if (!confirm(`기존 계정(${existing.email})과 다른 ${providerName(pending.provider)} 계정(${email})으로 진입하려 합니다.\n\n[확인] 새 계정으로 교체  [취소] 중단`)) {
          return true;
        }
      }
      history.replaceState(null, '', location.pathname + location.search + (pending.mode === 'login' ? '#login' : ''));
      askPassphraseForProvider(pending.provider, claims);
      return true;
    }

    function handleGoogleCredential(resp) {
      if (!resp?.credential) { showToast('Google 응답이 비어있습니다', 'error'); return; }
      const claims = decodeJwt(resp.credential);
      if (!claims?.email) { showToast('Google 토큰 디코드 실패', 'error'); return; }
      // 가입 / 로그인 분기
      const existing = getProfile();
      if (existing?.email && existing.email !== claims.email) {
        if (!confirm(`기존 계정(${existing.email})과 다른 Google 계정(${claims.email})으로 진입하려 합니다.\n\n[확인] 새 계정으로 교체  [취소] 중단`)) return;
      }
      // 패스프레이즈 모달 (Vault setup)
      askPassphraseForProvider('google', claims);
    }

    function askPassphraseForProvider(provider, claims) {
      const label = providerName(provider);
      const email = claims.email || claims.preferred_username || claims.upn || '';
      const displayName = claims.name || email || `${label} 사용자`;
      const existingProfile = getProfile();
      const root = document.createElement('div');
      root.className = 'modal-bd';
      root.innerHTML = `
        <div class="modal-card">
          <h3>👋 ${escapeAttr(displayName)}</h3>
          <p>${label} 계정으로 확인되었습니다. 기존 보관소가 있으면 패스프레이즈로 잠금을 해제하고, 처음이면 새 보관소를 만듭니다. 저장된 API 키는 덮어쓰지 않습니다.</p>
          <div class="field">
            <label>마스터 패스프레이즈 (6자+)</label>
            <input type="password" id="gpass" placeholder="6자 이상" />
            <div class="field-error" id="gerr"></div>
          </div>
          <div class="modal-actions">
            <button class="form-cancel" type="button" id="gcancel">취소</button>
            <button class="submit" type="button" id="gok"><span class="spinner"></span><span>계속</span></button>
          </div>
        </div>
      `;
      document.body.appendChild(root);
      const close = () => { try { document.body.removeChild(root); } catch {} };
      root.addEventListener('click', e => { if (e.target === root) close(); });
      root.querySelector('#gcancel').onclick = close;
      const inp = root.querySelector('#gpass');
      const err = root.querySelector('#gerr');
      const ok = root.querySelector('#gok');
      inp.focus();
      inp.addEventListener('keydown', e => { if (e.key === 'Enter') ok.click(); });
      ok.addEventListener('click', async () => {
        const pass = inp.value;
        if (pass.length < 6) { err.textContent = '6자 이상'; err.classList.add('show'); return; }
        ok.classList.add('loading');
        const vaultState = await verifyVault(pass);
        let okV = false;
        if (vaultState === true) {
          okV = true;
        } else if (vaultState === false) {
          err.textContent = '기존 Vault 패스프레이즈가 일치하지 않습니다';
          err.classList.add('show');
          ok.classList.remove('loading');
          return;
        } else {
          okV = await setupVault(pass);
        }
        if (!okV) { err.textContent = 'Vault 설정 실패'; err.classList.add('show'); ok.classList.remove('loading'); return; }
        finishAuth({
          ...existingProfile,
          name: claims.name || existingProfile?.name || (email ? email.split('@')[0] : `${label} 사용자`),
          email: email || existingProfile?.email || '',
          picture: claims.picture || existingProfile?.picture || null,
          photoUrl: claims.picture || existingProfile?.photoUrl || null,
          authProvider: provider,
          providerSub: claims.sub,
          createdAt: existingProfile?.createdAt || Date.now(),
          lastLogin: Date.now(),
          updatedAt: Date.now(),
          version: 'v3',
        }, `✓ ${label} 로그인 — ${displayName}`);
      });
    }

    function askPassphraseForGoogle(claims) {
      askPassphraseForProvider('google', claims);
    }

    consumeOAuthRedirect();

