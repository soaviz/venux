  </main>

  <div class="toast" id="toast"></div>

  <script>
    /* ══════════════════════════════════════════════════════
       Supabase 클라이언트 초기화 (anon key — 공개 안전)
       ══════════════════════════════════════════════════════ */
    const _SUPA_URL = 'https://yfzhvuyrdabpzowprupa.supabase.co';
    const _SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlmemh2dXlyZGFicHpvd3BydXBhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzczMTk3NTcsImV4cCI6MjA5Mjg5NTc1N30.b2rFHl5axZfy4v1_onrJeMQp7c6nEyUIvOI8ScT9doM';
    const _sb = (() => {
      try { return supabase.createClient(_SUPA_URL, _SUPA_KEY); }
      catch (e) { console.warn('Supabase init failed', e); return null; }
    })();

    /* Supabase OAuth 콜백 처리 — 페이지 로드 시 세션 감지 */
    if (_sb) {
      _sb.auth.onAuthStateChange(async (event, session) => {
        if (event === 'SIGNED_IN' && session?.user) {
          const user = session.user;
          const meta = user.user_metadata || {};
          const rawProvider = user.app_metadata?.provider || 'google';
          const providerLabel = { google: 'Google', azure: 'Microsoft', github: 'GitHub', email: '이메일' }[rawProvider] || rawProvider;
          const profile = {
            name:         meta.full_name || meta.name || (user.email || '').split('@')[0] || 'User',
            email:        user.email || '',
            picture:      meta.avatar_url || meta.picture || null,
            photoUrl:     meta.avatar_url || meta.picture || null,
            authProvider: rawProvider,
            providerSub:  user.id,
            supabaseId:   user.id,
            plan:         'pro',   // 베타 기간: 로그인 = Pro 전체 액세스
            createdAt:    Date.now(),
            lastLogin:    Date.now(),
            updatedAt:    Date.now(),
            version:      'v3',
          };
          // 이미 처리됐으면 중복 실행 방지
          if (window._sbAuthHandled) return;
          window._sbAuthHandled = true;
          finishAuth(profile, `✓ ${providerLabel} 로그인 — ${profile.name}`);
        }
      });
    }

    /* Supabase Google OAuth 시작 */
    async function startSupabaseGoogleLogin() {
      if (!_sb) { showToast?.('Supabase 초기화 오류', 'error'); return; }
      const redirectTo = (() => {
        const u = new URL(location.href);
        u.hash = ''; u.search = '';
        return u.href;
      })();
      const { error } = await _sb.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo, queryParams: { prompt: 'select_account' } },
      });
      if (error) showToast?.('Google 로그인 오류: ' + error.message, 'error');
    }

    /* Supabase Microsoft (Azure) OAuth 시작 */
    async function startMicrosoftLogin() {
      if (!_sb) { showToast?.('Supabase 초기화 오류', 'error'); return; }
      const redirectTo = (() => {
        const u = new URL(location.href);
        u.hash = ''; u.search = '';
        return u.href;
      })();
      const { error } = await _sb.auth.signInWithOAuth({
        provider: 'azure',
        options: {
          redirectTo,
          scopes: 'email profile openid',
        },
      });
      if (error) showToast?.('Microsoft 로그인 오류: ' + error.message, 'error');
    }

    /* ───────────── Helpers ───────────── */
    const PROFILE_KEY = 'soaviz.profile.v1';
    const GOOGLE_CID_KEY = 'soaviz.google.client_id';
    const APPLE_CID_KEY = 'soaviz.apple.client_id';
    const OAUTH_REDIRECT_KEY = 'soaviz.oauth.redirect_uri';
    const OAUTH_PENDING_KEY = 'soaviz.oauth.pending';
    // Google OAuth Client ID 기본값 (공개 식별자, secret 아님 — 임베드 안전)
    const DEFAULT_GOOGLE_CLIENT_ID = '886041789747-en0i68q11ojgtg7hpujasm5idni9emsq.apps.googleusercontent.com';

    /* 부모 창(opener)에 인증 성공 알림 + 자체 닫기
       - file:// 같은 크로스오리진에서도 동작하도록 BroadcastChannel 동시 사용
       - 팝업 컨텍스트는 window.name === 'soaviz_auth'로 robust 판정 */
    function notifyParentAuthSuccess() {
      const isPopup = (window.name === 'soaviz_auth');
      let parentReachable = false;
      // 1) postMessage (same-origin or relaxed CORS)
      try {
        if (window.opener && !window.opener.closed) {
          window.opener.postMessage('soaviz:auth-success', '*');
          parentReachable = true;
        }
      } catch {}
      // 2) BroadcastChannel — file://·cross-origin 안전한 백업 신호
      try {
        const bc = new BroadcastChannel('soaviz-auth');
        bc.postMessage('soaviz:auth-success');
        bc.close();
      } catch {}
      // 3) localStorage 핑 — 부모의 storage 이벤트로 감지 가능
      try {
        localStorage.setItem('soaviz.auth.popup.success', String(Date.now()));
        localStorage.removeItem('soaviz.auth.popup.success');
      } catch {}
      if (isPopup || parentReachable) {
        // 팝업이면 무조건 닫기 (returnTo redirect 차단)
        setTimeout(() => { try { window.close(); } catch {} }, 400);
        return true;
      }
      return false;
    }
    let _gsiInited = false;
    let _gsiRetries = 0;

    const $ = sel => document.querySelector(sel);
    const $$ = sel => [...document.querySelectorAll(sel)];

    function getProfile() { try { return JSON.parse(localStorage.getItem(PROFILE_KEY) || 'null'); } catch { return null; } }
    function saveProfile(p) { try { localStorage.setItem(PROFILE_KEY, JSON.stringify(p)); } catch {} }
    function getLocal(key, fallback = '') { try { return localStorage.getItem(key) || fallback; } catch { return fallback; } }
    function setLocal(key, value) { try { value ? localStorage.setItem(key, value) : localStorage.removeItem(key); } catch {} }
    function isLocalDevHost() {
      const h = location.hostname;
      return location.protocol === 'file:' || h === 'localhost' || h === '127.0.0.1' || h === '::1';
    }
    function getStudioUrl() {
      const u = new URL(location.href);
      u.hash = '';
      u.search = '';
      if (isLocalDevHost()) {
        // 로컬 개발: signup.html → soaviz-studio.html (같은 디렉토리)
        u.pathname = u.pathname.replace(/\/?(?:signup|login)(?:\.html)?$/i, '/soaviz-studio.html');
        if (!/soaviz-studio\.html$/i.test(u.pathname)) u.pathname = '/soaviz-studio.html';
      } else {
        // Vercel/프로덕션: studio는 루트 / 에 있음 (vercel.json rewrite: / → soaviz-studio.html)
        u.pathname = '/';
      }
      return u.href;
    }
    function finishAuth(profile, message) {
      const betaProfile = {
        ...profile,
        betaAccess: 'app',
        betaAccessGrantedAt: profile?.betaAccessGrantedAt || Date.now(),
      };
      saveProfile(betaProfile);
      try {
        const wasBetaFullAccess = localStorage.getItem('soaviz.beta.fullAccess.v1') === '1';
        if (wasBetaFullAccess && localStorage.getItem('soaviz.user.plan') === 'pro') {
          localStorage.setItem('soaviz.user.plan', 'free');
        }
        if (!localStorage.getItem('soaviz.user.plan')) localStorage.setItem('soaviz.user.plan', 'free');
        localStorage.setItem('soaviz.beta.appAccess.v1', '1');
        localStorage.removeItem('soaviz.beta.fullAccess.v1');
      } catch {}
      try { sessionStorage.removeItem('soaviz.signup.bypass'); } catch {}
      showToast(message || '✓ 로그인 완료', 'ok');
      if (notifyParentAuthSuccess()) return;
      // mobile에서 로그인 후 다시 mobile로 복귀
      let _returnTo = getStudioUrl();
      try {
        const _saved = localStorage.getItem('soaviz.auth.returnTo.v1');
        if (_saved) { localStorage.removeItem('soaviz.auth.returnTo.v1'); _returnTo = _saved; }
      } catch {}
      setTimeout(() => { location.href = _returnTo; }, 700);
    }
    function escapeAttr(s) {
      return String(s || '').replace(/[&<>"']/g, ch => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));
    }
    function getRedirectUri() {
      const saved = getLocal(OAUTH_REDIRECT_KEY).trim();
      if (saved) return saved;
      const u = new URL(location.href);
      u.hash = '';
      return u.href;
    }
    function makeOAuthState(provider) {
      const bytes = crypto.getRandomValues(new Uint8Array(16));
      const state = btoa(String.fromCharCode(...bytes)).replace(/[+/=]/g, '');
      const nonce = `${Date.now()}-${state}`;
      localStorage.setItem(OAUTH_PENDING_KEY, JSON.stringify({ provider, state, nonce, mode: MODE, createdAt: Date.now() }));
      return { state, nonce };
    }
    function getOAuthClientId(provider) {
      if (provider === 'apple') return getLocal(APPLE_CID_KEY).trim();
      return '';
    }
    function refreshOAuthBadges() {
      [
        ['apple', '#apple-oauth-badge'],
      ].forEach(([provider, selector]) => {
        const badge = $(selector);
        if (!badge) return;
        const configured = !!getOAuthClientId(provider);
        const localFallback = !configured && isLocalDevHost();
        badge.textContent = configured ? '활성' : localFallback ? '로컬 테스트' : '설정 필요';
        badge.className = configured ? 'badge ok' : 'badge';
        if (localFallback) {
          badge.style.background = 'rgba(251,191,36,0.16)';
          badge.style.color = 'var(--warn)';
        } else {
          badge.style.background = '';
          badge.style.color = '';
        }
      });
    }

    const toastEl = $('#toast');
    let toastTimer = null;
    function showToast(msg, type = '') {
      toastEl.innerHTML = msg;
      toastEl.className = 'toast show ' + type;
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toastEl.classList.remove('show'), 3500);
    }

    /* ───────────── Mode (signup / login) ───────────── */
    let MODE = 'signup';
    function setMode(m) {
      MODE = m;
      const isLogin = m === 'login';
      const nextHash = isLogin ? '#login' : '';
      if (location.hash !== nextHash) {
        history.replaceState(null, '', location.pathname + location.search + nextHash);
      }
      $$('.auth-tab').forEach(t => t.classList.toggle('active', t.dataset.mode === m));
      $('#ah-title').textContent = isLogin ? '돌아오신 걸 환영합니다' : '시작하기';
      $('#ah-sub').textContent = isLogin ? '저장된 패스프레이즈로 잠금을 해제합니다' : '계정을 만들거나 이메일·소셜 로그인으로 진입하세요.';
      $('#email-btn-label').textContent = isLogin ? '이메일로 로그인' : '이메일로 시작하기';
      $('#submit-label').textContent = isLogin ? '로그인' : '계정 만들기';
      $('#pass-label').innerHTML = isLogin ? '마스터 패스프레이즈' : '마스터 패스프레이즈 <span style="color:#fb923c">필수</span>';
      $$('[data-signup-only]').forEach(el => el.style.display = isLogin ? 'none' : '');
      $('#su-pass').value = '';
      $('#su-pass2').value = '';
      $$('.field-error').forEach(e => e.classList.remove('show'));
      // GSI 버튼 텍스트 동기화 (재렌더)
      renderGoogleButton();
    }
    $$('.auth-tab').forEach(t => t.addEventListener('click', () => setMode(t.dataset.mode)));

    /* 이미 프로필 있으면 로그인 모드 자동 */
    (function bootMode() {
      const p = getProfile();
      // /login URL (Vercel rewrite) 또는 #login hash이면 로그인 탭
      const isLoginPath = /\/login(?:\.html)?$/i.test(location.pathname);
      if (isLoginPath || location.hash === '#login') {
        setMode('login');
        if (p?.email) $('#su-email').value = p.email || '';
      } else if (p && p.name) {
        setMode('login');
        $('#su-email').value = p.email || '';
      }
    })();

    /* ───────────── Email button → form ───────────── */
    const emailBtn = $('#auth-email-btn');
    const emailForm = $('#email-form');
    const socialEl = $('#auth-social');
    emailBtn.addEventListener('click', () => {
      emailForm.classList.add('show');
      emailBtn.style.display = 'none';
      socialEl.style.display = 'none';
      $('.auth-divider').style.display = 'none';
      const first = MODE === 'login' ? '#su-email' : '#su-name';
      const f = $(first);
      if (f && !f.value) f.focus();
    });
    $('#auth-back').addEventListener('click', () => {
      emailForm.classList.remove('show');
      emailBtn.style.display = '';
      socialEl.style.display = '';
      $('.auth-divider').style.display = '';
    });

    /* ───────────── Microsoft OAuth ───────────── */
    const msBtn = document.getElementById('ms-login-btn');
    if (msBtn) msBtn.addEventListener('click', () => startMicrosoftLogin());

    refreshOAuthBadges();

    $$('[data-oauth-provider]').forEach(b => {
      b.addEventListener('click', () => startOAuthLogin(b.dataset.oauthProvider));
    });

    function providerName(provider) {
      return provider === 'apple' ? 'Apple' : provider;
    }
    function defaultProviderClientLabel(provider) {
      return provider === 'apple' ? 'Apple Services ID' : 'Client ID';
    }
    function currentLocalServerUrl() {
      if (location.protocol === 'file:') return 'http://localhost:5501/signup.html';
      const u = new URL(location.href);
      u.protocol = 'http:';
      u.hostname = 'localhost';
      if (!u.port) u.port = '5501';
      u.hash = '';
      return u.href;
    }
    function openOAuthPopup(url, provider) {
      const w = 520, h = 720;
      const left = window.screenX + Math.max(0, (window.outerWidth - w) / 2);
      const top = window.screenY + Math.max(0, (window.outerHeight - h) / 2);
      const popup = window.open(url, `soaviz_${provider}_oauth`, `width=${w},height=${h},left=${left},top=${top},menubar=no,toolbar=no,location=yes,status=no`);
      if (!popup) location.href = url;
    }
    function startOAuthLogin(provider) {
      const clientId = getOAuthClientId(provider);
      if (location.protocol === 'file:') {
        if (!clientId) {
          startLocalProviderLogin(provider);
        } else {
          openProviderConfigModal(provider, 'file');
        }
        return;
      }
      if (!clientId) {
        if (isLocalDevHost()) {
          startLocalProviderLogin(provider);
        } else {
          openProviderConfigModal(provider, 'missing');
        }
        return;
      }
      if (!/^https?:\/\//.test(getRedirectUri())) {
        openProviderConfigModal(provider, 'redirect');
        return;
      }
      const redirectUri = getRedirectUri();
      const { state, nonce } = makeOAuthState(provider);
      let authUrl = '';
      if (provider === 'apple') {
        authUrl =
          'https://appleid.apple.com/auth/authorize' +
          `?client_id=${encodeURIComponent(clientId)}` +
          `&redirect_uri=${encodeURIComponent(redirectUri)}` +
          '&response_type=id_token' +
          '&response_mode=fragment' +
          '&scope=name%20email' +
          `&state=${encodeURIComponent(state)}` +
          `&nonce=${encodeURIComponent(nonce)}`;
      }
      if (!authUrl) return;
      openOAuthPopup(authUrl, provider);
    }
    function startLocalProviderLogin(provider) {
      const name = providerName(provider);
      const existing = getProfile() || {};
      const email = existing.email || `${provider}@local.soaviz`;
      showToast(`${name} 로컬 테스트 로그인으로 진행합니다`, 'warn');
      askPassphraseForProvider(provider, {
        sub: `local-${provider}`,
        email,
        preferred_username: email,
