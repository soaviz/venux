<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>soaviz studio — AI 영화 제작 OS</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" />
  <link rel="preconnect" href="https://accounts.google.com" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css" />
  <link rel="manifest" href="manifest.json" />
  <meta name="theme-color" content="#A78BFA" />
  <meta name="description" content="상위 1% 크리에이터를 위한 AI 영화 제작 OS — Pipeline · Compare · Bible · Cinema. 한 줄 아이디어를 시리즈까지." />
  <script src="https://cdn.jsdelivr.net/npm/dexie@4.0.8/dist/dexie.min.js"></script>
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
  <style>
    :root {
      --bg: #08080C;
      --bg-1: #0F0F18;
      --bg-card: #14141F;
      --bg-elev: #1B1B2A;
      --text: #F4F4F8;
      --text-dim: #B8B8C8;
      --text-faint: #6B6B82;
      --border: #1F1F30;
      --border-strong: #2A2A40;
      --accent: #A78BFA;
      --accent-2: #6366F1;
      --accent-soft: rgba(167,139,250,0.10);
      --danger: #F87171;
      --success: #6EE7B7;
      --warn: #FBBF24;
    }
    * { box-sizing: border-box; }
    html, body {
      margin: 0; padding: 0;
      font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      letter-spacing: -0.01em;
    }
    body {
      background:
        radial-gradient(ellipse 1200px 800px at 12% 8%, rgba(167,139,250,0.12), transparent 60%),
        radial-gradient(ellipse 1000px 700px at 85% 90%, rgba(99,102,241,0.10), transparent 60%),
        radial-gradient(ellipse 700px 500px at 50% 50%, rgba(244,114,182,0.04), transparent 70%),
        var(--bg);
      min-height: 100vh;
      display: grid;
      place-items: center;
    }
    /* Subtle grid background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(167,139,250,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(167,139,250,0.04) 1px, transparent 1px);
      background-size: 64px 64px;
      pointer-events: none;
      z-index: 0;
      mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
    }

    .auth-wrap {
      position: relative;
      z-index: 1;
      width: 100%; max-width: 1180px;
      padding: 32px 20px;
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    @media (max-width: 920px) {
      .auth-wrap {
        grid-template-columns: 1fr;
        max-width: 540px;
        gap: 32px;
        padding: 32px 20px 60px;
      }
      .hero-section .hero-stats { display: none; }
    }
    @media (max-width: 920px) and (max-height: 820px) {
      body { place-items: start center; }
      .auth-wrap {
        gap: 18px;
        padding: 20px 20px 36px;
      }
      .brand-row { margin-bottom: 18px; }
      .hero-h1 {
        font-size: 34px;
        margin-bottom: 12px;
      }
      .hero-sub {
        font-size: 14px;
        line-height: 1.55;
        margin-bottom: 0;
      }
      .hero-feats,
      .hero-stats {
        display: none;
      }
      .auth-card {
        padding: 26px 22px;
      }
    }

    /* ═══ HERO (Left) ═══ */
    .hero-section { padding-right: 12px; }
    .brand-row {
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 28px;
    }
    .brand-logo {
      width: 96px; height: 26px;
      flex: 0 0 96px;
      border-radius: 0;
      background: transparent;
      display: grid; place-items: center;
      overflow: hidden;
      box-shadow: none;
      position: relative;
    }
    .brand-logo::after {
      content: none;
      display: none;
    }
    .brand-logo img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: contain;
      object-position: center;
    }
    .brand-name {
      display: none;
      font-size: 17px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .brand-tag {
      display: none;
      font-size: 11px;
      color: var(--text-faint);
      padding: 3px 8px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 999px;
      margin-left: auto;
      font-family: ui-monospace, monospace;
    }

    .hero-h1 {
      font-size: clamp(30px, 4.4vw, 46px);
      line-height: 1.05;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin: 0 0 14px;
    }
    .hero-h1 .grad {
      background: linear-gradient(135deg, var(--accent) 0%, #f472b6 60%, #fbbf24 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      font-weight: 800;
    }
    .hero-sub {
      font-size: 15px;
      line-height: 1.55;
      color: var(--text-dim);
      max-width: 480px;
      margin: 0;
    }

    .hero-feats {
      display: flex; flex-direction: column;
      gap: 14px;
      margin-bottom: 36px;
    }
    .hero-feat {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px 16px;
      background: rgba(20,20,31,0.5);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 12px;
      transition: all 0.2s;
    }
    .hero-feat:hover {
      border-color: rgba(167,139,250,0.30);
      background: var(--bg-card);
      transform: translateX(2px);
    }
    .hero-feat-icon {
      width: 36px; height: 36px;
      border-radius: 10px;
      background: var(--accent-soft);
      color: var(--accent);
      display: grid; place-items: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .hero-feat-body { flex: 1; min-width: 0; }
    .hero-feat-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 2px;
    }
    .hero-feat-desc {
      font-size: 12.5px;
      color: var(--text-faint);
      line-height: 1.5;
    }

    .hero-stats {
      display: flex; gap: 24px;
      padding: 16px 0 0;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .hero-stat-num {
      font-size: 20px;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .hero-stat-lbl {
      font-size: 11px;
      color: var(--text-faint);
      margin-top: 4px;
    }

    /* ═══ AUTH (Right) ═══ */
    .auth-card {
      background: rgba(12,12,20,0.92);
      backdrop-filter: blur(32px);
      border: 1px solid rgba(167,139,250,0.18);
      border-radius: 24px;
      padding: 36px 32px;
      box-shadow:
        0 40px 100px -20px rgba(0,0,0,0.75),
        0 0 0 1px rgba(167,139,250,0.06) inset,
        0 0 80px -30px rgba(167,139,250,0.12);
    }
    @media (max-width: 920px) { .auth-card { padding: 28px 24px; } }

    .auth-head {
      margin-bottom: 20px;
    }
    .auth-head-row {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 6px;
    }
    .auth-head-icon {
      width: 36px; height: 36px;
      border-radius: 10px;
      background: linear-gradient(135deg, rgba(167,139,250,0.2), rgba(99,102,241,0.15));
      border: 1px solid rgba(167,139,250,0.25);
      display: grid; place-items: center;
      font-size: 17px;
      flex-shrink: 0;
    }
    .auth-head h2 {
      font-size: 22px;
      margin: 0;
      letter-spacing: -0.025em;
      flex: 1;
    }
    .auth-beta-badge {
      font-size: 10px;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 20px;
      background: rgba(167,139,250,0.15);
      border: 1px solid rgba(167,139,250,0.3);
      color: var(--accent);
      letter-spacing: 0.04em;
      white-space: nowrap;
    }
    .auth-head p {
      font-size: 13px;
      color: var(--text-faint);
      margin: 0;
      line-height: 1.5;
    }

    /* Mode tabs */
    .auth-tabs {
      display: flex;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 4px;
      margin-bottom: 20px;
    }
    .auth-tab {
      flex: 1;
      padding: 9px 14px;
      background: transparent;
      border: 0;
      border-radius: 8px;
      color: var(--text-faint);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.18s;
      font-family: inherit;
    }
    .auth-tab.active {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: white;
      box-shadow: 0 4px 14px -4px rgba(167,139,250,0.50);
    }

    /* Social section label */
    .social-section-label {
      font-size: 10.5px;
      color: var(--text-faint);
      letter-spacing: 0.07em;
      text-transform: uppercase;
      font-weight: 700;
      text-align: center;
      margin-bottom: 10px;
    }

    /* Social buttons */
    .auth-social {
      display: flex; flex-direction: column; gap: 9px;
      margin-bottom: 14px;
    }
    .auth-btn {
      width: 100%;
      padding: 12px 18px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      color: var(--text);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      gap: 12px;
      transition: all 0.18s;
      font-family: inherit;
      position: relative;
    }
    .auth-btn:hover:not(:disabled) {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.18);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px -8px rgba(0,0,0,0.4);
    }
    .auth-btn:active:not(:disabled) {
      transform: scale(0.97);
      transition: transform 0.08s;
    }
    @media (hover: none) {
      /* 터치 디바이스: hover 상태 제거, active만 사용 */
      .auth-btn:hover:not(:disabled) {
        transform: none;
        box-shadow: none;
      }
      .auth-btn:active:not(:disabled) {
        transform: scale(0.96);
        background: rgba(255,255,255,0.07);
      }
      .auth-btn.google-btn:active:not(:disabled) {
        background: rgba(66,133,244,0.08);
      }
      .auth-btn.ms-btn:active:not(:disabled) {
        background: rgba(0,120,212,0.08);
      }
      /* 모바일에서 버튼 좀 더 크게 */
      .auth-btn { padding: 14px 18px; }
      .auth-tabs .auth-tab { padding: 11px 14px; }
    }
    .auth-btn.google-btn:hover:not(:disabled) {
      border-color: rgba(66,133,244,0.40);
      background: rgba(66,133,244,0.06);
    }
    .auth-btn.ms-btn:hover:not(:disabled) {
      border-color: rgba(0,120,212,0.40);
      background: rgba(0,120,212,0.06);
    }
    .auth-btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }
    .auth-btn-icon {
      width: 20px; height: 20px;
      flex-shrink: 0;
      display: grid; place-items: center;
    }
    .auth-btn .badge {
      position: absolute;
      right: 14px; top: 50%;
      transform: translateY(-50%);
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 4px;
      background: rgba(255,255,255,0.06);
      color: var(--text-faint);
      letter-spacing: 0.04em;
      font-weight: 600;
    }
    .auth-btn .badge.ok { background: rgba(110,231,183,0.18); color: #6ee7b7; }

    /* Google GSI button container */
    #gsi-btn-wrap {
      width: 100%;
      min-height: 44px;
      display: flex; justify-content: center;
    }
    #gsi-btn-wrap > div { width: 100% !important; }

    .auth-divider {
      display: flex; align-items: center;
      gap: 12px;
      margin: 16px 0;
      color: var(--text-faint);
      font-size: 10.5px;
      letter-spacing: 0.08em;
      font-weight: 500;
    }
    .auth-divider::before, .auth-divider::after {
      content: ''; flex: 1; height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
    }

    .auth-btn.email {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      border-color: transparent;
      color: white;
      font-weight: 700;
      box-shadow: 0 12px 32px -10px rgba(167,139,250,0.55);
      letter-spacing: -0.01em;
    }
    .auth-btn.email:hover:not(:disabled) {
      filter: brightness(1.08);
      transform: translateY(-1px);
      box-shadow: 0 16px 36px -10px rgba(167,139,250,0.65);
    }

    /* Email form */
    .email-form { display: none; }
    .email-form.show { display: block; animation: slideUp 0.25s ease; }
    @keyframes slideUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

    .field { margin-bottom: 12px; }
    .field label {
      display: block;
      font-size: 11px;
      color: var(--text-faint);
      letter-spacing: 0.04em;
      margin-bottom: 6px;
      font-weight: 500;
    }
    .field input {
      width: 100%;
      padding: 11px 14px;
      background: var(--bg-1);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text);
      font-size: 14px;
      font-family: inherit;
      transition: border-color 0.15s;
    }
    .field input:focus {
      outline: none;
      border-color: var(--accent);
      background: var(--bg-card);
    }
    .field-help {
      font-size: 11px;
      color: var(--text-faint);
      margin-top: 4px;
      line-height: 1.45;
    }
    .field-error {
      font-size: 11px;
      color: var(--danger);
      margin-top: 4px;
      display: none;
    }
    .field-error.show { display: block; }

    .pass-strength { display: flex; gap: 4px; margin-top: 6px; }
    .pass-strength-bar {
      flex: 1; height: 3px;
      background: var(--border);
      border-radius: 2px;
      transition: background 0.15s;
    }
    .pass-strength-bar.on { background: var(--accent); }
    .pass-strength-bar.warn { background: var(--warn); }
    .pass-strength-bar.weak { background: var(--danger); }

    .form-actions {
      display: flex; gap: 8px;
      margin-top: 16px;
    }
    .form-actions .submit { flex: 1; }
    .submit {
      padding: 13px 18px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: white;
      border: 0;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 10px 24px -8px rgba(167,139,250,0.50);
      transition: all 0.1s;
      font-family: inherit;
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    }
    .submit:hover { transform: translateY(-1px); }
    .submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .spinner {
      display: none;
      width: 14px; height: 14px;
      border: 2px solid rgba(255,255,255,0.30);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    .submit.loading .spinner { display: inline-block; }
    .form-cancel {
      padding: 13px 18px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-dim);
      border-radius: 10px;
      cursor: pointer;
      font-family: inherit;
      font-size: 13px;
    }
    .form-cancel:hover { background: var(--bg-card); color: var(--text); }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Footer */
    .auth-foot {
      margin-top: 22px;
      padding-top: 18px;
      border-top: 1px solid var(--border);
      font-size: 11.5px;
      color: var(--text-faint);
      line-height: 1.7;
      text-align: center;
    }
    .auth-foot a { color: var(--text-dim); text-decoration: underline; text-decoration-color: var(--text-faint); cursor: pointer; }
    .auth-foot a:hover { color: var(--text); }

    /* Modal */
    .modal-bd {
      position: fixed; inset: 0;
      background: rgba(8,8,12,0.85);
      backdrop-filter: blur(8px);
      z-index: 9999;
      display: grid; place-items: center;
      padding: 16px;
    }
    .modal-card {
      width: 100%; max-width: 440px;
      background: var(--bg-card);
      border: 1px solid var(--border-strong);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 30px 80px -10px rgba(0,0,0,0.6);
    }
    .modal-card h3 { margin: 0 0 8px; font-size: 17px; }
    .modal-card p { margin: 0 0 16px; font-size: 13.5px; color: var(--text-dim); line-height: 1.6; }
    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 14px; }
    .modal-actions button { font-family: inherit; }

    /* Toast */
    .toast {
      position: fixed; bottom: 24px; left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: var(--bg-elev);
      border: 1px solid var(--border-strong);
      padding: 12px 18px;
      border-radius: 12px;
      font-size: 13px;
      box-shadow: 0 16px 40px -10px rgba(0,0,0,0.5);
      opacity: 0; pointer-events: none;
      transition: 0.25s;
      z-index: 200;
      max-width: calc(100vw - 32px);
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.error { border-color: rgba(248,113,113,0.40); color: #fecaca; }
    .toast.ok { border-color: rgba(110,231,183,0.40); color: #a7f3d0; }
    .toast.warn { border-color: rgba(251,191,36,0.40); color: #fde68a; }

    /* Provider config link */
    .provider-cog {
      position: absolute;
      right: 8px; top: 50%;
      transform: translateY(-50%);
      width: 26px; height: 26px;
      border-radius: 50%;
      background: transparent;
      border: 0;
      color: var(--text-faint);
      font-size: 14px;
      cursor: pointer;
      display: grid; place-items: center;
    }
    .provider-cog:hover { background: var(--bg-elev); color: var(--text); }
  </style>
</head>
<body>
  <main class="auth-wrap">

    <!-- ═══ HERO (Left) ═══ -->
    <section class="hero-section">
      <div class="brand-row">
        <div class="brand-logo">
          <img
            src="assets/brand/soaviz-logo-signup.png"
            alt="soaviz"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="brand-name">soaviz studio</div>
        <span class="brand-tag">v3</span>
      </div>

      <h1 class="hero-h1">AI 영상 제작,<br/><span class="grad">바로 이어가세요.</span></h1>
      <p class="hero-sub">
        SOAVIZ Studio에 로그인하고 작업을 계속하세요.
      </p>
    </section>

    <!-- ═══ AUTH (Right) ═══ -->
    <section class="auth-card">
      <!-- Pro 플랜 CTA 배너 -->
      <div id="signup-pro-banner" style="
        background: linear-gradient(135deg, rgba(167,139,250,0.15), rgba(99,102,241,0.10));
        border: 1px solid rgba(167,139,250,0.3);
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
      ">
        <div style="font-size:13px; line-height:1.45;">
          <span style="color:var(--accent);font-weight:700;">✦ Pro</span>
          <span style="color:var(--text-dim);"> — 30 프로젝트 · 50GB · 4K 내보내기</span>
        </div>
        <a id="signup-pro-cta-btn" href="#" target="_blank" rel="noopener noreferrer" style="
          background: var(--accent);
          color: #08080C;
          font-size: 12px;
          font-weight: 700;
          padding: 6px 14px;
          border-radius: 6px;
          text-decoration: none;
          white-space: nowrap;
          flex-shrink: 0;
        ">₩19,000/월 →</a>
      </div>
      <script>
        (function() {
          // checkoutUrl이 설정되어 있으면 Pro CTA 링크 활성화, 없으면 배너 숨김
          var checkoutUrl = (window.__SOAVIZ_CONFIG__ || {}).checkoutUrl;
          var btn = document.getElementById('signup-pro-cta-btn');
          var banner = document.getElementById('signup-pro-banner');
          if (checkoutUrl && btn) {
            btn.href = checkoutUrl;
          } else if (banner) {
            banner.style.display = 'none';
          }
        })();
      </script>

      <div class="auth-head">
        <div class="auth-head-row">
          <div class="auth-head-icon">✦</div>
          <h2 id="ah-title">시작하기</h2>
          <span class="auth-beta-badge">베타 무료</span>
        </div>
        <p id="ah-sub">소셜 계정으로 10초 만에 시작하세요.</p>
