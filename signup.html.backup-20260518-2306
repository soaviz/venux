    /* ───────────── Google Sign-In (실제 동작) ───────────── */
    function getGoogleClientId() {
      try {
        const saved = localStorage.getItem(GOOGLE_CID_KEY);
        if (saved && saved.trim()) return saved.trim();
      } catch {}
      return DEFAULT_GOOGLE_CLIENT_ID;
    }
    function setGoogleClientId(id) {
      try { localStorage.setItem(GOOGLE_CID_KEY, id || ''); } catch {}
    }

    // JWT 디코드 (header.payload.signature)
    function decodeJwt(token) {
      try {
        const payload = token.split('.')[1];
        const json = atob(payload.replace(/-/g, '+').replace(/_/g, '/'));
        return JSON.parse(decodeURIComponent(escape(json)));
      } catch { return null; }
    }

    function setGsiStatus(msg, type = '') {
      const s = $('#gsi-status');
      if (!s) return;
      if (!msg) { s.style.display = 'none'; return; }
      s.style.display = '';
      s.style.color = type === 'error' ? 'var(--danger)' : type === 'warn' ? 'var(--warn)' : 'var(--text-faint)';
      s.innerHTML = msg;
    }
    function showGsiHelper(reason) {
      // Google 사용 불가 케이스 → 깔끔한 helper 버튼만 보임
      $('#gsi-block').style.display = 'none';
      const helper = $('#gsi-helper');
      helper.style.display = '';
      helper._reason = reason;
      // 화면에 즉시 이유 표시
      const reasons = {
        file:    { msg: '⚠ <code>file://</code> 환경 — 로컬 서버 필요. <strong>설정 →</strong> 클릭', type: 'warn' },
        blocked: { msg: '⚠ Google SDK 차단됨 — 광고차단기 OFF 후 새로고침', type: 'error' },
        nocid:   { msg: '⚠ Client ID 미설정 — 관리자에게 문의하세요', type: 'warn' },
      };
      const info = reasons[reason] || { msg: '⚠ Google 로그인 비활성 — <strong>설정 →</strong> 클릭', type: 'warn' };
      setGsiStatus(info.msg, info.type);
    }
    function hideGsiHelper() {
      $('#gsi-helper').style.display = 'none';
      $('#gsi-block').style.display = '';
    }
    function renderGoogleButton() {
      const wrap = $('#gsi-btn-wrap');
      const fallback = $('#gsi-fallback');
      const fbLabel = $('#gsi-fb-label');
      const cid = getGoogleClientId();

      // ── Supabase 우선: GIS 대신 Supabase OAuth 사용 ──
      if (_sb) {
        wrap.style.display = 'none';
        fallback.style.display = '';
        if (fbLabel) fbLabel.textContent = MODE === 'login' ? 'Google로 로그인' : 'Google로 계속하기';
        fallback.onclick = (e) => { e.preventDefault(); startSupabaseGoogleLogin(); };
        hideGsiHelper();
        setGsiStatus('');
        return;
      }

      // ── 진단 1: file:// 프로토콜 체크 ──
      if (location.protocol === 'file:') {
        showGsiHelper('file');
        return;
      }

      // ── 진단 2: GSI 라이브러리 로드 대기 ──
      if (typeof google === 'undefined' || !google.accounts?.id) {
        wrap.style.display = 'none';
        fallback.style.display = '';
        fbLabel.textContent = 'Google 로딩 중…';
        _gsiRetries++;
        if (_gsiRetries >= 12) {
          showGsiHelper('blocked');
          return;
        }
        setTimeout(renderGoogleButton, 600);
        return;
      }

      // ── 진단 3: Client ID 미설정 ──
      if (!cid) {
        wrap.innerHTML = '';
        wrap.style.display = 'none';
        fallback.style.display = '';
        fbLabel.textContent = 'Google 로그인 — Client ID 미설정';
        setGsiStatus('우측 ⚙ 클릭하여 OAuth Client ID 등록', 'warn');
        return;
      }

      // ── 정상: GSI 초기화 + 버튼 렌더 ──
      if (!_gsiInited) {
        try {
          google.accounts.id.initialize({
            client_id: cid,
            callback: handleGoogleCredential,
            ux_mode: 'popup',
            auto_select: false,
          });
          _gsiInited = true;
        } catch (e) {
          console.error('GSI init failed', e);
          wrap.style.display = 'none';
          fallback.style.display = '';
          fbLabel.textContent = 'Google 초기화 실패';
          setGsiStatus('⚠ ' + (e.message || 'Google 초기화 에러'), 'error');
          return;
        }
      }
      hideGsiHelper();   // 정상 경로 → helper 숨김
      wrap.style.display = '';
      fallback.style.display = 'none';
      setGsiStatus('');
      wrap.innerHTML = '';
      try {
        google.accounts.id.renderButton(wrap, {
          theme: 'filled_black',
          text: MODE === 'login' ? 'signin_with' : 'continue_with',
          size: 'large',
          width: Math.min(380, wrap.clientWidth || 320),
          shape: 'rectangular',
          locale: 'ko',
        });
      } catch (e) {
        console.warn('GSI render', e);
