        close();
        _gsiInited = false;
        renderGoogleButton();
        showToast('✓ Google Sign-In 활성화됨', 'ok');
      };
    }

    // GSI 라이브러리가 로드되면 자동 시도
    setTimeout(renderGoogleButton, 800);

    /* ───────────── Vault crypto ───────────── */
    function b64(bytes) { let s = ''; for (const b of bytes) s += String.fromCharCode(b); return btoa(s); }
    function fromB64(b64) { const s = atob(b64); const out = new Uint8Array(s.length); for (let i = 0; i < s.length; i++) out[i] = s.charCodeAt(i); return out; }

    function openDB() {
      const db = new Dexie('soaviz_v3');
      db.version(1).stores({
        secrets: 'id, kind', kv: 'k',
        projects: 'id, *tags, updatedAt, archived',
        episodes: 'id, parentId, number, updatedAt, status, archived',
        scenes: 'id, parentId, number, updatedAt, status, archived',
        shots: 'id, parentId, number, updatedAt, status, archived, storageTier',
        characters: 'id, projectId, name, updatedAt, archived',
        styles: 'id, projectId, scope, updatedAt, archived',
        refs: 'id, projectId, source, updatedAt, archived',
        refClips: 'id, parentId, projectId, category, updatedAt, archived',
        compares: 'id, projectId, shotId, status, updatedAt, archived',
        prompts: 'id, projectId, promptType, shotId, status, updatedAt, archived',
        assets: 'id, projectId, type, shotId, promptId, parentAssetId, status, storageTier, updatedAt, archived',
        activities: 'id, projectId, date, activityType, assetId, timestamp',
        goals: 'id, projectId, deadlineDate, updatedAt, archived',
        blobs: 'id, kind, size, createdAt',
      });
      return db;
    }

    async function deriveKey(passphrase, salt) {
      const baseKey = await crypto.subtle.importKey('raw', new TextEncoder().encode(passphrase), 'PBKDF2', false, ['deriveKey']);
      return crypto.subtle.deriveKey(
        { name: 'PBKDF2', salt, iterations: 250000, hash: 'SHA-256' },
        baseKey, { name: 'AES-GCM', length: 256 }, false, ['encrypt', 'decrypt']
      );
    }
    async function setupVault(passphrase) {
      try {
        const db = openDB();
        await db.open();
        // 이미 vault가 있는 경우 보존, 새로 만들면 verifier만 갱신
        const salt = crypto.getRandomValues(new Uint8Array(16));
        const masterKey = await deriveKey(passphrase, salt);
        const iv = crypto.getRandomValues(new Uint8Array(12));
        const ct = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, masterKey, new TextEncoder().encode('soaviz-verifier-v1'));
        await db.kv.put({ k: 'vault.salt', v: b64(salt) });
        await db.kv.put({ k: 'vault.verifier', v: JSON.stringify({ iv: b64(iv), ct: b64(new Uint8Array(ct)) }) });
        return true;
      } catch (e) { console.error('Vault setup failed', e); return false; }
    }
    async function verifyVault(passphrase) {
      try {
        const db = openDB();
        await db.open();
        const saltRec = await db.kv.get('vault.salt');
        const verRec = await db.kv.get('vault.verifier');
        if (!saltRec || !verRec) return null;
        const salt = fromB64(saltRec.v);
        const tmpKey = await deriveKey(passphrase, salt);
        const verifier = JSON.parse(verRec.v);
        try {
          const pt = await crypto.subtle.decrypt(
            { name: 'AES-GCM', iv: fromB64(verifier.iv) },
            tmpKey,
            fromB64(verifier.ct)
          );
          if (new TextDecoder().decode(pt) === 'soaviz-verifier-v1') return true;
          return false;
        } catch { return false; }
      } catch (e) { console.error('Vault verify failed', e); return null; }
    }

    /* ───────────── Email Submit ───────────── */
    const passInput = $('#su-pass');
    const pass2Input = $('#su-pass2');
    const pass2Err = $('#su-pass2-err');
    const submitBtn = $('#auth-submit');
    const submitLabel = $('#submit-label');

    function passStrength(s) {
      let n = 0;
      if (s.length >= 6) n++;
      if (s.length >= 10) n++;
      if (/[A-Z]/.test(s) && /[a-z]/.test(s)) n++;
      if (/[0-9]/.test(s)) n++;
      if (/[^A-Za-z0-9]/.test(s)) n++;
      return Math.min(4, n);
    }
    const sBars = $$('#su-strength .pass-strength-bar');
    passInput.addEventListener('input', () => {
      if (MODE !== 'signup') return;
      const sc = passStrength(passInput.value);
      sBars.forEach((b, i) => {
        b.classList.remove('on', 'warn', 'weak');
        if (i < sc) {
          if (sc <= 1) b.classList.add('weak');
          else if (sc <= 2) b.classList.add('warn');
          else b.classList.add('on');
        }
      });
    });
    function checkMatch() {
      if (MODE !== 'signup') return true;
      const a = passInput.value, b = pass2Input.value;
      const bad = b && a && a !== b;
      pass2Err.classList.toggle('show', bad);
      return !bad;
    }
    pass2Input.addEventListener('input', checkMatch);
    passInput.addEventListener('input', checkMatch);

    $('#email-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = $('#su-email').value.trim();
      const pass = passInput.value;

      if (MODE === 'login') {
        if (pass.length < 6) { showToast('패스프레이즈를 입력하세요', 'error'); return; }
        submitBtn.classList.add('loading');
        submitBtn.disabled = true;
        submitLabel.textContent = '확인 중…';
        try {
          const ok = await verifyVault(pass);
          if (ok === null) {
            showToast('계정이 없습니다 — 회원가입 탭에서 시작하세요', 'error');
            setMode('signup');
          } else if (ok === false) {
            const errEl = $('#su-pass-err');
            errEl.textContent = '패스프레이즈가 일치하지 않습니다';
            errEl.classList.add('show');
            showToast('❌ 패스프레이즈 불일치', 'error');
          } else {
            const cur = getProfile() || {};
            const nextProfile = {
              ...cur,
              name: cur.name || (email ? email.split('@')[0] : 'soaviz user'),
              email: email || cur.email,
              authProvider: cur.authProvider || 'email',
              lastLogin: Date.now(),
              updatedAt: Date.now(),
              version: 'v3',
            };
            submitLabel.textContent = '로딩…';
            finishAuth(nextProfile, `✓ 환영합니다 ${nextProfile.name || ''}`);
            return;
          }
        } catch (err) { showToast('로그인 오류: ' + (err.message || ''), 'error'); }
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
        submitLabel.textContent = '로그인';
        return;
      }

      const name = $('#su-name').value.trim();
      const pass2 = pass2Input.value;
      if (!name) { showToast('이름을 입력하세요', 'error'); return; }
      if (pass.length < 6) { showToast('패스프레이즈는 6자 이상', 'error'); return; }
      if (pass !== pass2) { pass2Err.classList.add('show'); showToast('패스프레이즈 불일치', 'error'); return; }
      if (email && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { showToast('이메일 형식이 올바르지 않습니다', 'error'); return; }

      submitBtn.classList.add('loading');
      submitBtn.disabled = true;
      submitLabel.textContent = '계정 생성 중…';
      try {
        const ok = await setupVault(pass);
        if (!ok) {
          showToast('Vault 설정 실패', 'error');
          submitBtn.classList.remove('loading'); submitBtn.disabled = false; submitLabel.textContent = '계정 만들기';
          return;
        }
        finishAuth({
          name, email,
          authProvider: 'email',
          createdAt: Date.now(),
          updatedAt: Date.now(),
          version: 'v3',
        }, `✓ 환영합니다 ${name}님`);
        submitLabel.textContent = '로딩…';
      } catch (err) {
        showToast('오류: ' + (err.message || ''), 'error');
        submitBtn.classList.remove('loading'); submitBtn.disabled = false; submitLabel.textContent = '계정 만들기';
      }
    });

    if (window.location.protocol === 'file:') {
      document.querySelectorAll('[data-file-href]').forEach(function(link) {
        link.setAttribute('href', link.getAttribute('data-file-href'));
      });
    }
  </script>
</body>
